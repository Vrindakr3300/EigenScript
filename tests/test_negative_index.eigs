# Negative indexing (0.13.0).
checks is 0
passed is 0

define check(label, got, want) as:
    checks is checks + 1
    if got == want:
        passed is passed + 1
    else:
        print of ("MISMATCH " + label + ": got=" + str of got + " want=" + str of want)

# 1. List get with negative index.
a is [10, 20, 30, 40, 50]
check of ["1a", a[-1], 50]
check of ["1b", a[-2], 40]
check of ["1c", a[-5], 10]

# 2. List set with negative index.
b is [1, 2, 3, 4, 5]
b[-1] is 99
b[-3] is 77
check of ["2a", str of b, "[1, 2, 77, 4, 99]"]

# 3. String char with negative index.
s is "hello"
check of ["3a", s[-1], "o"]
check of ["3b", s[-5], "h"]

# 4. Buffer (zeros) get/set with negative index.
buf is zeros of 4
buf[-1] is 9
buf[-2] is 8
check of ["4a", buf[-1], 9]
check of ["4b", buf[-2], 8]
check of ["4c", buf[0], 0]
check of ["4d", buf[1], 0]

# 5. Out-of-range negative raises (caught via try/catch).
err is null
try:
    _ is a[-6]
catch e:
    err is e
checks is checks + 1
if err != null:
    passed is passed + 1
else:
    print of "MISMATCH 5a: expected error from a[-6]"

# 6. Negative resolves before bounds: -len is valid, -(len+1) is not.
c is [100, 200, 300]
check of ["6a", c[-3], 100]
err2 is null
try:
    _ is c[-4]
catch e:
    err2 is e
checks is checks + 1
if err2 != null:
    passed is passed + 1
else:
    print of "MISMATCH 6b: expected error from c[-4]"

# 7. Empty list: any negative is out of range.
d is []
err3 is null
try:
    _ is d[-1]
catch e:
    err3 is e
checks is checks + 1
if err3 != null:
    passed is passed + 1
else:
    print of "MISMATCH 7a: expected error from d[-1]"

# 8. Mixed positive + negative inside same expression.
xs is [1, 2, 3, 4, 5]
check of ["8a", xs[0] + xs[-1], 6]
check of ["8b", xs[-1] - xs[-5], 4]

# 9. Negative index in a hot loop (exercises JIT bail-to-helper path).
sum is 0
i is 0
loop while i < 1000:
    sum is sum + xs[-1]
    i is i + 1
check of ["9a", sum, 5000]

# 10. Negative index on assignment in a hot loop (exercises JIT INDEX_SET bail).
target is zeros of 3
i is 0
loop while i < 500:
    target[-1] is i
    i is i + 1
check of ["10a", target[-1], 499]
check of ["10b", target[2], 499]

if passed == checks:
    print of "All tests passed"
else:
    print of f"FAIL: {passed}/{checks} passed"
