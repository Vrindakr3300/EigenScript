# Default parameter values (0.13.0).
checks is 0
passed is 0

define check(label, got, want) as:
    checks is checks + 1
    if got == want:
        passed is passed + 1
    else:
        print of ("MISMATCH " + label + ": got=" + str of got + " want=" + str of want)

# 1. Basic default fires when caller omits the arg.
define greet(name, salutation is "hello") as:
    return salutation + ", " + name

check of ["1a", greet of "world", "hello, world"]
check of ["1b", greet of ["world", "hey"], "hey, world"]

# 2. Multiple trailing defaults.
define rect(w, h is 1, fill is "x") as:
    return fill + "/" + str of w + "x" + str of h

check of ["2a", rect of 4, "x/4x1"]
check of ["2b", rect of [4, 2], "x/4x2"]
check of ["2c", rect of [4, 2, "o"], "o/4x2"]

# 3. Default expression can reference earlier params.
define pair(a, b is a * 2) as:
    return [a, b]

check of ["3a", str of (pair of 5), "[5, 10]"]
check of ["3b", str of (pair of [5, 7]), "[5, 7]"]

# 4. Defaults re-evaluate every call (side-effect counter).
count is 0
define fresh() as:
    count is count + 1
    return count

define tick(label, t is fresh of null) as:
    return label + "@" + str of t

check of ["4a", tick of "a", "a@1"]
check of ["4b", tick of "b", "b@2"]
check of ["4c", tick of ["c", 99], "c@99"]
check of ["4d", tick of "d", "d@3"]

# 5. Explicit null is a real value — defaults DO NOT fire.
define show(x is "fallback") as:
    if x == null:
        return "got-null"
    return "got=" + str of x

check of ["5a", show of [], "got=fallback"]
check of ["5b", show of null, "got-null"]
check of ["5c", show of "v", "got=v"]

# 6. Default referencing an outer variable.
multiplier is 3
define scale(x, k is multiplier) as:
    return x * k

check of ["6a", scale of 4, 12]
multiplier is 10
check of ["6b", scale of 4, 40]

# 7. Recursion with a default-bottomed accumulator.
define fact(n, acc is 1) as:
    if n <= 1:
        return acc
    return fact of [n - 1, acc * n]

check of ["7a", fact of 5, 120]
check of ["7b", fact of [5, 2], 240]

# 8. Issue #155 — defaults must not clobber explicit args on entry
#    paths that go through vm_execute. spawn binds args via
#    env_set_local then calls vm_execute; the base frame's call_argc
#    used to read stale stack memory, so OP_DEFAULT_PARAM could fire
#    over a slot the caller did supply (most reproducible on a fresh
#    thread, where the frame storage is zeroed → call_argc=0 → every
#    default fires).
define worker(a, b is 100) as:
    return a + b

t is spawn of [worker, 1, 2]
check of ["8a", thread_join of t, 3]

t is spawn of [worker, 7, 11]
check of ["8b", thread_join of t, 18]

# Both args explicit on a 3-param fn with two defaults.
define triple(a, b is 10, c is 100) as:
    return a + b + c

t is spawn of [triple, 1, 2, 3]
check of ["8c", thread_join of t, 6]

if passed == checks:
    print of "All tests passed"
else:
    print of f"FAIL: {passed}/{checks} passed"
