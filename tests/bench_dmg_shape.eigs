# DMG-shaped workload: dispatch-table interpreter over a byte buffer.
# Mirrors the hot loop of the Game Boy core: fetch8 from a buffer,
# dispatch of [_op_table, op, ctx], register dict mutations.

mem is buffer of 65536
i is 0
unobserved:
    loop while i < 65536:
        mem[i] is i % 8
        i is i + 1

ctx is {"a": 0, "b": 0, "pc": 0, "cycles": 0}

define op0(c) as:
    c.a is c.a + 1
    return 4
define op1(c) as:
    c.b is c.b + c.a
    return 4
define op2(c) as:
    c.a is c.a & 255
    return 8
define op3(c) as:
    c.b is c.b ^ c.a
    return 4
define op4(c) as:
    c.a is (c.a << 1) & 255
    return 8
define op5(c) as:
    c.b is (c.b >> 1)
    return 4
define op6(c) as:
    c.a is c.a | 16
    return 4
define op7(c) as:
    c.b is c.b % 199
    return 12

table is [op0, op1, op2, op3, op4, op5, op6, op7]

t0 is monotonic_ms of null
steps is 0
unobserved:
    loop while steps < 500000:
        pc is ctx.pc
        op is mem[pc]
        handler is table[op]
        cyc is handler of ctx
        ctx.cycles is ctx.cycles + cyc
        ctx.pc is (pc + 1) % 65536
        steps is steps + 1
t1 is monotonic_ms of null
print of f"dmg-shape 500k steps: {t1 - t0}ms  cycles={ctx.cycles} a={ctx.a} b={ctx.b}"
