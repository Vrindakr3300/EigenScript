# Destructuring assignment (0.13.0).
checks is 0
passed is 0

define check(label, got, want) as:
    checks is checks + 1
    if got == want:
        passed is passed + 1
    else:
        print of ("MISMATCH " + label + ": got=" + str of got + " want=" + str of want)

# 1. Basic two-name destructure.
[a, b] is [10, 20]
check of ["1a", a, 10]
check of ["1b", b, 20]

# 2. Three-name destructure.
[x, y, z] is [1, 2, 3]
check of ["2a", x, 1]
check of ["2b", y, 2]
check of ["2c", z, 3]

# 3. RHS is an expression returning a list.
define pair() as:
    return [100, 200]
[p, q] is pair of null
check of ["3a", p, 100]
check of ["3b", q, 200]

# 4. RHS evaluated once (side-effect counter).
cnt is 0
define mkpair() as:
    cnt is cnt + 1
    return [cnt, cnt * 10]
[u, v] is mkpair of null
check of ["4a", u, 1]
check of ["4b", v, 10]
check of ["4c", cnt, 1]
[u2, v2] is mkpair of null
check of ["4d", u2, 2]
check of ["4e", v2, 20]
check of ["4f", cnt, 2]

# 5. Swap via destructure.
i is 1
j is 2
[i, j] is [j, i]
check of ["5a", i, 2]
check of ["5b", j, 1]

# 6. Single-element pattern.
[only] is [42]
check of ["6a", only, 42]

# 7. Length-mismatch raises.
err is null
try:
    [r, s] is [1, 2, 3]
catch e:
    err is e
checks is checks + 1
if err != null:
    passed is passed + 1
else:
    print of "MISMATCH 7a: expected error from length mismatch"

# 8. Non-list raises.
err2 is null
try:
    [r2, s2] is 99
catch e:
    err2 is e
checks is checks + 1
if err2 != null:
    passed is passed + 1
else:
    print of "MISMATCH 8a: expected error from non-list rhs"

# 9. Destructuring works inside a function (locals).
define use() as:
    [aa, bb, cc] is [7, 8, 9]
    return aa + bb + cc
check of ["9a", use of null, 24]

# 10. Destructure with a computed RHS.
xs is [3, 4, 5]
[head, mid, tail] is xs
check of ["10a", head, 3]
check of ["10b", mid, 4]
check of ["10c", tail, 5]

# 11. Re-destructure (reassign already-existing names).
[a, b] is [99, 100]
check of ["11a", a, 99]
check of ["11b", b, 100]

# 12. List literal as expression still parses (lookahead must not eat it).
ys is [1, 2, 3]
check of ["12a", len of ys, 3]
check of ["12b", ys[0], 1]

# 13. Issue #156 — module-level destructured names must be registered as
#     module names. Without it, `gx is 999` inside a function silently
#     creates a local and the global stays 100.
[gx_dest, gy_dest] is [100, 200]
define bump_gx() as:
    gx_dest is 999
bump_gx of []
check of ["13a", gx_dest, 999]
check of ["13b", gy_dest, 200]

# Plain-assigned twin must keep the same global-write semantics — both
# paths should behave identically.
ax_plain is 100
define bump_ax() as:
    ax_plain is 999
bump_ax of []
check of ["13c", ax_plain, 999]

# 14. Issue #156 — closure capture through a destructure RHS. The
#     inner closure references `pair_src` only via destructure expr.
define outer_dest() as:
    pair_src is [7, 11]
    define inner() as:
        [hh, tt] is pair_src
        return hh + tt
    return inner of []
check of ["14a", outer_dest of null, 18]

if passed == checks:
    print of "All tests passed"
else:
    print of f"FAIL: {passed}/{checks} passed"
