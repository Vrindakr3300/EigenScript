# Function-call argument unpacking + reference aliasing contract.
# See docs/LANGUAGE_CONTRACT.md.

define two(a, b) as:
    return a - b
define one(a) as:
    return a
define three(a, b, c) as:
    return a + b + c

# Multi-param functions spread a list argument across parameters
assert of [(two of [10, 3]) == 7, "2-param spreads list"]
assert of [(three of [1, 2, 3]) == 6, "3-param spreads list"]
assert of [(two of [10, 3, 99]) == 7, "extra list elements ignored"]

# A one-param function binds the WHOLE argument (a list is not spread)
assert of [(one of [7]) == [7], "1-param binds whole list"]
assert of [(one of 5) == 5, "1-param binds scalar"]

# Issue #153: a length-1 literal list does NOT spread, even to a
# multi-param callee. f of [x] binds [x] as one arg; the second param
# stays unset (null) or takes its default. Use f of (x) for the
# one-arg spread case.
define mp(a, b) as:
    return [a, b]
assert of [(mp of [7]) == [[7], null], "1-element list to 2-param: binds whole list, b=null"]
assert of [(mp of (7)) == [7, null], "paren form: 1 arg to 2-param spreads, b=null"]

define mpd(a, b is 100) as:
    return a + b
assert of [(mpd of (5)) == 105, "paren form lets default fire"]
# fib-style recursion footgun avoided by paren form
define fib(n, memo is 0) as:
    if n < 2:
        return n
    return (fib of (n - 1)) + (fib of (n - 2))
assert of [(fib of 10) == 55, "fib paren form recurses correctly"]

# Issue #154: f of [] lowers to a zero-arg call for every callee, so a
# multi-param callee gets all params = null (or defaults fire). The
# single-param non-defaulted special case preserves the pre-0.13.0
# "binds the empty list" shape so `one of []` -> a = [] still works.
assert of [(mp of []) == [null, null], "multi-param of []: a=null, b=null"]
assert of [(one of []) == [], "1-param of []: preserves empty-list bind"]
define hd(x is 99) as:
    return x
assert of [(hd of []) == 99, "1-param defaulted of []: default fires"]
# f of [] is argc=0; defaults only fire when argc >= first_default.
# Here first_default=1 but argc=0, so the b-default doesn't fire either.
define mpd2(a, b is 100) as:
    return [a, b]
assert of [(mpd2 of []) == [null, null], "multi-param defaulted of []: a=null, b=null (argc<first_default)"]

# Assignment binds a reference: lists/dicts are shared, not copied
a is [1, 2, 3]
b is a
b[0] is 99
assert of [a[0] == 99, "list assignment aliases (shared reference)"]

d is {"k": 1}
e is d
e.k is 99
assert of [d.k == 99, "dict assignment aliases"]

# Scalars are immutable, so reassigning an alias never affects the original
x is 5
y is x
y is y + 1
assert of [x == 5, "scalar reassignment does not affect original"]

print of "All tests passed"
