# Streaming subprocess I/O (0.13.0).
checks is 0
passed is 0

define check(label, got, want) as:
    checks is checks + 1
    if got == want:
        passed is passed + 1
    else:
        print of ("MISMATCH " + label + ": got=" + str of got + " want=" + str of want)

# 1. proc_spawn returns a 3-element [pid, in_fd, out_fd] handle for echo.
h is proc_spawn of ["/bin/echo", "hello"]
check of ["1a", len of h, 3]
check of ["1b", h[0] > 0, 1]
check of ["1c", h[1] >= 0, 1]
check of ["1d", h[2] >= 0, 1]

# 2. proc_read_line yields the line without the trailing newline.
line is proc_read_line of h[2]
check of ["2a", line, "hello"]

# 3. proc_read_line returns null after EOF on a finished child.
eof is proc_read_line of h[2]
check of ["3a", eof, null]
proc_close of h[1]
proc_close of h[2]
code is proc_wait of h[0]
check of ["3b", code, 0]

# 4. cat: stdin → stdout round-trip via separate read+write.
h is proc_spawn of ["/bin/cat"]
n is proc_write of [h[1], "round\n"]
check of ["4a", n, 6]
line is proc_read_line of h[2]
check of ["4b", line, "round"]
proc_close of h[1]
post_eof is proc_read_line of h[2]
check of ["4c", post_eof, null]
proc_close of h[2]
code is proc_wait of h[0]
check of ["4d", code, 0]

# 5. wc -l: write three lines, close stdin, read count.
h is proc_spawn of ["/usr/bin/wc", "-l"]
proc_write of [h[1], "a\nb\nc\n"]
proc_close of h[1]
out is proc_read_line of h[2]
check of ["5a", out, "3"]
proc_close of h[2]
code is proc_wait of h[0]
check of ["5b", code, 0]

# 6. proc_read returns a raw chunk up to max_bytes.
h is proc_spawn of ["/bin/echo", "abcdef"]
proc_close of h[1]
chunk is proc_read of [h[2], 3]
check of ["6a", chunk, "abc"]
rest is proc_read of [h[2], 16]
# rest should be "def\n" or whatever remains (read may return fewer than max).
check of ["6b", rest != null, 1]
proc_close of h[2]
code is proc_wait of h[0]
check of ["6c", code, 0]

# 7. Nonexistent program: spawn succeeds, child _exit(127) → exit code 127.
h is proc_spawn of ["/no/such/binary/anywhere"]
check of ["7a", h[0] > 0, 1]
proc_close of h[1]
proc_close of h[2]
code is proc_wait of h[0]
check of ["7b", code, 127]

# 8. proc_write after the child has exited returns -1 (SIGPIPE → EPIPE).
h is proc_spawn of ["/bin/echo", "x"]
proc_close of h[1]
proc_close of h[2]
proc_wait of h[0]
# Spawn a fresh one and let it exit; write after exit should fail.
h is proc_spawn of ["/bin/true"]
# Give /bin/true a moment to exit.
i is 0
loop while i < 100000:
    i is i + 1
n is proc_write of [h[1], "data\n"]
check of ["8a", n, -1]
proc_close of h[1]
proc_close of h[2]
proc_wait of h[0]

# 9. proc_close is idempotent on a bad fd.
proc_close of 9999
check of ["9a", 1, 1]

# 10. proc_spawn with empty argv returns the failure sentinel.
bad is proc_spawn of []
check of ["10a", bad[0], -1]
check of ["10b", bad[1], -1]
check of ["10c", bad[2], -1]

# 11. proc_wait on -1 returns -1.
check of ["11a", proc_wait of -1, -1]

# 12. proc_read_line on a closed fd returns null.
check of ["12a", proc_read_line of 9999, null]

# 13. Issue #149 — pipe fds carry FD_CLOEXEC so they don't leak into
#     subsequent children. Spawn a long-lived cat, then exec_capture a
#     checker that inspects /proc/self/fd for cat's parent-side fds.
h is proc_spawn of ["/bin/cat"]
in_fd is h[1]
out_fd is h[2]
script is "test -e /proc/self/fd/" + str of in_fd + " && echo present || echo absent"
res is exec_capture of ["/bin/sh", "-c", script]
check of ["13a", res[0], 0]
check of ["13b", res[1], "absent\n"]
script2 is "test -e /proc/self/fd/" + str of out_fd + " && echo present || echo absent"
res2 is exec_capture of ["/bin/sh", "-c", script2]
check of ["13c", res2[1], "absent\n"]
proc_close of in_fd
proc_close of out_fd
proc_wait of h[0]

# 14. Issue #150 — exec_capture's child resets SIGPIPE to SIG_DFL even after
#     proc_spawn has installed SIG_IGN process-wide. Without the reset,
#     `yes | head -1` hangs: head exits, but yes inherits SIG_IGN and loops
#     forever filling the pipe buffer.
res is exec_capture of [["/bin/sh", "-c", "yes | head -n 1"], 5]
check of ["14a", res[0], 0]
check of ["14b", res[1], "y\n"]

if passed == checks:
    print of "All tests passed"
else:
    print of f"FAIL: {passed}/{checks} passed"
