# test_closure_cycles.eigs — functional correctness of every closure /
# value cycle shape, all reclaimed by the cycle collector
# (docs/CLOSURE_CYCLE_GC.md). This test locks two things: the shapes
# keep computing the RIGHT VALUES, and every one of them is leak-clean.
# run_all_tests.sh section [87] gates this file STRICTLY — a
# LeakSanitizer exit here is a collector regression, not a tolerated
# known leak.
#
# NB: a no-parameter `define` has an implicit parameter `n` — never name
# a captured mutable variable `n` or the implicit param shadows it.

load_file of "lib/test.eigs"

# --- Direct closure cycle: E binds `inner`, `inner` captures E ---
define outer as:
    x is 5
    define inner as:
        return x + 1
    return inner
f is outer of null
assert_eq of [f of null, 6, "direct closure cycle returns captured value"]

# --- List of closures returned (env<->fn cycle, container is an extra holder) ---
define make_ops as:
    s is 7
    add is (a) => a + s
    mul is (a) => a * s
    return [add, mul]
ops is make_ops of null
assert_eq of [ops[0] of 3, 10, "list-closure 0 captures s"]
assert_eq of [ops[1] of 3, 21, "list-closure 1 captures s"]

# --- Mutable counter closure (captured var written across calls) ---
define make_counter as:
    val is 0
    define step as:
        val is val + 1
        return val
    return step
c1 is make_counter of null
assert_eq of [c1 of null, 1, "counter first"]
assert_eq of [c1 of null, 2, "counter second"]
c2 is make_counter of null
assert_eq of [c2 of null, 1, "second counter independent"]
assert_eq of [c1 of null, 3, "first counter unaffected by second"]

# --- Many distinct closures (the formerly-accumulating case) ---
# 500 discarded counter closures: enough to cross the collector's
# capture threshold several times, so mid-run collection (not just the
# exit sweep) is exercised. Values must stay right across collections.
total is 0
i is 0
loop while i < 500:
    ctr is make_counter of null
    total is total + (ctr of null) + (ctr of null)
    i is i + 1
assert_eq of [total, 1500, "500 independent counters each yield 1+2"]

# --- Cycle through a captured container: env -> dict -> fn -> env ---
# The method closure lives inside a dict bound in the env it captures,
# so the cycle runs through a VAL_DICT node, not just env slots.
define make_obj as:
    state is {"count": 0}
    define bump as:
        state.count is state.count + 1
        return state.count
    state.bump is bump
    return state
o is make_obj of null
b is o.bump
assert_eq of [b of null, 1, "dict-cycle method first call"]
assert_eq of [b of null, 2, "dict-cycle method second call"]

# Discarded per-iteration: the dict-routed cycles must be collected
# mid-run just like the plain counter cycles.
j is 0
loop while j < 200:
    obj is make_obj of null
    m is obj.bump
    j is j + (m of null)
assert_eq of [j, 200, "200 discarded dict-cycle objects each bump once"]

# --- Dispatch table of closures (created once — the safe, bounded form) ---
define build_table as:
    base is 100
    h0 is (a) => base + a
    h1 is (a) => base - a
    return [h0, h1]
tbl is build_table of null
assert_eq of [dispatch of [tbl, 0, 5], 105, "dispatch closure 0"]
assert_eq of [dispatch of [tbl, 1, 5], 95, "dispatch closure 1"]

# --- Clean (non-leaking) invariant: self-referential container ---
# These must stay reclaimable; if they start leaking, the ASan tally jumps.
selflist is [1, 2]
append of [selflist, selflist]
assert_eq of [len of selflist, 3, "self-referential list length"]
assert_eq of [selflist[0], 1, "self-referential list element"]

selfdict is {"k": 1}
selfdict.self is selfdict
assert_eq of [selfdict.k, 1, "self-referential dict value"]

# --- Clean invariant: mutual recursion that does not escape ---
define parity as:
    define is_even(m) as:
        if m == 0:
            return 1
        return is_odd of (m - 1)
    define is_odd(m) as:
        if m == 0:
            return 0
        return is_even of (m - 1)
    return is_even of 8
assert_eq of [parity of null, 1, "non-escaping mutual recursion result"]

test_summary of null
