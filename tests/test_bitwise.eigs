# Bitwise operation tests
load_file of "lib/test.eigs"

# AND
assert_eq of [bit_and of [0xFF, 0x0F], 15, "AND FF & 0F"]
assert_eq of [bit_and of [12, 10], 8, "AND 12 & 10"]
assert_eq of [bit_and of [7, 0], 0, "AND 7 & 0"]

# OR
assert_eq of [bit_or of [0xF0, 0x0F], 255, "OR F0 | 0F"]
assert_eq of [bit_or of [4, 2], 6, "OR 4 | 2"]
assert_eq of [bit_or of [0, 0], 0, "OR 0 | 0"]

# XOR
assert_eq of [bit_xor of [0xFF, 0x0F], 240, "XOR FF ^ 0F"]
assert_eq of [bit_xor of [5, 3], 6, "XOR 5 ^ 3"]

# Shift left
assert_eq of [bit_shl of [1, 0], 1, "SHL 1 << 0"]
assert_eq of [bit_shl of [1, 3], 8, "SHL 1 << 3"]
assert_eq of [bit_shl of [5, 2], 20, "SHL 5 << 2"]

# Shift right
assert_eq of [bit_shr of [8, 3], 1, "SHR 8 >> 3"]
assert_eq of [bit_shr of [255, 4], 15, "SHR 255 >> 4"]

# Bitmask patterns
unlocked is 0
unlocked is bit_or of [unlocked, bit_shl of [1, 0]]
unlocked is bit_or of [unlocked, bit_shl of [1, 2]]
assert_eq of [bit_and of [unlocked, 1], 1, "bitmask bit 0 set"]
assert_eq of [bit_and of [unlocked, 2], 0, "bitmask bit 1 clear"]
assert_eq of [bit_and of [unlocked, 4], 4, "bitmask bit 2 set"]

# Shift amount masking — out-of-range shifts are defined, not UB
assert_eq of [bit_shl of [1, 32], 1, "SHL 1 << 32 masks to << 0"]
assert_eq of [bit_shl of [1, 33], 2, "SHL 1 << 33 masks to << 1"]
assert_eq of [bit_shr of [8, 35], 1, "SHR 8 >> 35 masks to >> 3"]

# Type safety — non-numeric args raise (strict error model, not UB, not 0).
# Builtins:
caught_and is ""
try:
    x is bit_and of ["abc", 5]
catch err:
    caught_and is err
assert_true of [contains of [caught_and, "bit_and"], "bit_and string arg raises"]

caught_or is ""
try:
    x is bit_or of [null, 5]
catch err:
    caught_or is err
assert_true of [contains of [caught_or, "bit_or"], "bit_or null arg raises"]

caught_shl is ""
try:
    x is bit_shl of [[1,2], 4]
catch err:
    caught_shl is err
assert_true of [contains of [caught_shl, "bit_shl"], "bit_shl list arg raises"]

caught_not is ""
try:
    x is bit_not of "abc"
catch err:
    caught_not is err
assert_true of [contains of [caught_not, "bit_not"], "bit_not string arg raises"]

# Operators:
caught_op_and is ""
try:
    x is "a" & 1
catch err:
    caught_op_and is err
assert_true of [contains of [caught_op_and, "cannot apply"], "& string operand raises"]

caught_op_shl is ""
try:
    x is null << 2
catch err:
    caught_op_shl is err
assert_true of [contains of [caught_op_shl, "cannot apply"], "<< null operand raises"]

caught_op_not is ""
try:
    x is ~null
catch err:
    caught_op_not is err
assert_true of [contains of [caught_op_not, "cannot apply"], "~ null operand raises"]

test_summary of null
