# ============================================================
# UI Toolkit Demo — all widget types + new features
# ============================================================
# Run: make gfx && ./src/eigenscript examples/ui_demo.eigs
#
# Features demonstrated:
#   - Theme switching (Ctrl+1/2/3 hotkeys)
#   - Layout containers (hbox/vbox)
#   - Table widget
#   - Toolbar/statusbar widgets
#   - Scrollbar widget
#   - Disabled widgets
#   - Keyboard navigation (Tab/Shift+Tab, Enter, arrows)
#   - Animation (tween)
#   - Tree view, combobox, color picker
#   - Right-click context menus
#   - Drag & drop / reorder
#   - Window resize

import ui

WINDOW_W is 960
WINDOW_H is 620

gfx_open of [WINDOW_W, WINDOW_H, "UI Toolkit Demo"]

# ---- State ----
status_text is "Ready — Tab to navigate, Ctrl+1/2/3 for themes"
_current_theme is "dark"

# ---- Callbacks ----
define on_play(w) as:
    status_text is "Playing..."

define on_stop(w) as:
    status_text is "Stopped"

define on_volume(w) as:
    status_text is f"Volume: {floor of w.value}"

define on_pan(w) as:
    status_text is f"Pan: {floor of w.value}"

define on_mute(w) as:
    if w.value == 1:
        status_text is "Muted"
    else:
        status_text is "Unmuted"

define on_attack(w) as:
    status_text is f"Attack: {floor of (w.value * 100) / 100}"

define on_release(w) as:
    status_text is f"Release: {floor of (w.value * 100) / 100}"

define on_cutoff(w) as:
    status_text is f"Cutoff: {floor of w.value} Hz"

define on_snap(w) as:
    status_text is f"Snap: {w.items[w.selected]}"

define on_tab(w) as:
    status_text is f"Tab: {w.tab_names[w.active]}"

define on_fader(w) as:
    status_text is f"Fader: {floor of w.value} dB"

define on_active(w) as:
    if w.value == 1:
        status_text is "Effect active"
    else:
        status_text is "Effect bypassed"

define on_name_change(w) as:
    status_text is f"Name: {w.text}"

define on_menu_select(m, idx) as:
    item is m.items[idx]
    if (type of item) == "list":
        status_text is f"Menu: {item[0]}"
    else:
        status_text is f"Menu: {item}"

define on_scroll(w) as:
    status_text is f"Scroll: {floor of (w.value * 100)}%"

define on_table_select(w) as:
    if w.selected >= 0 and w.selected < (len of w.rows):
        row is w.rows[w.selected]
        status_text is f"Selected: {row[0]}"

define on_table_sort(w) as:
    dir is "asc"
    if w.sort_asc == 0:
        dir is "desc"
    status_text is f"Sort: column {w.sort_col} {dir}"

define on_disabled_toggle(w) as:
    vol is ui.find_by_id of [root, "volume"]
    pan_s is ui.find_by_id of [root, "pan"]
    if vol != null:
        if w.value == 1:
            vol.enabled is 0
            pan_s.enabled is 0
            status_text is "Sliders disabled"
        else:
            vol.enabled is 1
            pan_s.enabled is 1
            status_text is "Sliders enabled"

# Canvas waveform painter
define paint_waveform(widget, ax, ay) as:
    gfx_rect of [ax, ay, widget.w, widget.h, 20, 20, 30]
    mid_y is ay + floor of (widget.h / 2)
    gfx_line of [ax, mid_y, ax + widget.w, mid_y, 40, 40, 55]
    prev_y is mid_y
    for i in range of widget.w:
        amp is (sin of (i * 0.05)) * (cos of (i * 0.013)) * (widget.h / 3)
        y is mid_y + floor of amp
        gfx_line of [ax + i, prev_y, ax + i + 1, y, 80, 160, 220]
        prev_y is y

define on_wave_mouse(widget, ev) as:
    status_text is f"Wave: x={ev.x} y={ev.y}"

# New feature callbacks
define on_tree_select(w, node) as:
    status_text is f"Tree: {node.text}"

define on_combo_change(w) as:
    if w.selected >= 0 and w.selected < (len of w.items):
        status_text is f"Combobox: {w.items[w.selected]}"

define on_color_change(w) as:
    status_text is f"Color: R={w.color[0]} G={w.color[1]} B={w.color[2]}"

define on_reorder(w, old_idx, new_idx) as:
    # Move item from old_idx to new_idx
    item is w.items[old_idx]
    new_items is []
    for i in range of (len of w.items):
        if i == new_idx and new_idx < old_idx:
            append of [new_items, item]
        if i != old_idx:
            append of [new_items, w.items[i]]
        if i == new_idx and new_idx >= old_idx:
            append of [new_items, item]
    w.items is new_items
    status_text is f"Reordered: {item}"

define on_right_click_table(w, mx, my) as:
    status_text is "Right-clicked table"
    ctx is ui.find_by_id of [root, "table_ctx"]
    if ctx != null:
        ui.show_menu of [ctx, mx, my]

# ---- Build UI ----

root is ui.panel of ["root", 0, 0, WINDOW_W, WINDOW_H]
root.bg is [25, 25, 35]
root.border is null

# -- Toolbar --
tb is ui.toolbar of ["toolbar", 0, 0, WINDOW_W]
ui.add_child of [tb, ui.button of ["play", 0, 0, 60, 24, "Play", on_play]]
ui.add_child of [tb, ui.button of ["stop", 0, 0, 60, 24, "Stop", on_stop]]
ui.add_child of [tb, ui.separator of ["sep1", 0, 0, 24, 1]]
snap_items is ["Off", "1/4", "1/8", "1/16", "1/32", "Beat", "Bar"]
ui.add_child of [tb, ui.dropdown of ["snap", 0, 0, 90, snap_items, 0, on_snap]]
ui.add_child of [tb, ui.text_input of ["track_name", 0, 0, 140, "Track 1", on_name_change]]
ui.add_child of [tb, ui.separator of ["sep2", 0, 0, 24, 1]]
ui.add_child of [tb, ui.label of ["title", 0, 0, "UI Demo"]]

# -- Tabs --
main_tabs is ui.tabs of ["main", 0, 40, WINDOW_W, WINDOW_H - 40 - 24, ["Mix", "Synth", "Wave", "Table", "FX", "Extras"], on_tab]

# --- Mix tab (with hbox/vbox layout) ---
mix_panel is ui.panel of ["mix_content", 0, 0, WINDOW_W, WINDOW_H - 92]
mix_panel.border is null

# Left column: sliders in a vbox
left_col is ui.vbox of ["left_col", 10, 10, 280, 300]
left_col.gap is 8
left_col.padding is 8
left_col.bg is [30, 30, 42]
left_col.border is [50, 50, 65]

ui.add_child of [left_col, ui.label of ["vol_lbl", 0, 0, "Volume"]]
ui.add_child of [left_col, ui.slider of ["volume", 0, 0, 260, 0, 100, 75, on_volume]]
ui.add_child of [left_col, ui.label of ["pan_lbl", 0, 0, "Pan"]]
ui.add_child of [left_col, ui.slider of ["pan", 0, 0, 260, -100, 100, 0, on_pan]]
ui.add_child of [left_col, ui.label of ["mute_lbl", 0, 0, "Mute"]]
ui.add_child of [left_col, ui.toggle of ["mute", 0, 0, 0, on_mute]]
ui.add_child of [left_col, ui.label of ["dis_lbl", 0, 0, "Disable sliders"]]
ui.add_child of [left_col, ui.toggle of ["disable_tog", 0, 0, 0, on_disabled_toggle]]

# Right column: vertical faders in hbox
right_col is ui.hbox of ["right_col", 310, 10, 300, 300]
right_col.gap is 16
right_col.padding is 10
right_col.align is "end"
right_col.bg is [30, 30, 42]
right_col.border is [50, 50, 65]

for ch in range of 4:
    strip is ui.vbox of [f"strip_{ch}", 0, 0, 50, 280]
    strip.gap is 4
    strip.align is "center"
    ui.add_child of [strip, ui.label of [f"ch{ch}_lbl", 0, 0, f"Ch {ch + 1}"]]
    ui.add_child of [strip, ui.vslider of [f"fader_{ch}", 0, 0, 200, -60, 12, 0, on_fader]]
    ui.add_child of [right_col, strip]

# Scrollbar demo
ui.add_child of [mix_panel, ui.label of ["sb_lbl", 640, 10, "Scrollbar"]]
ui.add_child of [mix_panel, ui.scrollbar of ["vscroll", 640, 36, 200, 1, on_scroll]]
ui.add_child of [mix_panel, ui.scrollbar of ["hscroll", 670, 36, 200, 0, on_scroll]]

ui.add_child of [mix_panel, left_col]
ui.add_child of [mix_panel, right_col]

# --- Synth tab ---
synth_panel is ui.panel of ["synth_content", 0, 0, WINDOW_W, WINDOW_H - 92]
synth_panel.border is null

knob_row is ui.hbox of ["knob_row", 10, 10, 400, 80]
knob_row.gap is 20
knob_row.padding is 10
knob_row.align is "center"
knob_row.bg is [30, 30, 42]
knob_row.border is [50, 50, 65]
ui.add_child of [knob_row, ui.knob of ["attack", 0, 0, 44, 0, 1.0, 0.1, on_attack]]
ui.add_child of [knob_row, ui.knob of ["release", 0, 0, 44, 0, 2.0, 0.5, on_release]]
ui.add_child of [knob_row, ui.knob of ["cutoff", 0, 0, 44, 20, 20000, 5000, on_cutoff]]
ui.add_child of [synth_panel, knob_row]

# --- Wave tab ---
wave_panel is ui.panel of ["wave_content", 0, 0, WINDOW_W, WINDOW_H - 92]
wave_panel.border is null
ui.add_child of [wave_panel, ui.canvas of ["waveform", 10, 10, WINDOW_W - 20, 180, paint_waveform, on_wave_mouse]]
ui.add_child of [wave_panel, ui.label of ["wave_hint", 10, 200, "Click the waveform"]]

# --- Table tab ---
table_panel is ui.panel of ["table_content", 0, 0, WINDOW_W, WINDOW_H - 92]
table_panel.border is null

cols is [{"name": "Track", "width": 200}, {"name": "Duration", "width": 120}, {"name": "BPM", "width": 80}, {"name": "Key", "width": 80}, {"name": "Genre", "width": 160}]
tbl is ui.table of ["track_table", 10, 10, 650, 400, cols, on_table_select]
tbl.on_sort is on_table_sort
tbl.on_right_click is on_right_click_table
tbl.rows is [
    ["Midnight Drive", "3:42", "128", "Am", "Synthwave"],
    ["Ocean Breeze", "4:15", "96", "C", "Ambient"],
    ["Neon Lights", "2:58", "140", "Fm", "Electro"],
    ["Summer Rain", "3:30", "110", "G", "Lo-fi"],
    ["Velvet Thunder", "5:02", "150", "Dm", "DnB"],
    ["Crystal Caves", "4:48", "80", "Em", "Downtempo"],
    ["Urban Jungle", "3:15", "130", "Bb", "Hip-Hop"],
    ["Starlight", "4:00", "120", "D", "House"],
    ["Deep Blue", "6:12", "72", "F", "Ambient"],
    ["Electric Dreams", "3:55", "135", "Gm", "Techno"],
    ["Autumn Leaves", "3:22", "95", "A", "Jazz"],
    ["Pulse", "4:30", "145", "Cm", "Trance"],
    ["Horizon", "5:18", "88", "Eb", "Chillout"],
    ["Thunderstorm", "3:48", "160", "Bm", "Metal"],
    ["Coral Reef", "4:05", "105", "Ab", "R&B"]
]

# Right-click menu for table
table_ctx is ui.menu of ["table_ctx", [["Select All", "Ctrl+A"], "Export", "-", "Delete"], on_menu_select]
ui.add_child of [table_panel, table_ctx]
ui.add_child of [table_panel, tbl]

# --- FX tab with scrollable panel and checkboxes ---
fx_panel is ui.panel of ["fx_content", 0, 0, WINDOW_W, WINDOW_H - 92]
fx_panel.border is null

fx_scroll is ui.scroll_panel of ["fx_list", 10, 10, 400, 300]
fx_scroll.content_h is 400
ui.add_child of [fx_scroll, ui.checkbox of ["eq_active", 10, 10, "EQ", 1, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["comp_active", 10, 40, "Compressor", 1, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["rev_active", 10, 70, "Reverb", 0, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["del_active", 10, 100, "Delay", 0, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["cho_active", 10, 130, "Chorus", 0, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["lim_active", 10, 160, "Limiter", 1, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["dist_active", 10, 190, "Distortion", 0, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["flg_active", 10, 220, "Flanger", 0, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["phs_active", 10, 250, "Phaser", 0, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["gate_active", 10, 280, "Noise Gate", 0, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["sat_active", 10, 310, "Saturator", 0, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["wid_active", 10, 340, "Stereo Width", 0, on_active]]
ui.add_child of [fx_scroll, ui.checkbox of ["de_active", 10, 370, "De-Esser", 0, on_active]]
ui.add_child of [fx_panel, fx_scroll]

ctx_menu is ui.menu of ["ctx", ["Cut", "Copy", "Paste", "-", "Delete", "Duplicate"], on_menu_select]
ui.add_child of [fx_panel, ctx_menu]

# --- Extras tab (tree, combobox, color picker, drag-to-reorder) ---
extras_panel is ui.panel of ["extras_content", 0, 0, WINDOW_W, WINDOW_H - 92]
extras_panel.border is null

# Tree view
tree_nodes is [
    {"id": "instruments", "text": "Instruments", "expanded": 1, "children": [
        {"id": "synths", "text": "Synths", "expanded": 0, "children": [
            {"id": "analog", "text": "Analog", "children": []},
            {"id": "fm", "text": "FM", "children": []},
            {"id": "wavetable", "text": "Wavetable", "children": []}
        ]},
        {"id": "samplers", "text": "Samplers", "expanded": 0, "children": [
            {"id": "drums", "text": "Drums", "children": []},
            {"id": "strings", "text": "Strings", "children": []}
        ]},
        {"id": "piano", "text": "Piano", "children": []}
    ]},
    {"id": "effects", "text": "Effects", "expanded": 1, "children": [
        {"id": "reverb", "text": "Reverb", "children": []},
        {"id": "delay", "text": "Delay", "children": []},
        {"id": "eq", "text": "Equalizer", "children": []}
    ]},
    {"id": "routing", "text": "Routing", "children": []}
]
tree_w is ui.tree of ["demo_tree", 10, 10, 220, 300, tree_nodes, on_tree_select]
ui.add_child of [extras_panel, tree_w]

# Combobox
combo_items is ["Sine", "Square", "Sawtooth", "Triangle", "Noise", "Pulse", "Custom"]
combo_w is ui.combobox of ["waveform_combo", 250, 10, 180, combo_items, on_combo_change]
ui.add_child of [extras_panel, ui.label of ["combo_lbl", 250, 40, "Waveform"]]
ui.add_child of [extras_panel, combo_w]

# Color picker
cpick is ui.color_picker of ["demo_color", 250, 70, on_color_change]
ui.add_child of [extras_panel, cpick]

# Draggable item list (drag to reorder)
reorder_items is ["Kick", "Snare", "Hi-hat", "Clap", "Rim", "Tom", "Crash", "Ride"]
reorder_list is ui.item_list of ["reorder_list", 460, 10, 180, 300, reorder_items, null]
reorder_list.draggable is 1
reorder_list.on_reorder is on_reorder
ui.add_child of [extras_panel, ui.label of ["reorder_lbl", 460, 318, "Drag to reorder"]]
ui.add_child of [extras_panel, reorder_list]

# Wire tab panels
append of [main_tabs.tab_panels, mix_panel]
append of [main_tabs.tab_panels, synth_panel]
append of [main_tabs.tab_panels, wave_panel]
append of [main_tabs.tab_panels, table_panel]
append of [main_tabs.tab_panels, fx_panel]
append of [main_tabs.tab_panels, extras_panel]

# -- Statusbar --
sb is ui.statusbar of ["status", 0, WINDOW_H - 24, WINDOW_W]
sb.sections is [
    {"text": "Ready", "width": 0, "flex": 1},
    {"text": "Dark", "width": 100, "flex": 0},
    {"text": "Tab: navigate", "width": 160, "flex": 0}
]

# -- Assemble --
ui.add_child of [root, tb]
ui.add_child of [root, main_tabs]
ui.add_child of [root, sb]

# ---- Hotkeys for theme switching ----
define set_dark() as:
    ui.set_theme of (ui.theme_dark of null)
    _current_theme is "dark"
    status_text is "Theme: Dark"

define set_light() as:
    ui.set_theme of (ui.theme_light of null)
    _current_theme is "light"
    status_text is "Theme: Light"

define set_hc() as:
    ui.set_theme of (ui.theme_high_contrast of null)
    _current_theme is "high contrast"
    status_text is "Theme: High Contrast"

ui.register_hotkey of ["ctrl+1", set_dark]
ui.register_hotkey of ["ctrl+2", set_light]
ui.register_hotkey of ["ctrl+3", set_hc]

# ---- Handlers ----

define on_key(ev) as:
    if ev.type == "keydown":
        if ev.key == "escape":
            return 0
    return 1

define on_tick(root) as:
    # Update statusbar
    sbar is ui.find_by_id of [root, "status"]
    if sbar != null and (len of sbar.sections) >= 2:
        sbar.sections[0].text is status_text
        sbar.sections[1].text is _current_theme

# ---- Run ----

ui.app_loop of [root, on_key, on_tick]
gfx_close of null
