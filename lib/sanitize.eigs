# ============================================================
# Sanitize Library — text validation in pure EigenScript
# ============================================================
#
# How to use:
#   load_file of "lib/sanitize.eigs"
#   clean is sanitize_text of "some input"
#   garble is is_garble of "model output"
#   response is clean_response of "raw model output"
#   available is check_openai of null

# ---- Sanitize: trim whitespace ----
define sanitize_text(text) as:
    return trim of text

# ---- Garble detection: check if text looks like nonsense ----
# Heuristics: too short, no spaces in long text, too few words
define is_garble(text) as:
    if (len of text) < 2:
        return 1
    if (len of text) > 20:
        if (contains of [text, " "]) == 0:
            return 1
    words is split of [text, " "]
    wcount is len of words
    if wcount < 1:
        return 1
    return 0

# ---- Clean response: trim at "User:" marker, find sentence boundary ----
define clean_response(text) as:
    if (contains of [text, "User:"]) == 1:
        parts is split of [text, "User:"]
        text is parts[0]
    text is trim of text
    if (len of text) < 1:
        return ""
    return text

# ---- Check OpenAI API key availability ----
define check_openai(_x) as:
    key is env_get of "AI_INTEGRATIONS_OPENAI_API_KEY"
    if key == "":
        key is env_get of "OPENAI_API_KEY"
    if key == "":
        return 0
    return 1
