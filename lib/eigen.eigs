    return env

# ============================================================
# Public API
# ============================================================

define eigen_run(source) as:
    # Reset control-flow flags from any previous run
    _eigen_returning is 0
    _eigen_return_val is null
    _eigen_breaking is 0
    _eigen_continuing is 0
    tokens is eigen_tokenize of source
    ast is eigen_parse of tokens
    env is _make_default_env of null
    result is eigen_eval of [ast, env]
    # Capture return value and reset flags
    if _eigen_returning == 1:
        result is _eigen_return_val
    _eigen_returning is 0
    _eigen_return_val is null
    _eigen_breaking is 0
    _eigen_continuing is 0
    return result
