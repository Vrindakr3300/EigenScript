# ============================================================
# EigenScript Meta-Circular Interpreter
# ============================================================
#
# EigenScript implemented in EigenScript — full parity with C evaluator.
#
# Usage:
#   load_file of "lib/eigen.eigs"
#   result is eigen_run of "x is 42\nprint of x"
#
# Components:
#   eigen_tokenize of source    -> list of [type, value, line] tokens
#   eigen_parse of tokens       -> AST (nested lists)
#   eigen_eval of [ast, env]    -> value
#   eigen_run of source         -> evaluate source string

# ============================================================
# Tokenizer
# ============================================================

# Token types (strings for readability):
# "num", "str", "ident", "op", "kw", "newline", "indent", "dedent", "eof"
# "lparen", "rparen", "lbracket", "rbracket", "lbrace", "rbrace"
# "comma", "colon", "dot", "arrow", "pipe", "null", "true", "false"

define _is_digit(c) as:
    return contains of ["0123456789", c]

define _is_alpha(c) as:
    return contains of ["abcdefghijklmnopqrstuvwxyz_ABCDEFGHIJKLMNOPQRSTUVWXYZ", c]

define _is_alnum(c) as:
    if (_is_alpha of c) == 1:
        return 1
    return _is_digit of c

define _is_space(c) as:
    if c == " ":
        return 1
    if c == "\t":
        return 1
    return 0

# Full keyword list matching C lexer
_keywords is ["is", "of", "define", "as", "if", "else", "elif", "loop", "while", "return", "and", "or", "not", "for", "in", "null", "try", "catch", "break", "continue", "import", "match", "case", "unobserved", "what", "who", "when", "where", "why", "how", "converged", "stable", "improving", "oscillating", "diverging", "equilibrium", "true", "false"]

# Interrogative keywords
_interrogatives is ["what", "who", "when", "where", "why", "how"]

# Predicate keywords
_predicates is ["converged", "stable", "improving", "oscillating", "diverging", "equilibrium"]

define _is_keyword(word) as:
    for i in range of (len of _keywords):
        if word == _keywords[i]:
            return 1
    return 0

define _is_interrogative(word) as:
    for i in range of (len of _interrogatives):
        if word == _interrogatives[i]:
            return 1
    return 0

define _is_predicate(word) as:
    for i in range of (len of _predicates):
        if word == _predicates[i]:
            return 1
    return 0

define _predicate_index(word) as:
    for i in range of (len of _predicates):
        if word == _predicates[i]:
            return i
    return 0

define _interrogative_index(word) as:
    for i in range of (len of _interrogatives):
        if word == _interrogatives[i]:
            return i
    return 0

define eigen_tokenize(source) as:
    tokens is []
    pos is 0
    line is 1
    src_len is len of source
    indent_stack is [0]
    at_line_start is 1
    bracket_depth is 0

    loop while pos < src_len:
        # Handle line start: measure indent
        if at_line_start == 1:
            at_line_start is 0
            if bracket_depth == 0:
                spaces is 0
                counting is 1
                loop while (pos < src_len) and (counting == 1):
                    ch is char_at of [source, pos]
                    if ch == " ":
                        spaces is spaces + 1
                        pos is pos + 1
                    elif ch == "\t":
                        spaces is spaces + 4
                        pos is pos + 1
                    else:
                        counting is 0
                # Skip comment lines
                if pos < src_len:
                    if (char_at of [source, pos]) == "#":
                        loop while (pos < src_len) and ((char_at of [source, pos]) != "\n"):
                            pos is pos + 1
                        if pos < src_len:
                            pos is pos + 1
                            line is line + 1
                        at_line_start is 1
                        continue
                # Skip blank lines
                blank_line is 0
                if pos < src_len:
                    if (char_at of [source, pos]) == "\n":
                        pos is pos + 1
                        line is line + 1
                        at_line_start is 1
                        blank_line is 1
                if pos >= src_len:
                    blank_line is 1
                if blank_line == 0:
                    # Emit indent/dedent
                    current_indent is indent_stack[(len of indent_stack) - 1]
                    if spaces > current_indent:
                        append of [indent_stack, spaces]
                        append of [tokens, ["indent", null, line]]
                    else:
                        loop while spaces < (indent_stack[(len of indent_stack) - 1]):
                            # pop
                            new_stack is []
                            for si in range of ((len of indent_stack) - 1):
                                append of [new_stack, indent_stack[si]]
                            indent_stack is new_stack
                            append of [tokens, ["dedent", null, line]]
        # Now handle non-indent characters
        if (at_line_start == 0) and (pos < src_len):
            c is char_at of [source, pos]
            handled is 0
            # Skip inline spaces
            if (_is_space of c) == 1:
                pos is pos + 1
                handled is 1
            # Comments
            if (handled == 0) and (c == "#"):
                commenting is 1
                loop while (pos < src_len) and (commenting == 1):
                    ch2 is char_at of [source, pos]
                    if ch2 == "\n":
                        commenting is 0
                    else:
                        pos is pos + 1
                handled is 1
            # Newlines
            if (handled == 0) and (c == "\n"):
                if bracket_depth == 0:
                    if (len of tokens) > 0:
                        last is tokens[(len of tokens) - 1]
                        if last[0] != "newline":
                            if last[0] != "indent":
                                if last[0] != "dedent":
                                    append of [tokens, ["newline", null, line]]
                    at_line_start is 1
                pos is pos + 1
                line is line + 1
                handled is 1
            # f-strings: f"text {expr}"
            if (handled == 0) and (c == "f") and ((pos + 1) < src_len):
                if (char_at of [source, pos + 1]) == "\"":
                    pos is pos + 2
                    has_segments is 0
                    buf is ""
                    reading_fstr is 1
                    loop while (pos < src_len) and (reading_fstr == 1):
                        fc is char_at of [source, pos]
                        if fc == "\"":
                            pos is pos + 1
                            reading_fstr is 0
                        elif fc == "\\":
                            pos is pos + 1
                            if pos < src_len:
                                esc is char_at of [source, pos]
                                if esc == "n":
                                    buf is buf + "\n"
                                elif esc == "t":
                                    buf is buf + "\t"
                                elif esc == "\\":
                                    buf is buf + "\\"
                                elif esc == "\"":
                                    buf is buf + "\""
                                elif esc == "{":
                                    buf is buf + "{"
                                elif esc == "}":
                                    buf is buf + "}"
                                else:
                                    buf is buf + esc
                                pos is pos + 1
                        elif fc == "{":
                            # Emit accumulated literal
                            if ((len of buf) > 0) or (has_segments == 0):
                                if has_segments == 1:
                                    append of [tokens, ["op", "+", line]]
                                append of [tokens, ["str", buf, line]]
                                has_segments is 1
                            buf is ""
                            pos is pos + 1
                            # Emit + (str of (expr))
                            if has_segments == 1:
                                append of [tokens, ["op", "+", line]]
                            else:
                                has_segments is 1
                            append of [tokens, ["lparen", null, line]]
                            append of [tokens, ["ident", "str", line]]
                            append of [tokens, ["kw", "of", line]]
                            append of [tokens, ["lparen", null, line]]
                            # Collect expression text inside braces
                            depth is 1
                            expr_buf is ""
                            loop while (pos < src_len) and (depth > 0):
                                bc is char_at of [source, pos]
                                if bc == "{":
                                    depth is depth + 1
                                    expr_buf is expr_buf + bc
                                    pos is pos + 1
                                elif bc == "}":
                                    depth is depth - 1
                                    if depth > 0:
                                        expr_buf is expr_buf + bc
                                    pos is pos + 1
                                else:
                                    expr_buf is expr_buf + bc
                                    pos is pos + 1
                            # Recursively tokenize the inner expression
                            inner_tokens is eigen_tokenize of expr_buf
                            for iti in range of (len of inner_tokens):
                                itok is inner_tokens[iti]
                                if itok[0] != "eof":
                                    if itok[0] != "newline":
                                        append of [tokens, itok]
                            append of [tokens, ["rparen", null, line]]
                            append of [tokens, ["rparen", null, line]]
                        else:
                            buf is buf + fc
                            pos is pos + 1
                    # Emit trailing literal
                    if (len of buf) > 0:
                        if has_segments == 1:
                            append of [tokens, ["op", "+", line]]
                        append of [tokens, ["str", buf, line]]
                    elif has_segments == 0:
                        append of [tokens, ["str", "", line]]
                    handled is 1
            # Strings
            if (handled == 0) and (c == "\""):
                pos is pos + 1
                buf is ""
                reading_str is 1
                loop while (pos < src_len) and (reading_str == 1):
                    ch is char_at of [source, pos]
                    if ch == "\"":
                        pos is pos + 1
                        reading_str is 0
                    elif ch == "\\":
                        pos is pos + 1
                        esc is char_at of [source, pos]
                        if esc == "n":
                            buf is buf + "\n"
                        elif esc == "t":
                            buf is buf + "\t"
                        elif esc == "\\":
                            buf is buf + "\\"
                        elif esc == "\"":
                            buf is buf + "\""
                        else:
                            buf is buf + esc
                        pos is pos + 1
                    else:
                        buf is buf + ch
                        pos is pos + 1
                append of [tokens, ["str", buf, line]]
                handled is 1
            # Numbers
            if (handled == 0) and ((_is_digit of c) == 1):
                buf is ""
                has_dot is 0
                reading_num is 1
                loop while (pos < src_len) and (reading_num == 1):
                    ch is char_at of [source, pos]
                    if (_is_digit of ch) == 1:
                        buf is buf + ch
                        pos is pos + 1
                    elif (ch == ".") and (has_dot == 0):
                        has_dot is 1
                        buf is buf + ch
                        pos is pos + 1
                    else:
                        reading_num is 0
                append of [tokens, ["num", num of buf, line]]
                handled is 1
            # Identifiers and keywords
            if (handled == 0) and ((_is_alpha of c) == 1):
                buf is ""
                reading_id is 1
                loop while (pos < src_len) and (reading_id == 1):
                    ch is char_at of [source, pos]
                    if (_is_alnum of ch) == 1:
                        buf is buf + ch
                        pos is pos + 1
                    else:
                        reading_id is 0
                if buf == "null":
                    append of [tokens, ["null", null, line]]
                elif buf == "true":
                    append of [tokens, ["true", 1, line]]
                elif buf == "false":
                    append of [tokens, ["false", 0, line]]
                elif (_is_interrogative of buf) == 1:
                    append of [tokens, ["interrogative", buf, line]]
                elif (_is_predicate of buf) == 1:
                    append of [tokens, ["predicate", buf, line]]
                elif (_is_keyword of buf) == 1:
                    append of [tokens, ["kw", buf, line]]
                else:
                    append of [tokens, ["ident", buf, line]]
                handled is 1
            # Two-character operators
            if (handled == 0) and ((pos + 1) < src_len):
                next is char_at of [source, pos + 1]
                two is c + next
                if two == "==":
                    append of [tokens, ["op", "==", line]]
                    pos is pos + 2
                    handled is 1
                elif two == "!=":
                    append of [tokens, ["op", "!=", line]]
                    pos is pos + 2
                    handled is 1
                elif two == "<=":
                    append of [tokens, ["op", "<=", line]]
                    pos is pos + 2
                    handled is 1
                elif two == ">=":
                    append of [tokens, ["op", ">=", line]]
                    pos is pos + 2
                    handled is 1
                elif two == "=>":
                    append of [tokens, ["arrow", null, line]]
                    pos is pos + 2
                    handled is 1
                elif two == "|>":
                    append of [tokens, ["pipe", null, line]]
                    pos is pos + 2
                    handled is 1
            # Single-character operators and punctuation
            if handled == 0:
                if (contains of ["+-*/%<>", c]) == 1:
                    append of [tokens, ["op", c, line]]
                    pos is pos + 1
                    handled is 1
                elif c == "(":
                    append of [tokens, ["lparen", null, line]]
                    pos is pos + 1
                    bracket_depth is bracket_depth + 1
                    handled is 1
                elif c == ")":
                    append of [tokens, ["rparen", null, line]]
                    pos is pos + 1
                    if bracket_depth > 0:
                        bracket_depth is bracket_depth - 1
                    handled is 1
                elif c == "[":
                    append of [tokens, ["lbracket", null, line]]
                    pos is pos + 1
                    bracket_depth is bracket_depth + 1
                    handled is 1
                elif c == "]":
                    append of [tokens, ["rbracket", null, line]]
                    pos is pos + 1
                    if bracket_depth > 0:
                        bracket_depth is bracket_depth - 1
                    handled is 1
                elif c == "{":
                    append of [tokens, ["lbrace", null, line]]
                    pos is pos + 1
                    bracket_depth is bracket_depth + 1
                    handled is 1
                elif c == "}":
                    append of [tokens, ["rbrace", null, line]]
                    pos is pos + 1
                    if bracket_depth > 0:
                        bracket_depth is bracket_depth - 1
                    handled is 1
                elif c == ",":
                    append of [tokens, ["comma", null, line]]
                    pos is pos + 1
                    handled is 1
                elif c == ":":
                    append of [tokens, ["colon", null, line]]
                    pos is pos + 1
                    handled is 1
                elif c == ".":
                    append of [tokens, ["dot", null, line]]
                    pos is pos + 1
                    handled is 1
                else:
                    # Unknown character — skip
                    pos is pos + 1

    # Emit remaining dedents
    loop while (len of indent_stack) > 1:
        new_stack is []
        for si in range of ((len of indent_stack) - 1):
            append of [new_stack, indent_stack[si]]
        indent_stack is new_stack
        append of [tokens, ["dedent", null, line]]

    append of [tokens, ["eof", null, line]]
    return tokens

# ============================================================
# Parser
# ============================================================
#
# AST nodes are lists: [type, ...data]
# Examples:
#   ["num", 42]
#   ["str", "hello"]
#   ["ident", "x"]
#   ["assign", "x", expr]
#   ["binop", "+", left, right]
#   ["call", fn_expr, arg_expr]
#   ["if", cond, if_body, else_body]
#   ["loop", cond, body]
#   ["for", var, iter, body]
#   ["func", name, [params], body]
#   ["return", expr]
#   ["list", [elems]]
#   ["index", target, idx]
#   ["null"]
#   ["try", try_body, err_name, catch_body]
#   ["block", [stmts]]
#   ["dict", [[key, val], ...]]
#   ["dot", target, "field"]
#   ["dot_assign", target, "field", expr]
#   ["index_assign", target, index, expr]
#   ["lambda", [params], body_expr]
#   ["match", expr, [[pattern, body], ...]]
#   ["break"]
#   ["continue"]
#   ["import", name]
#   ["listcomp", expr, var, iter_expr, filter_expr_or_null]
#   ["unobserved", body_stmts]
#   ["interrogate", kind, expr]
#   ["predicate", kind]

define _parser_new(tokens) as:
    return [tokens, 0]

define _p_pos(p) as:
    return p[1]

define _p_cur(p) as:
    if p[1] >= (len of p[0]):
        return ["eof", null, 0]
    return p[0][p[1]]

define _p_advance(p) as:
    set_at of [p, 1, p[1] + 1]

define _p_peek_type(p) as:
    tok is _p_cur of p
    return tok[0]

define _p_peek_val(p) as:
    tok is _p_cur of p
    return tok[1]

define _p_peek_at(p, offset) as:
    idx is p[1] + offset
    if idx >= (len of p[0]):
        return ["eof", null, 0]
    return p[0][idx]

define _p_expect(p, ttype) as:
    tok is _p_cur of p
    if tok[0] != ttype:
        throw of f"parse error: expected {ttype}, got {tok[0]} ('{tok[1]}') at line {tok[2]}"
    _p_advance of p
    return tok

define _p_skip_newlines(p) as:
    loop while (_p_peek_type of p) == "newline":
        _p_advance of p

define _p_parse_block(p) as:
    stmts is []
    if (_p_peek_type of p) == "indent":
        _p_advance of p
        loop while (_p_peek_type of p) != "dedent":
            if (_p_peek_type of p) == "eof":
                return stmts
            _p_skip_newlines of p
            if (_p_peek_type of p) == "dedent":
                return stmts
            stmt is _p_parse_statement of p
            if stmt != null:
                append of [stmts, stmt]
            _p_skip_newlines of p
        _p_advance of p
    else:
        # Single-line block
        stmt is _p_parse_statement of p
        if stmt != null:
            append of [stmts, stmt]
    return stmts

define _p_parse_statement(p) as:
    _p_skip_newlines of p
    tt is _p_peek_type of p
    _stmt_line is (_p_cur of p)[2]

    if tt == "eof":
        return null
    if tt == "dedent":
        return null

    # define
    if tt == "kw":
        if (_p_peek_val of p) == "define":
            _p_advance of p
            name_tok is _p_expect of [p, "ident"]
            name is name_tok[1]
            # Optional params
            params is []
            if (_p_peek_type of p) == "lparen":
                _p_advance of p
                loop while (_p_peek_type of p) == "ident":
                    append of [params, (_p_cur of p)[1]]
                    _p_advance of p
                    if (_p_peek_type of p) == "comma":
                        _p_advance of p
                _p_expect of [p, "rparen"]
            if (len of params) == 0:
                params is ["n"]
            # as:
            if (_p_peek_type of p) == "kw":
                if (_p_peek_val of p) == "as":
                    _p_advance of p
            _p_expect of [p, "colon"]
            _p_skip_newlines of p
            body is _p_parse_block of p
            return ["_line", _stmt_line, ["func", name, params, body]]

        # if
        if (_p_peek_val of p) == "if":
            _p_advance of p
            cond is _p_parse_expr of p
            _p_expect of [p, "colon"]
            _p_skip_newlines of p
            if_body is _p_parse_block of p
            else_body is []
            _p_skip_newlines of p
            if (_p_peek_type of p) == "kw":
                if (_p_peek_val of p) == "elif":
                    # Rewrite as else { if ... }
                    set_at of [(_p_cur of p), 1, "if"]
                    elif_stmt is _p_parse_statement of p
                    else_body is [elif_stmt]
                elif (_p_peek_val of p) == "else":
                    _p_advance of p
                    _p_expect of [p, "colon"]
                    _p_skip_newlines of p
                    else_body is _p_parse_block of p
            return ["_line", _stmt_line, ["if", cond, if_body, else_body]]

        # return
        if (_p_peek_val of p) == "return":
            _p_advance of p
            expr is _p_parse_expr of p
            return ["_line", _stmt_line, ["return", expr]]

        # for
        if (_p_peek_val of p) == "for":
            _p_advance of p
            var_tok is _p_expect of [p, "ident"]
            _p_expect of [p, "kw"]
            iter is _p_parse_expr of p
            _p_expect of [p, "colon"]
            _p_skip_newlines of p
            body is _p_parse_block of p
            return ["_line", _stmt_line, ["for", var_tok[1], iter, body]]

        # loop while
        if (_p_peek_val of p) == "loop":
            _p_advance of p
            # expect "while"
            if (_p_peek_type of p) == "kw":
                if (_p_peek_val of p) == "while":
                    _p_advance of p
            cond is _p_parse_expr of p
            _p_expect of [p, "colon"]
            _p_skip_newlines of p
            body is _p_parse_block of p
            return ["_line", _stmt_line, ["loop", cond, body]]

        # try/catch
        if (_p_peek_val of p) == "try":
            _p_advance of p
            _p_expect of [p, "colon"]
            _p_skip_newlines of p
            try_body is _p_parse_block of p
            _p_skip_newlines of p
            _p_expect of [p, "kw"]
            err_name is "err"
            if (_p_peek_type of p) == "ident":
                err_name is (_p_cur of p)[1]
                _p_advance of p
            _p_expect of [p, "colon"]
            _p_skip_newlines of p
            catch_body is _p_parse_block of p
            return ["_line", _stmt_line, ["try", try_body, err_name, catch_body]]

        # break
        if (_p_peek_val of p) == "break":
            _p_advance of p
            return ["_line", _stmt_line, ["break"]]

        # continue
        if (_p_peek_val of p) == "continue":
            _p_advance of p
            return ["_line", _stmt_line, ["continue"]]

        # import
        if (_p_peek_val of p) == "import":
            _p_advance of p
            name_tok is _p_expect of [p, "ident"]
            return ["_line", _stmt_line, ["import", name_tok[1]]]

        # match
        if (_p_peek_val of p) == "match":
            _p_advance of p
            expr is _p_parse_expr of p
            _p_expect of [p, "colon"]
            _p_skip_newlines of p
            _p_expect of [p, "indent"]
            _p_skip_newlines of p
            cases is []
            loop while (_p_peek_type of p) == "kw":
                if (_p_peek_val of p) != "case":
                    break
                _p_advance of p
                # Pattern: _ is wildcard
                pattern is null
                if (_p_peek_type of p) == "ident":
                    if (_p_peek_val of p) == "_":
                        _p_advance of p
                    else:
                        pattern is _p_parse_expr of p
                else:
                    pattern is _p_parse_expr of p
                _p_expect of [p, "colon"]
                _p_skip_newlines of p
                case_body is _p_parse_block of p
                append of [cases, [pattern, case_body]]
                _p_skip_newlines of p
            if (_p_peek_type of p) == "dedent":
                _p_advance of p
            return ["_line", _stmt_line, ["match", expr, cases]]

        # unobserved
        if (_p_peek_val of p) == "unobserved":
            _p_advance of p
            _p_expect of [p, "colon"]
            _p_skip_newlines of p
            body is _p_parse_block of p
            return ["_line", _stmt_line, ["unobserved", body]]

    # Dot-assignment and index-assignment: ident.field is val, ident[i] is val
    if tt == "ident":
        # Check for dot/bracket after ident
        peek1 is _p_peek_at of [p, 1]
        if (peek1[0] == "dot") or (peek1[0] == "lbracket"):
            saved_pos is p[1]
            target is _p_parse_postfix of p
            if (target[0] == "dot") and ((_p_peek_type of p) == "kw"):
                if (_p_peek_val of p) == "is":
                    _p_advance of p
                    expr is _p_parse_expr of p
                    return ["_line", _stmt_line, ["dot_assign", target[1], target[2], expr]]
            if (target[0] == "index") and ((_p_peek_type of p) == "kw"):
                if (_p_peek_val of p) == "is":
                    _p_advance of p
                    expr is _p_parse_expr of p
                    return ["_line", _stmt_line, ["index_assign", target[1], target[2], expr]]
            # Not an assignment — restore and fall through
            set_at of [p, 1, saved_pos]

        # Assignment: ident is expr
        saved_pos is p[1]
        name is (_p_cur of p)[1]
        _p_advance of p
        if (_p_peek_type of p) == "kw":
            if (_p_peek_val of p) == "is":
                _p_advance of p
                expr is _p_parse_expr of p
                return ["_line", _stmt_line, ["assign", name, expr]]
        # Not an assignment — restore and parse as expression
        set_at of [p, 1, saved_pos]

    # Expression statement
    expr is _p_parse_expr of p
    return ["_line", _stmt_line, expr]

# ---- Postfix parser for dot/index chains (used by assignment detection) ----

define _p_parse_postfix(p) as:
    tok is _p_cur of p
    _p_advance of p
    node is ["ident", tok[1]]
    loop while ((_p_peek_type of p) == "dot") or ((_p_peek_type of p) == "lbracket"):
        if (_p_peek_type of p) == "dot":
            _p_advance of p
            key_tok is _p_expect of [p, "ident"]
            node is ["dot", node, key_tok[1]]
        else:
            _p_advance of p
            idx is _p_parse_expr of p
            _p_expect of [p, "rbracket"]
            node is ["index", node, idx]
    return node

# ---- Expression parser (precedence climbing) ----

define _p_parse_expr(p) as:
    return _p_parse_pipe of p

define _p_parse_pipe(p) as:
    left is _p_parse_or of p
    loop while (_p_peek_type of p) == "pipe":
        _p_advance of p
        fn is _p_parse_or of p
        # a |> b desugars to b of a
        left is ["call", fn, left]
    return left

define _p_parse_or(p) as:
    left is _p_parse_and of p
    loop while (_p_peek_type of p) == "kw":
        if (_p_peek_val of p) == "or":
            _p_advance of p
            right is _p_parse_and of p
            left is ["binop", "or", left, right]
        else:
            return left
    return left

define _p_parse_and(p) as:
    left is _p_parse_not of p
    loop while (_p_peek_type of p) == "kw":
        if (_p_peek_val of p) == "and":
            _p_advance of p
            right is _p_parse_not of p
            left is ["binop", "and", left, right]
        else:
            return left
    return left

define _p_parse_not(p) as:
    if (_p_peek_type of p) == "kw":
        if (_p_peek_val of p) == "not":
            _p_advance of p
            operand is _p_parse_not of p
            return ["unary", "not", operand]
    return _p_parse_comparison of p

define _p_parse_comparison(p) as:
    left is _p_parse_add of p
    if (_p_peek_type of p) == "op":
        op is _p_peek_val of p
        if op == "==":
            _p_advance of p
            return ["binop", "==", left, _p_parse_add of p]
        if op == "!=":
            _p_advance of p
            return ["binop", "!=", left, _p_parse_add of p]
        if op == "<":
            _p_advance of p
            return ["binop", "<", left, _p_parse_add of p]
        if op == ">":
            _p_advance of p
            return ["binop", ">", left, _p_parse_add of p]
        if op == "<=":
            _p_advance of p
            return ["binop", "<=", left, _p_parse_add of p]
        if op == ">=":
            _p_advance of p
            return ["binop", ">=", left, _p_parse_add of p]
    return left

define _p_parse_add(p) as:
    left is _p_parse_mul of p
    loop while (_p_peek_type of p) == "op":
        op is _p_peek_val of p
        if op == "+":
            _p_advance of p
            left is ["binop", "+", left, _p_parse_mul of p]
        elif op == "-":
            _p_advance of p
            left is ["binop", "-", left, _p_parse_mul of p]
        else:
            return left
    return left

define _p_parse_mul(p) as:
    left is _p_parse_unary of p
    loop while (_p_peek_type of p) == "op":
        op is _p_peek_val of p
        if op == "*":
            _p_advance of p
            left is ["binop", "*", left, _p_parse_unary of p]
        elif op == "/":
            _p_advance of p
            left is ["binop", "/", left, _p_parse_unary of p]
        elif op == "%":
            _p_advance of p
            left is ["binop", "%", left, _p_parse_unary of p]
        else:
            return left
    return left

define _p_parse_unary(p) as:
    if (_p_peek_type of p) == "op":
        if (_p_peek_val of p) == "-":
            _p_advance of p
            return ["unary", "-", _p_parse_unary of p]
    return _p_parse_call of p

define _p_parse_call(p) as:
    left is _p_parse_primary of p
    # Handle postfix: .field, [idx], "fn of arg"
    parsing is 1
    loop while parsing == 1:
        if (_p_peek_type of p) == "kw":
            if (_p_peek_val of p) == "of":
                _p_advance of p
                arg is _p_parse_add of p
                left is ["call", left, arg]
            else:
                parsing is 0
        elif (_p_peek_type of p) == "lbracket":
            _p_advance of p
            idx is _p_parse_expr of p
            _p_expect of [p, "rbracket"]
            left is ["index", left, idx]
        elif (_p_peek_type of p) == "dot":
            _p_advance of p
            key_tok is _p_expect of [p, "ident"]
            left is ["dot", left, key_tok[1]]
        else:
            parsing is 0
    return left

define _p_parse_primary(p) as:
    tt is _p_peek_type of p

    if tt == "num":
        tok is _p_cur of p
        _p_advance of p
        return ["num", tok[1]]

    if tt == "str":
        tok is _p_cur of p
        _p_advance of p
        return ["str", tok[1]]

    if tt == "null":
        _p_advance of p
        return ["null"]

    if tt == "true":
        _p_advance of p
        return ["num", 1]

    if tt == "false":
        _p_advance of p
        return ["num", 0]

    # Interrogatives: what of x, who of x, etc.
    if tt == "interrogative":
        tok is _p_cur of p
        _p_advance of p
        kind is _interrogative_index of tok[1]
        # Check for "of" — interrogative of expr
        if (_p_peek_type of p) == "kw":
            if (_p_peek_val of p) == "of":
                _p_advance of p
                expr is _p_parse_primary of p
                return ["interrogate", kind, expr]
        # Not followed by 'of' — treat as identifier
        return ["ident", tok[1]]

    # Predicates: converged, stable, improving, oscillating, diverging, equilibrium
    if tt == "predicate":
        tok is _p_cur of p
        _p_advance of p
        kind is _predicate_index of tok[1]
        return ["predicate", kind]

    if tt == "ident":
        tok is _p_cur of p
        _p_advance of p
        return ["ident", tok[1]]

    if tt == "lparen":
        # Check for lambda: (params) => expr
        saved_pos is p[1]
        _p_advance of p
        # Scan ahead to see if this is lambda
        is_lambda is 0
        scan_pos is p[1]
        scan_ok is 1
        loop while scan_ok == 1:
            if scan_pos >= (len of p[0]):
                scan_ok is 0
            else:
                stok is p[0][scan_pos]
                if (stok[0] == "ident") or (stok[0] == "comma"):
                    scan_pos is scan_pos + 1
                elif stok[0] == "rparen":
                    # Check if next is arrow
                    if (scan_pos + 1) < (len of p[0]):
                        if p[0][scan_pos + 1][0] == "arrow":
                            is_lambda is 1
                    scan_ok is 0
                else:
                    scan_ok is 0
        if is_lambda == 1:
            params is []
            loop while (_p_peek_type of p) == "ident":
                append of [params, (_p_cur of p)[1]]
                _p_advance of p
                if (_p_peek_type of p) == "comma":
                    _p_advance of p
            if (len of params) == 0:
                params is ["n"]
            _p_expect of [p, "rparen"]
            _p_expect of [p, "arrow"]
            body is _p_parse_expr of p
            return ["lambda", params, body]
        # Not a lambda — restore and parse as grouping
        set_at of [p, 1, saved_pos]
        _p_advance of p
        expr is _p_parse_expr of p
        _p_expect of [p, "rparen"]
        return expr

    if tt == "lbracket":
        _p_advance of p
        # Empty list
        if (_p_peek_type of p) == "rbracket":
            _p_advance of p
            return ["list", []]
        first is _p_parse_expr of p
        # List comprehension: [expr for x in iter]
        if (_p_peek_type of p) == "kw":
            if (_p_peek_val of p) == "for":
                _p_advance of p
                var_tok is _p_expect of [p, "ident"]
                _p_expect of [p, "kw"]
                iter_expr is _p_parse_expr of p
                filter_expr is null
                if (_p_peek_type of p) == "kw":
                    if (_p_peek_val of p) == "if":
                        _p_advance of p
                        filter_expr is _p_parse_expr of p
                _p_expect of [p, "rbracket"]
                return ["listcomp", first, var_tok[1], iter_expr, filter_expr]
        elems is [first]
        loop while (_p_peek_type of p) == "comma":
            _p_advance of p
            if (_p_peek_type of p) == "rbracket":
                break
            append of [elems, _p_parse_expr of p]
        _p_expect of [p, "rbracket"]
        return ["list", elems]

    # Dict literal: {"key": value, ...}
    if tt == "lbrace":
        _p_advance of p
        pairs is []
        if (_p_peek_type of p) != "rbrace":
            key is _p_parse_expr of p
            _p_expect of [p, "colon"]
            val is _p_parse_expr of p
            append of [pairs, [key, val]]
            loop while (_p_peek_type of p) == "comma":
                _p_advance of p
                if (_p_peek_type of p) == "rbrace":
                    break
                key is _p_parse_expr of p
                _p_expect of [p, "colon"]
                val is _p_parse_expr of p
                append of [pairs, [key, val]]
        _p_expect of [p, "rbrace"]
        return ["dict", pairs]

    throw of f"parse error: unexpected token {tt} '{_p_peek_val of p}'"

define eigen_parse(tokens) as:
    p is _parser_new of tokens
    stmts is []
    _p_skip_newlines of p
    loop while (_p_peek_type of p) != "eof":
        stmt is _p_parse_statement of p
        if stmt != null:
            append of [stmts, stmt]
        _p_skip_newlines of p
    return ["block", stmts]

# ============================================================
# Evaluator
# ============================================================

define _env_new(parent) as:
    return [[], parent]

define _env_get(env, name) as:
    bindings is env[0]
    for i in range of (len of bindings):
        if bindings[i][0] == name:
            return bindings[i][1]
    if env[1] != null:
        return _env_get of [env[1], name]
    return null

define _env_set(env, name, val) as:
    bindings is env[0]
    for i in range of (len of bindings):
        if bindings[i][0] == name:
            set_at of [bindings, i, [name, val]]
            return null
    if env[1] != null:
        parent_val is _env_get of [env[1], name]
        if parent_val != null:
            _env_set of [env[1], name, val]
            return null
    # New binding in current scope
    append of [bindings, [name, val]]
    return null

define _env_set_local(env, name, val) as:
    bindings is env[0]
    for i in range of (len of bindings):
        if bindings[i][0] == name:
            set_at of [bindings, i, [name, val]]
            return null
    append of [bindings, [name, val]]
    return null

# Return / break / continue mechanism — global flags
_eigen_returning is 0
_eigen_return_val is null
_eigen_breaking is 0
_eigen_continuing is 0

# Debug hook support — set via eigen_set_hook to intercept each statement
_eigen_debug_hook is null
_eigen_current_line is 0

define eigen_set_hook(hook) as:
    _eigen_debug_hook is hook

# Observer state per binding: [name, value, obs_count, entropy, prev_entropy, dH]
# For simplicity, we store observer metadata in a separate dict keyed by name.
_eigen_obs is {}

define _compute_entropy(val) as:
    t is type of val
    if t == "num":
        x is abs of val
        if (x == 0) or (x == 1):
            return 0
        p is 1.0 / (1.0 + x)
        if (p <= 0) or (p >= 1):
            return 0
        return 0 - (p * ((log of p) / (log of 2)) + (1 - p) * ((log of (1 - p)) / (log of 2)))
    if t == "str":
        slen is len of val
        if slen == 0:
            return 0
        return (log of (slen + 1)) / (log of 2)
    if t == "list":
        llen is len of val
        if llen == 0:
            return 0
        return (log of (llen + 1)) / (log of 2)
    if t == "dict":
        dk is keys of val
        dlen is len of dk
        if dlen == 0:
            return 0
        return (log of (dlen + 1)) / (log of 2)
    return 0

define _update_observer(name, val) as:
    new_entropy is _compute_entropy of val
    if (has_key of [_eigen_obs, name]) == 1:
        old is _eigen_obs[name]
        obs_count is old[0] + 1
        prev_ent is old[1]
        dH is new_entropy - prev_ent
        dict_set of [_eigen_obs, name, [obs_count, new_entropy, dH, old[3]]]
    else:
        dict_set of [_eigen_obs, name, [1, new_entropy, 0, 0]]
    return null

define _get_observer(name) as:
    if (has_key of [_eigen_obs, name]) == 1:
        return _eigen_obs[name]
    return [0, 0, 0, 0]

define eigen_eval(node, env) as:
    if node == null:
        return null
    ntype is node[0]

    # Unwrap _line wrapper (line-number annotation from parser)
    if ntype == "_line":
        _eigen_current_line is node[1]
        return eigen_eval of [node[2], env]

    if ntype == "num":
        return node[1]
    if ntype == "str":
        return node[1]
    if ntype == "null":
        return null

    if ntype == "ident":
        val is _env_get of [env, node[1]]
        if val == null:
            # Check if it might actually be null vs undefined
            # For now, return null (same as C evaluator for undefined)
            return null
        return val

    if ntype == "assign":
        val is eigen_eval of [node[2], env]
        _env_set of [env, node[1], val]
        _update_observer of [node[1], val]
        return val

    if ntype == "binop":
        op is node[1]
        if op == "and":
            left is eigen_eval of [node[2], env]
            if left == 0:
                return 0
            if (left == null) or (left == ""):
                return 0
            right is eigen_eval of [node[3], env]
            if right:
                return 1
            return 0
        if op == "or":
            left is eigen_eval of [node[2], env]
            if left:
                return 1
            right is eigen_eval of [node[3], env]
            if right:
                return 1
            return 0
        left is eigen_eval of [node[2], env]
        right is eigen_eval of [node[3], env]
        if op == "+":
            if (type of left) == "str":
                return left + (str of right)
            if (type of right) == "str":
                return (str of left) + right
            return left + right
        if op == "-":
            return left - right
        if op == "*":
            return left * right
        if op == "/":
            if right == 0:
                return 0
            return left / right
        if op == "%":
            if right == 0:
                return 0
            return left % right
        if op == "==":
            if left == right:
                return 1
            return 0
        if op == "!=":
            if left != right:
                return 1
            return 0
        if op == "<":
            if left < right:
                return 1
            return 0
        if op == ">":
            if left > right:
                return 1
            return 0
        if op == "<=":
            if left <= right:
                return 1
            return 0
        if op == ">=":
            if left >= right:
                return 1
            return 0

    if ntype == "unary":
        operand is eigen_eval of [node[2], env]
        if node[1] == "-":
            return 0 - operand
        if node[1] == "not":
            if operand:
                return 0
            return 1

    if ntype == "call":
        fn is eigen_eval of [node[1], env]
        arg is eigen_eval of [node[2], env]
        # Check for eigen function (meta-interpreter defined)
        if (type of fn) == "list":
            if (len of fn) >= 4:
                if fn[0] == "__eigen_fn__":
                    # fn is [__eigen_fn__, name, params, body]
                    params is fn[2]
                    body is fn[3]
                    call_env is _env_new of env
                    if (len of params) > 1:
                        if (type of arg) == "list":
                            for pi in range of (len of params):
                                if pi < (len of arg):
                                    _env_set_local of [call_env, params[pi], arg[pi]]
                    else:
                        _env_set_local of [call_env, params[0], arg]
                    _eigen_returning is 0
                    result is _eval_block of [body, call_env]
                    if _eigen_returning == 1:
                        _eigen_returning is 0
                        return _eigen_return_val
                    return result
        # C builtin — call it directly through the host runtime
        return fn of arg

    if ntype == "list":
        elems is node[1]
        result is []
        for i in range of (len of elems):
            append of [result, eigen_eval of [elems[i], env]]
        return result

    if ntype == "dict":
        pairs is node[1]
        result is {}
        for i in range of (len of pairs):
            pair is pairs[i]
            k is eigen_eval of [pair[0], env]
            v is eigen_eval of [pair[1], env]
            dict_set of [result, str of k, v]
        return result

    if ntype == "index":
        target is eigen_eval of [node[1], env]
        idx is eigen_eval of [node[2], env]
        return target[idx]

    if ntype == "dot":
        target is eigen_eval of [node[1], env]
        key is node[2]
        if (type of target) == "dict":
            if (has_key of [target, key]) == 1:
                return target[key]
            return null
        throw of f"cannot access .{key} on {type of target}"

    if ntype == "dot_assign":
        target is eigen_eval of [node[1], env]
        key is node[2]
        val is eigen_eval of [node[3], env]
        if (type of target) == "dict":
            dict_set of [target, key, val]
            return val
        throw of f"cannot assign .{key} on {type of target}"

    if ntype == "index_assign":
        target is eigen_eval of [node[1], env]
        idx is eigen_eval of [node[2], env]
        val is eigen_eval of [node[3], env]
        if (type of target) == "list":
            set_at of [target, idx, val]
            return val
        if (type of target) == "dict":
            dict_set of [target, str of idx, val]
            return val
        throw of f"cannot index-assign on {type of target}"

    if ntype == "lambda":
        params is node[1]
        body_expr is node[2]
        # Wrap body expression as a return statement
        body is [["return", body_expr]]
        # Don't capture env to avoid circular references in value lists
        return ["__eigen_fn__", "", params, body]

    if ntype == "if":
        cond is eigen_eval of [node[1], env]
        if cond:
            return _eval_block of [node[2], env]
        else:
            return _eval_block of [node[3], env]

    if ntype == "loop":
        result is null
        max_iter is 1000000
        running is 1
        loop while (max_iter > 0) and (running == 1):
            cond is eigen_eval of [node[1], env]
            if cond == 0:
                running is 0
            elif cond == null:
                running is 0
            else:
                result is _eval_block of [node[2], env]
                if _eigen_returning == 1:
                    return result
                if _eigen_breaking == 1:
                    _eigen_breaking is 0
                    running is 0
                elif _eigen_continuing == 1:
                    _eigen_continuing is 0
                max_iter is max_iter - 1
        return result

    if ntype == "for":
        var_name is node[1]
        iter is eigen_eval of [node[2], env]
        result is null
        for i in range of (len of iter):
            _env_set_local of [env, var_name, iter[i]]
            result is _eval_block of [node[3], env]
            if _eigen_returning == 1:
                return result
            if _eigen_breaking == 1:
                _eigen_breaking is 0
                break
            if _eigen_continuing == 1:
                _eigen_continuing is 0
        return result

    if ntype == "func":
        name is node[1]
        params is node[2]
        body is node[3]
        # Don't capture env to avoid circular references in value lists
        fn_val is ["__eigen_fn__", name, params, body]
        _env_set of [env, name, fn_val]
        return fn_val

    if ntype == "return":
        val is eigen_eval of [node[1], env]
        _eigen_returning is 1
        _eigen_return_val is val
        return val

    if ntype == "break":
        _eigen_breaking is 1
        return null

    if ntype == "continue":
        _eigen_continuing is 1
        return null

    if ntype == "block":
        return _eval_block of [node[1], env]

    if ntype == "try":
        try_body is node[1]
        err_name is node[2]
        catch_body is node[3]
        _try_result is null
        _try_caught is 0
        try:
            _try_result is _eval_block of [try_body, env]
        catch err:
            _try_caught is 1
            catch_env is _env_new of env
            _env_set_local of [catch_env, err_name, err]
            _try_result is _eval_block of [catch_body, catch_env]
        return _try_result

    if ntype == "match":
        val is eigen_eval of [node[1], env]
        cases is node[2]
        for ci in range of (len of cases):
            case_pair is cases[ci]
            pattern is case_pair[0]
            case_body is case_pair[1]
            if pattern == null:
                # Wildcard — always matches
                return _eval_block of [case_body, env]
            pat_val is eigen_eval of [pattern, env]
            if val == pat_val:
                return _eval_block of [case_body, env]
        return null

    if ntype == "import":
        mod_name is node[1]
        # Use load_file to load lib/NAME.eigs, then run it in isolated env
        path is "lib/" + mod_name + ".eigs"
        try:
            source is read_text of path
        catch err:
            throw of f"import: module '{mod_name}' not found"
        # Parse and eval in a child environment
        mod_tokens is eigen_tokenize of source
        mod_ast is eigen_parse of mod_tokens
        mod_env is _env_new of env
        eigen_eval of [mod_ast, mod_env]
        # Collect bindings into a dict
        mod_dict is {}
        mod_bindings is mod_env[0]
        for mi in range of (len of mod_bindings):
            bname is mod_bindings[mi][0]
            bval is mod_bindings[mi][1]
            # Skip private names starting with _
            if (len of bname) > 0:
                first_char is char_at of [bname, 0]
                if first_char != "_":
                    dict_set of [mod_dict, bname, bval]
        _env_set of [env, mod_name, mod_dict]
        return mod_dict

    if ntype == "listcomp":
        expr_node is node[1]
        var_name is node[2]
        iter is eigen_eval of [node[3], env]
        filter_node is node[4]
        result is []
        for i in range of (len of iter):
            comp_env is _env_new of env
            _env_set_local of [comp_env, var_name, iter[i]]
            if filter_node != null:
                cond is eigen_eval of [filter_node, comp_env]
                if cond == 0:
                    continue
                if cond == null:
                    continue
            val is eigen_eval of [expr_node, comp_env]
            append of [result, val]
        return result

    if ntype == "unobserved":
        # Execute the body — meta-interpreter just runs it normally
        return _eval_block of [node[1], env]

    if ntype == "interrogate":
        kind is node[1]
        target is eigen_eval of [node[2], env]
        # kind: 0=what, 1=who, 2=when, 3=where, 4=why, 5=how
        if kind == 0:
            # what: value / magnitude
            if (type of target) == "num":
                return target
            if (type of target) == "str":
                return len of target
            if (type of target) == "list":
                return len of target
            return 0
        if kind == 1:
            # who: name / type
            if node[2][0] == "ident":
                return node[2][1]
            return type of target
        if kind == 2:
            # when: observation count
            if node[2][0] == "ident":
                obs is _get_observer of node[2][1]
                return obs[0]
            return 0
        if kind == 3:
            # where: entropy
            if node[2][0] == "ident":
                obs is _get_observer of node[2][1]
                return obs[1]
            return _compute_entropy of target
        if kind == 4:
            # why: dH (entropy change)
            if node[2][0] == "ident":
                obs is _get_observer of node[2][1]
                return obs[2]
            return 0
        if kind == 5:
            # how: stability score
            if node[2][0] == "ident":
                obs is _get_observer of node[2][1]
                ent is obs[1]
                prior is obs[3]
                initial is prior
                if initial <= 0:
                    initial is 1.0
                if ent > 0:
                    return 1.0 - (ent / initial)
                return 1.0
            return 1.0
        return 0

    if ntype == "predicate":
        kind is node[1]
        # Look at last observer state
        # kind: 0=converged, 1=stable, 2=improving, 3=oscillating, 4=diverging, 5=equilibrium
        h is 0
        dh is 0
        prev_dh is 0
        # Try to get the latest observer state from __observer__ binding
        last_obs is _env_get of [env, "__observer__"]
        if last_obs != null:
            h is _compute_entropy of last_obs
        if kind == 0:
            # converged: low dH and low entropy
            if (abs of dh) < 0.001:
                if h < 0.1:
                    return 1
            return 0
        if kind == 1:
            # stable: low dH, moderate entropy
            if (abs of dh) < 0.01:
                if h >= 0.1:
                    return 1
            return 0
        if kind == 2:
            # improving: negative dH
            if dh < (0 - 0.001):
                return 1
            return 0
        if kind == 3:
            # oscillating: sign change in dH
            if (dh * prev_dh) < 0:
                if (abs of dh) > 0.001:
                    return 1
            return 0
        if kind == 4:
            # diverging: positive dH
            if dh > 0.001:
                return 1
            return 0
        if kind == 5:
            # equilibrium: very low dH
            if (abs of dh) < 0.001:
                return 1
            return 0
        return 0

    return null

define _eval_block(stmts, env) as:
    result is null
    for i in range of (len of stmts):
        stmt is stmts[i]
        # Unwrap _line wrapper to extract line number
        if (type of stmt) == "list":
            if (len of stmt) >= 3:
                if stmt[0] == "_line":
                    _eigen_current_line is stmt[1]
                    stmt is stmt[2]
        # Call debug hook if set
        if _eigen_debug_hook != null:
            _eigen_debug_hook of [stmt, env]
        result is eigen_eval of [stmt, env]
        if _eigen_returning == 1:
            return result
        if _eigen_breaking == 1:
            return result
        if _eigen_continuing == 1:
            return result
    return result

# ============================================================
# Built-in functions for the meta-circular environment
# ============================================================

define _make_default_env as:
    env is _env_new of null
    # Bridge ALL C builtins into the meta-interpreter's environment.
    # Since we're running inside the C runtime, these names resolve to
    # VAL_BUILTIN values. The evaluator's "call" handler calls them
    # with `fn of arg` which the C runtime handles natively.
    _env_set_local of [env, "print", print]
    _env_set_local of [env, "write", write]
    _env_set_local of [env, "flush", flush]
    _env_set_local of [env, "len", len]
    _env_set_local of [env, "str", str]
    _env_set_local of [env, "num", num]
    _env_set_local of [env, "append", append]
    _env_set_local of [env, "type", type]
    _env_set_local of [env, "report", report]
    _env_set_local of [env, "assert", assert]
    _env_set_local of [env, "throw", throw]
    _env_set_local of [env, "keys", keys]
    _env_set_local of [env, "values", values]
    _env_set_local of [env, "has_key", has_key]
    _env_set_local of [env, "dict_set", dict_set]
    _env_set_local of [env, "dict_remove", dict_remove]
    _env_set_local of [env, "observe", observe]
    _env_set_local of [env, "contains", contains]
    _env_set_local of [env, "starts_with", starts_with]
    _env_set_local of [env, "ends_with", ends_with]
    _env_set_local of [env, "split", split]
    _env_set_local of [env, "trim", trim]
    _env_set_local of [env, "str_replace", str_replace]
    _env_set_local of [env, "str_lower", str_lower]
    _env_set_local of [env, "str_upper", str_upper]
    _env_set_local of [env, "char_at", char_at]
    _env_set_local of [env, "substr", substr]
    _env_set_local of [env, "index_of", index_of]
    _env_set_local of [env, "join", join]
    _env_set_local of [env, "concat", concat]
    _env_set_local of [env, "range", range]
    _env_set_local of [env, "abs", abs]
    _env_set_local of [env, "floor", floor]
    _env_set_local of [env, "ceil", ceil]
    _env_set_local of [env, "round", round]
    _env_set_local of [env, "min", min]
    _env_set_local of [env, "max", max]
    _env_set_local of [env, "sin", sin]
    _env_set_local of [env, "cos", cos]
    _env_set_local of [env, "tan", tan]
    _env_set_local of [env, "asin", asin]
    _env_set_local of [env, "acos", acos]
    _env_set_local of [env, "atan", atan]
    _env_set_local of [env, "atan2", atan2]
    _env_set_local of [env, "log", log]
    _env_set_local of [env, "exp", exp]
    _env_set_local of [env, "sqrt", sqrt]
    _env_set_local of [env, "pow", pow]
    _env_set_local of [env, "pi", pi]
    _env_set_local of [env, "random", random]
    _env_set_local of [env, "random_int", random_int]
    _env_set_local of [env, "seed_random", seed_random]
    _env_set_local of [env, "set_at", set_at]
    _env_set_local of [env, "get_at", get_at]
    _env_set_local of [env, "load_file", load_file]
    _env_set_local of [env, "file_exists", file_exists]
    _env_set_local of [env, "read_text", read_text]
    _env_set_local of [env, "write_text", write_text]
    _env_set_local of [env, "json_encode", json_encode]
    _env_set_local of [env, "json_decode", json_decode]
    _env_set_local of [env, "coalesce", coalesce]
    _env_set_local of [env, "env_get", env_get]
    _env_set_local of [env, "exec_capture", exec_capture]
    _env_set_local of [env, "path_join", path_join]
    _env_set_local of [env, "path_dir", path_dir]
    _env_set_local of [env, "path_base", path_base]
    _env_set_local of [env, "path_ext", path_ext]
    _env_set_local of [env, "mkdir", mkdir]
    _env_set_local of [env, "ls", ls]
    _env_set_local of [env, "rm", rm]
    _env_set_local of [env, "regex_match", regex_match]
