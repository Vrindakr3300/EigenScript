        "visible": 1
    }

# ============================================================
# Widget tree operations
# ============================================================

define add_child(parent, child) as:
    append of [parent.children, child]
    return parent

define find_by_id(widget, id) as:
    if widget.id == id:
        return widget
    if _is_container of widget.type:
        for i in range of (len of widget.children):
            found is find_by_id of [widget.children[i], id]
            if found != null:
                return found
    if widget.type == "tabs":
        for i in range of (len of widget.tab_panels):
            if widget.tab_panels[i] != null:
                found is find_by_id of [widget.tab_panels[i], id]
                if found != null:
                    return found
    if widget.type == "splitter":
        if widget.panel_a != null:
            found is find_by_id of [widget.panel_a, id]
            if found != null:
                return found
        if widget.panel_b != null:
            found is find_by_id of [widget.panel_b, id]
            if found != null:
                return found
    return null

# ============================================================
# Layout helpers
# ============================================================

define stack_vertical(widgets, x, y, gap) as:
    cy is y
    for i in range of (len of widgets):
        widgets[i].x is x
        widgets[i].y is cy
        cy is cy + widgets[i].h + gap
    return widgets

define stack_horizontal(widgets, x, y, gap) as:
    cx is x
    for i in range of (len of widgets):
        widgets[i].x is cx
        widgets[i].y is y
        cx is cx + widgets[i].w + gap
    return widgets

# ============================================================
# Rendering
# ============================================================

define render(widget, ox, oy) as:
    if widget.visible == 0:
        return null
    ax is ox + widget.x
    ay is oy + widget.y

    match widget.type:
        case "panel":
            _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius, widget.bg, widget.border]
            for i in range of (len of widget.children):
                render of [widget.children[i], ax, ay]

        case "label":
            gfx_text of [ax, ay, widget.text, widget.color[0], widget.color[1], widget.color[2], widget.scale]

        case "button":
            bg is _theme.btn_bg
            tc is _theme.btn_text
            if widget.enabled == 0:
                bg is _theme.btn_disabled
                tc is _theme.btn_text_disabled
            elif widget.pressed == 1:
                bg is _theme.btn_pressed
            elif widget.hover == 1:
                bg is _theme.btn_hover
            _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius_sm, bg, _theme.panel_border]
            # Center text in button
            tw is text_width of [widget.label, _theme.font_scale]
            th is text_height of _theme.font_scale
            tx is ax + floor of ((widget.w - tw) / 2)
            ty is ay + floor of ((widget.h - th) / 2)
            _draw_text_clipped of [tx, ty, widget.w - 4, widget.label, tc, _theme.font_scale]

        case "slider":
            track_y is ay + floor of (widget.h / 2) - 2
            # Track background
            gfx_rrect of [ax, track_y, widget.w, 4, 2, _theme.slider_track[0], _theme.slider_track[1], _theme.slider_track[2]]
            # Fill
            range_val is widget.max_val - widget.min_val
            if range_val > 0:
                frac is (widget.value - widget.min_val) / range_val
            else:
                frac is 0
            fill_w is floor of (frac * (widget.w - 8))
            if fill_w > 0:
                gfx_rrect of [ax, track_y, fill_w, 4, 2, _theme.slider_fill[0], _theme.slider_fill[1], _theme.slider_fill[2]]
            # Thumb
            thumb_x is ax + fill_w - 5
            gfx_rrect of [thumb_x, ay + 2, 10, widget.h - 4, 3, _theme.slider_thumb[0], _theme.slider_thumb[1], _theme.slider_thumb[2]]

        case "toggle":
            if widget.value == 1:
                bg is _theme.toggle_on
            else:
                bg is _theme.toggle_off
            # Pill shape — radius = half height
            pill_r is floor of (widget.h / 2)
            gfx_rrect of [ax, ay, widget.w, widget.h, pill_r, bg[0], bg[1], bg[2]]
            # Circular knob
            knob_r is pill_r - 3
            if widget.value == 1:
                knob_cx is ax + widget.w - pill_r
            else:
                knob_cx is ax + pill_r
            gfx_circle of [knob_cx, ay + pill_r, knob_r, 220, 220, 230]

        case "knob":
            # Draw knob as a filled circle with a pointer line
            cx is ax + floor of (widget.w / 2)
            cy is ay + floor of (widget.h / 2)
            r is floor of (widget.w / 2) - 2
            gfx_circle of [cx, cy, r, _theme.knob_bg[0], _theme.knob_bg[1], _theme.knob_bg[2]]
            # Arc indicator — draw small filled circle at edge
            range_val is widget.max_val - widget.min_val
            if range_val > 0:
                frac is (widget.value - widget.min_val) / range_val
            else:
                frac is 0
            # Angle: from 225deg (min) to -45deg (max), i.e. 270deg sweep
            angle is (3.927 - frac * 4.712)
            px is cx + floor of ((cos of angle) * (r - 2))
            py is cy - floor of ((sin of angle) * (r - 2))
            gfx_line of [cx, cy, px, py, _theme.knob_pointer[0], _theme.knob_pointer[1], _theme.knob_pointer[2]]
            # Small dot at pointer tip
            gfx_circle of [px, py, 2, _theme.knob_fg[0], _theme.knob_fg[1], _theme.knob_fg[2]]

        case "dropdown":
            if widget.hover == 1:
                dbg is _theme.dropdown_hover
            else:
                dbg is _theme.dropdown_bg
            _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius_sm, dbg, _theme.panel_border]
            # Current selection text
            if widget.selected >= 0 and widget.selected < (len of widget.items):
                sel_text is widget.items[widget.selected]
            else:
                sel_text is ""
            _draw_text_clipped of [ax + 6, ay + 5, widget.w - 24, sel_text, _theme.text_color, _theme.font_scale]
            # Arrow indicator
            arrow_x is ax + widget.w - 16
            arrow_y is ay + 8
            gfx_line of [arrow_x, arrow_y, arrow_x + 4, arrow_y + 6, _theme.dropdown_arrow[0], _theme.dropdown_arrow[1], _theme.dropdown_arrow[2]]
            gfx_line of [arrow_x + 8, arrow_y, arrow_x + 4, arrow_y + 6, _theme.dropdown_arrow[0], _theme.dropdown_arrow[1], _theme.dropdown_arrow[2]]
            # Open menu
            if widget.open == 1:
                item_h is 24
                menu_h is (len of widget.items) * item_h
                gfx_rrect of [ax, ay + widget.h + 2, widget.w, menu_h, _theme.radius_sm, _theme.menu_bg[0], _theme.menu_bg[1], _theme.menu_bg[2]]
                for i in range of (len of widget.items):
                    iy is ay + widget.h + 2 + i * item_h
                    if i == widget.hover_index:
                        gfx_rrect of [ax + 2, iy, widget.w - 4, item_h, _theme.radius_sm, _theme.menu_hover[0], _theme.menu_hover[1], _theme.menu_hover[2]]
                    _draw_text_clipped of [ax + 8, iy + 5, widget.w - 16, widget.items[i], _theme.text_color, _theme.font_scale]

        case "tabs":
            # Tab bar
            tab_h is 28
            gfx_rect of [ax, ay, widget.w, tab_h, _theme.tab_bg[0], _theme.tab_bg[1], _theme.tab_bg[2]]
            tab_x is ax
            for i in range of (len of widget.tab_names):
                tw is (text_width of [widget.tab_names[i], _theme.font_scale]) + 24
                if i == widget.active:
                    tbg is _theme.tab_active
                    tc is _theme.tab_text_active
                elif i == widget.hover_tab:
                    tbg is _theme.tab_hover
                    tc is _theme.tab_text
                else:
                    tbg is _theme.tab_bg
                    tc is _theme.tab_text
                gfx_rect of [tab_x, ay, tw, tab_h, tbg[0], tbg[1], tbg[2]]
                gfx_text of [tab_x + 12, ay + 7, widget.tab_names[i], tc[0], tc[1], tc[2], _theme.font_scale]
                tab_x is tab_x + tw
            # Active tab panel
            if widget.active < (len of widget.tab_panels):
                tp is widget.tab_panels[widget.active]
                if tp != null:
                    render of [tp, ax, ay + tab_h]

        case "canvas":
            if widget.on_paint != null:
                widget.on_paint of [widget, ax, ay]

        case "scroll_panel":
            _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius, widget.bg, widget.border]
            gfx_clip of [ax + 1, ay + 1, widget.w - 2, widget.h - 2]
            for i in range of (len of widget.children):
                render of [widget.children[i], ax - widget.scroll_x, ay - widget.scroll_y]
            gfx_clip of null
            # Vertical scrollbar
            if widget.content_h > widget.h:
                sb_h is floor of (widget.h * widget.h / widget.content_h)
                if sb_h < 20:
                    sb_h is 20
                sb_y is ay + floor of (widget.scroll_y * (widget.h - sb_h) / (widget.content_h - widget.h))
                gfx_rrect of [ax + widget.w - 6, sb_y, 4, sb_h, 2, 80, 80, 100]
            # Horizontal scrollbar
            if widget.content_w > widget.w:
                sb_w is floor of (widget.w * widget.w / widget.content_w)
                if sb_w < 20:
                    sb_w is 20
                sb_x is ax + floor of (widget.scroll_x * (widget.w - sb_w) / (widget.content_w - widget.w))
                gfx_rrect of [sb_x, ay + widget.h - 6, sb_w, 4, 2, 80, 80, 100]

        case "vslider":
            track_x is ax + floor of (widget.w / 2) - 2
            gfx_rrect of [track_x, ay, 4, widget.h, 2, _theme.slider_track[0], _theme.slider_track[1], _theme.slider_track[2]]
            range_val is widget.max_val - widget.min_val
            if range_val > 0:
                frac is (widget.value - widget.min_val) / range_val
            else:
                frac is 0
            # Fill from bottom up
            fill_h is floor of (frac * (widget.h - 8))
            if fill_h > 0:
                gfx_rrect of [track_x, ay + widget.h - fill_h, 4, fill_h, 2, _theme.slider_fill[0], _theme.slider_fill[1], _theme.slider_fill[2]]
            # Thumb
            thumb_y is ay + widget.h - fill_h - 5
            gfx_rrect of [ax + 2, thumb_y, widget.w - 4, 10, 3, _theme.slider_thumb[0], _theme.slider_thumb[1], _theme.slider_thumb[2]]

        case "checkbox":
            # Box
            box_bg is _theme.panel_bg
            if widget.value == 1:
                box_bg is _theme.accent
            gfx_rrect of [ax, ay, 14, 14, 2, box_bg[0], box_bg[1], box_bg[2]]
            if widget.value == 1:
                # Checkmark — two lines
                gfx_line of [ax + 3, ay + 7, ax + 6, ay + 10, 255, 255, 255]
                gfx_line of [ax + 6, ay + 10, ax + 11, ay + 3, 255, 255, 255]
            else:
                # Empty box border
                gfx_rrect of [ax, ay, 14, 14, 2, _theme.panel_border[0], _theme.panel_border[1], _theme.panel_border[2]]
                gfx_rrect of [ax + 1, ay + 1, 12, 12, 2, box_bg[0], box_bg[1], box_bg[2]]
            # Label
            gfx_text of [ax + 20, ay + 1, widget.label, _theme.text_color[0], _theme.text_color[1], _theme.text_color[2], _theme.font_scale]

        case "text_input":
            if widget.focused == 1:
                border is _theme.accent
            else:
                border is _theme.panel_border
            _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius_sm, _theme.dropdown_bg, border]
            # Selection highlight
            if widget.sel_start != null and widget.sel_start >= 0 and widget.sel_end != null and widget.sel_end >= 0:
                ss is widget.sel_start
                se is widget.sel_end
                if ss > se:
                    tmp is ss
                    ss is se
                    se is tmp
                sel_x is ax + 6 + ss * _theme.char_w
                sel_w is (se - ss) * _theme.char_w
                sbg is _theme.selection_bg
                gfx_rect of [sel_x, ay + 3, sel_w, widget.h - 6, sbg[0], sbg[1], sbg[2], 100]
            _draw_text_clipped of [ax + 6, ay + 5, widget.w - 12, widget.text, _theme.text_color, _theme.font_scale]
            # Blinking cursor
            if widget.focused == 1 and _cursor_blink < 35:
                cursor_x is ax + 6 + widget.cursor * _theme.char_w
                if cursor_x < ax + widget.w - 4:
                    gfx_line of [cursor_x, ay + 4, cursor_x, ay + widget.h - 4, _theme.accent[0], _theme.accent[1], _theme.accent[2]]

        case "menu":
            if widget.visible == 1:
                item_h is 24
                menu_h is (len of widget.items) * item_h
                # Shadow
                gfx_rrect of [ax + 2, ay + 2, widget.w, menu_h, _theme.radius_sm, 10, 10, 15, 120]
                # Background
                gfx_rrect of [ax, ay, widget.w, menu_h, _theme.radius_sm, _theme.menu_bg[0], _theme.menu_bg[1], _theme.menu_bg[2]]
                for i in range of (len of widget.items):
                    iy is ay + i * item_h
                    if i == widget.hover_index:
                        gfx_rrect of [ax + 2, iy + 1, widget.w - 4, item_h - 2, _theme.radius_sm, _theme.menu_hover[0], _theme.menu_hover[1], _theme.menu_hover[2]]
                    item is widget.items[i]
                    if item == "-":
                        # Separator
                        gfx_line of [ax + 8, iy + 12, ax + widget.w - 8, iy + 12, _theme.panel_border[0], _theme.panel_border[1], _theme.panel_border[2]]
                    elif (type of item) == "list":
                        # [label, shortcut]
                        _draw_text_clipped of [ax + 10, iy + 5, widget.w - 20, item[0], _theme.text_color, _theme.font_scale]
                        sw is text_width of [item[1], 1]
                        gfx_text of [ax + widget.w - sw - 10, iy + 8, item[1], _theme.text_dim[0], _theme.text_dim[1], _theme.text_dim[2], 1]
                    else:
                        _draw_text_clipped of [ax + 10, iy + 5, widget.w - 20, item, _theme.text_color, _theme.font_scale]

        case "meter":
            # Background
            gfx_rrect of [ax, ay, widget.w, widget.h, 2, 20, 20, 25]
            # Filled bar from bottom — green/yellow/red gradient
            bar_h is floor of (widget.value * widget.h)
            if bar_h > widget.h:
                bar_h is widget.h
            if bar_h > 0:
                # Green zone (bottom 60%)
                green_h is floor of (widget.h * 0.6)
                yellow_h is floor of (widget.h * 0.2)
                # Draw green portion
                gh is bar_h
                if gh > green_h:
                    gh is green_h
                if gh > 0:
                    gfx_rect of [ax + 1, ay + widget.h - gh, widget.w - 2, gh, 40, 180, 80]
                # Draw yellow portion
                if bar_h > green_h:
                    yh is bar_h - green_h
                    if yh > yellow_h:
                        yh is yellow_h
                    gfx_rect of [ax + 1, ay + widget.h - green_h - yh, widget.w - 2, yh, 200, 200, 40]
                # Draw red portion
                if bar_h > green_h + yellow_h:
                    rh is bar_h - green_h - yellow_h
                    gfx_rect of [ax + 1, ay + widget.h - bar_h, widget.w - 2, rh, 220, 50, 40]
            # Peak hold line
            if widget.peak > 0:
                peak_y is ay + widget.h - floor of (widget.peak * widget.h)
                if peak_y >= ay and peak_y < ay + widget.h:
                    gfx_line of [ax + 1, peak_y, ax + widget.w - 1, peak_y, 255, 255, 255]

        case "toggle_button":
            if widget.value == 1:
                bg is widget.color_on
            elif widget.hover == 1:
                bg is _theme.btn_hover
            else:
                bg is widget.color_off
            _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius_sm, bg, _theme.panel_border]
            tc is _theme.btn_text
            if widget.value == 1:
                tc is [255, 255, 255]
            tw is text_width of [widget.label, _theme.font_scale]
            th is text_height of _theme.font_scale
            tx is ax + floor of ((widget.w - tw) / 2)
            ty is ay + floor of ((widget.h - th) / 2)
            _draw_text_clipped of [tx, ty, widget.w - 4, widget.label, tc, _theme.font_scale]

        case "separator":
            gfx_rect of [ax, ay, widget.w, widget.h, widget.color[0], widget.color[1], widget.color[2]]

        case "spinbox":
            # Main box
            _draw_rbox of [ax, ay, widget.w - 40, widget.h, _theme.radius_sm, _theme.dropdown_bg, _theme.panel_border]
            # Value text
            val_text is f"{floor of widget.value}"
            _draw_text_clipped of [ax + 6, ay + 5, widget.w - 52, val_text, _theme.text_color, _theme.font_scale]
            # Minus button
            btn_w is 18
            mbg is _theme.btn_bg
            if widget.hover_btn == 1:
                mbg is _theme.btn_hover
            _draw_rbox of [ax + widget.w - 40, ay, btn_w, widget.h, _theme.radius_sm, mbg, _theme.panel_border]
            gfx_text of [ax + widget.w - 36, ay + 5, "-", _theme.text_color[0], _theme.text_color[1], _theme.text_color[2], _theme.font_scale]
            # Plus button
            pbg is _theme.btn_bg
            if widget.hover_btn == 2:
                pbg is _theme.btn_hover
            _draw_rbox of [ax + widget.w - 20, ay, btn_w, widget.h, _theme.radius_sm, pbg, _theme.panel_border]
            gfx_text of [ax + widget.w - 15, ay + 5, "+", _theme.text_color[0], _theme.text_color[1], _theme.text_color[2], _theme.font_scale]

        case "radio_group":
            rx is ax
            for i in range of (len of widget.items):
                rw is (text_width of [widget.items[i], _theme.font_scale]) + 16
                if i == widget.selected:
                    rbg is _theme.accent
                    rtc is [255, 255, 255]
                elif i == widget.hover_index:
                    rbg is _theme.btn_hover
                    rtc is _theme.text_color
                else:
                    rbg is _theme.btn_bg
                    rtc is _theme.text_color
                # First item gets left radius, last gets right, middle gets none
                if i == 0:
                    gfx_rrect of [rx, ay, rw, widget.h, _theme.radius_sm, rbg[0], rbg[1], rbg[2]]
                elif i == (len of widget.items) - 1:
                    gfx_rrect of [rx, ay, rw, widget.h, _theme.radius_sm, rbg[0], rbg[1], rbg[2]]
                else:
                    gfx_rect of [rx, ay, rw, widget.h, rbg[0], rbg[1], rbg[2]]
                gfx_text of [rx + 8, ay + 5, widget.items[i], rtc[0], rtc[1], rtc[2], _theme.font_scale]
                rx is rx + rw

        case "progress_bar":
            gfx_rrect of [ax, ay, widget.w, widget.h, 3, _theme.slider_track[0], _theme.slider_track[1], _theme.slider_track[2]]
            fill_w is floor of (widget.value * widget.w)
            if fill_w > 0:
                gfx_rrect of [ax, ay, fill_w, widget.h, 3, _theme.accent[0], _theme.accent[1], _theme.accent[2]]

        case "splitter":
            sp is floor of widget.split_pos
            bw is widget.bar_width
            # Panel A (left)
            if widget.panel_a != null:
                gfx_clip of [ax, ay, sp, widget.h]
                render of [widget.panel_a, ax, ay]
                gfx_clip of null
            # Divider bar
            dbg is _theme.panel_border
            if widget.hover == 1 or widget.dragging == 1:
                dbg is _theme.accent
            gfx_rect of [ax + sp, ay, bw, widget.h, dbg[0], dbg[1], dbg[2]]
            # Panel B (right)
            if widget.panel_b != null:
                gfx_clip of [ax + sp + bw, ay, widget.w - sp - bw, widget.h]
                render of [widget.panel_b, ax + sp + bw, ay]
                gfx_clip of null

        case "dialog":
            if widget.visible == 1:
                # Overlay dims the background
                gfx_rect of [0, 0, 9999, 9999, 0, 0, 0, 140]
                # Center the dialog
                dx is ax + floor of ((widget.w - widget.w) / 2)
                dy is ay + floor of ((widget.h - widget.h) / 2)
                # Dialog background
                gfx_rrect of [ax, ay, widget.w, widget.h, _theme.radius_lg, _theme.panel_bg[0], _theme.panel_bg[1], _theme.panel_bg[2]]
                # Title bar
                gfx_rrect of [ax, ay, widget.w, 32, _theme.radius_lg, _theme.tab_bg[0], _theme.tab_bg[1], _theme.tab_bg[2]]
                gfx_text of [ax + 12, ay + 9, widget.title, _theme.tab_text_active[0], _theme.tab_text_active[1], _theme.tab_text_active[2], _theme.font_scale]
                # Message
                gfx_text of [ax + 16, ay + 48, widget.message, _theme.text_color[0], _theme.text_color[1], _theme.text_color[2], _theme.font_scale]
                # Buttons
                btn_y is ay + widget.h - 40
                btn_x is ax + widget.w
                i is (len of widget.buttons) - 1
                loop while i >= 0:
                    btext is widget.buttons[i]
                    bw is (text_width of [btext, _theme.font_scale]) + 24
                    btn_x is btn_x - bw - 8
                    if i == widget.hover_btn:
                        bbg is _theme.btn_hover
                    else:
                        bbg is _theme.btn_bg
                    if i == 0:
                        bbg is _theme.accent
                    _draw_rbox of [btn_x, btn_y, bw, 28, _theme.radius_sm, bbg, _theme.panel_border]
                    gfx_text of [btn_x + 12, btn_y + 7, btext, 255, 255, 255, _theme.font_scale]
                    i is i - 1

        case "editable_label":
            if widget.editing == 1:
                # Editing mode — draw like text_input
                ew is widget.w
                if ew < 60:
                    ew is 60
                _draw_rbox of [ax, ay - 2, ew, widget.h + 4, _theme.radius_sm, _theme.dropdown_bg, _theme.accent]
                _draw_text_clipped of [ax + 4, ay, ew - 8, widget.text, _theme.text_color, widget.scale]
                if _cursor_blink < 35:
                    cursor_x is ax + 4 + widget.cursor * (6 * widget.scale)
                    gfx_line of [cursor_x, ay, cursor_x, ay + widget.h, _theme.accent[0], _theme.accent[1], _theme.accent[2]]
            else:
                gfx_text of [ax, ay, widget.text, widget.color[0], widget.color[1], widget.color[2], widget.scale]

        case "grid":
            for r in range of widget.rows:
                for c in range of widget.cols:
                    cx is ax + c * widget.cell_w
                    cy is ay + r * widget.cell_h
                    # Cell color
                    cell_val is widget.cells[r][c]
                    if cell_val > 0:
                        gc is widget.color_on
                    elif c == widget.col_highlight:
                        gc is widget.color_beat
                    elif r == widget.hover_row and c == widget.hover_col:
                        gc is widget.color_hover
                    else:
                        gc is widget.color_off
                        # Alternate beat shading (every 4 cols)
                        beat is floor of (c / 4)
                        if beat == floor of (beat / 2) * 2:
                            gc is widget.color_off
                        else:
                            gc is [35, 35, 48]
                    gfx_rrect of [cx + 1, cy + 1, widget.cell_w - 2, widget.cell_h - 2, 2, gc[0], gc[1], gc[2]]
            # Row labels
            if widget.row_labels != null:
                for r in range of widget.rows:
                    if r < (len of widget.row_labels):
                        ly is ay + r * widget.cell_h + floor of ((widget.cell_h - 7) / 2)
                        gfx_text of [ax - 60, ly, widget.row_labels[r], _theme.text_dim[0], _theme.text_dim[1], _theme.text_dim[2], 1]

        case "item_list":
            # Background
            _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius_sm, _theme.panel_bg, _theme.panel_border]
            gfx_clip of [ax + 1, ay + 1, widget.w - 2, widget.h - 2]
            for i in range of (len of widget.items):
                iy is ay - widget.scroll_y + i * widget.item_h
                if iy + widget.item_h > ay and iy < ay + widget.h:
                    if i == widget.selected:
                        gfx_rrect of [ax + 2, iy + 1, widget.w - 4, widget.item_h - 2, 2, _theme.accent[0], _theme.accent[1], _theme.accent[2]]
                        _draw_text_clipped of [ax + 8, iy + 4, widget.w - 16, widget.items[i], [255, 255, 255], _theme.font_scale]
                    elif i == widget.hover_index:
                        gfx_rrect of [ax + 2, iy + 1, widget.w - 4, widget.item_h - 2, 2, _theme.btn_hover[0], _theme.btn_hover[1], _theme.btn_hover[2]]
                        _draw_text_clipped of [ax + 8, iy + 4, widget.w - 16, widget.items[i], _theme.text_color, _theme.font_scale]
                    else:
                        _draw_text_clipped of [ax + 8, iy + 4, widget.w - 16, widget.items[i], _theme.text_color, _theme.font_scale]
            # Reorder insertion indicator
            if widget.reorder_insert >= 0:
                ri_y is ay - widget.scroll_y + widget.reorder_insert * widget.item_h
                gfx_rect of [ax + 2, ri_y - 1, widget.w - 4, 2, _theme.accent[0], _theme.accent[1], _theme.accent[2]]
            gfx_clip of null
            # Scrollbar
            total_h is (len of widget.items) * widget.item_h
            if total_h > widget.h:
                sb_h is floor of (widget.h * widget.h / total_h)
                if sb_h < 16:
                    sb_h is 16
                sb_y is ay + floor of (widget.scroll_y * (widget.h - sb_h) / (total_h - widget.h))
                gfx_rrect of [ax + widget.w - 6, sb_y, 4, sb_h, 2, 80, 80, 100]

        case "section":
            # Line — label — line
            lw is text_width of [widget.text, 1]
            line_y is ay + 10
            gfx_line of [ax, line_y, ax + 6, line_y, _theme.panel_border[0], _theme.panel_border[1], _theme.panel_border[2]]
            gfx_text of [ax + 10, ay + 6, widget.text, _theme.text_dim[0], _theme.text_dim[1], _theme.text_dim[2], 1]
            gfx_line of [ax + 14 + lw, line_y, ax + widget.w, line_y, _theme.panel_border[0], _theme.panel_border[1], _theme.panel_border[2]]

        case "color_dot":
            gfx_circle of [ax + floor of (widget.w / 2), ay + floor of (widget.h / 2), floor of (widget.w / 2), widget.color[0], widget.color[1], widget.color[2]]

        case "piano_kb":
            kw is widget.key_w
            kh is widget.key_h
            bh is widget.black_h
            # White key pattern per octave: C D E F G A B = indices 0,2,4,5,7,9,11
            # Draw white keys first
            wx is ax
            for o in range of widget.octaves:
                for wk in range of 7:
                    # Map white key index to semitone
                    if wk == 0:
                        note is o * 12
                    elif wk == 1:
                        note is o * 12 + 2
                    elif wk == 2:
                        note is o * 12 + 4
                    elif wk == 3:
                        note is o * 12 + 5
                    elif wk == 4:
                        note is o * 12 + 7
                    elif wk == 5:
                        note is o * 12 + 9
                    else:
                        note is o * 12 + 11
                    if note == widget.pressed_note:
                        gfx_rrect of [wx, ay, kw - 1, kh, 2, 80, 140, 220]
                    elif note == widget.hover_note:
                        gfx_rrect of [wx, ay, kw - 1, kh, 2, 230, 230, 240]
                    else:
                        gfx_rrect of [wx, ay, kw - 1, kh, 2, 240, 240, 245]
                    # Border
                    gfx_line of [wx + kw - 1, ay, wx + kw - 1, ay + kh, 180, 180, 190]
                    wx is wx + kw
            # Final C
            note is widget.octaves * 12
            if note == widget.pressed_note:
                gfx_rrect of [wx, ay, kw - 1, kh, 2, 80, 140, 220]
            else:
                gfx_rrect of [wx, ay, kw - 1, kh, 2, 240, 240, 245]
            # Black keys on top
            wx is ax
            for o in range of widget.octaves:
                # Black keys at positions: C#(1) D#(3) F#(6) G#(8) A#(10)
                for wk in range of 7:
                    has_black is 0
                    if wk == 0:
                        has_black is 1
                        bnote is o * 12 + 1
                    elif wk == 1:
                        has_black is 1
                        bnote is o * 12 + 3
                    elif wk == 3:
                        has_black is 1
                        bnote is o * 12 + 6
                    elif wk == 4:
                        has_black is 1
                        bnote is o * 12 + 8
                    elif wk == 5:
                        has_black is 1
                        bnote is o * 12 + 10
                    if has_black == 1:
                        bx is wx + kw - 5
                        if bnote == widget.pressed_note:
                            gfx_rrect of [bx, ay, 10, bh, 2, 60, 100, 180]
                        elif bnote == widget.hover_note:
                            gfx_rrect of [bx, ay, 10, bh, 2, 60, 60, 70]
                        else:
                            gfx_rrect of [bx, ay, 10, bh, 2, 30, 30, 35]
                    wx is wx + kw
            # Octave labels
            for o in range of widget.octaves:
                lx is ax + o * 7 * kw + 2
                gfx_text of [lx, ay + kh - 12, f"C{widget.base_octave + o}", 140, 140, 160, 1]

        case "waveform_view":
            # Background
            gfx_rect of [ax, ay, widget.w, widget.h, 18, 18, 26]
            mid_y is ay + floor of (widget.h / 2)
            # Center line
            gfx_line of [ax, mid_y, ax + widget.w, mid_y, 35, 35, 45]
            # Selection highlight
            if widget.sel_start >= 0 and widget.sel_end >= 0:
                s0 is floor of ((widget.sel_start - widget.offset) / widget.zoom)
                s1 is floor of ((widget.sel_end - widget.offset) / widget.zoom)
                if s1 > s0:
                    gfx_rect of [ax + s0, ay, s1 - s0, widget.h, widget.color[0], widget.color[1], widget.color[2], 30]
            # Waveform
            n is len of widget.samples
            if n > 0:
                c is widget.color
                prev_y is mid_y
                for px in range of widget.w:
                    si is floor of (widget.offset + px * widget.zoom)
                    if si >= 0 and si < n:
                        amp is widget.samples[si] * (widget.h / 2)
                        sy is mid_y - floor of amp
                        gfx_line of [ax + px, prev_y, ax + px + 1, sy, c[0], c[1], c[2]]
                        prev_y is sy
                    else:
                        prev_y is mid_y
            # Playhead
            if widget.playhead >= 0:
                px is floor of ((widget.playhead - widget.offset) / widget.zoom)
                if px >= 0 and px < widget.w:
                    gfx_line of [ax + px, ay, ax + px, ay + widget.h, 255, 80, 80]
            # Border
            gfx_rrect of [ax, ay, widget.w, 1, 0, 35, 35, 45]
            gfx_rrect of [ax, ay + widget.h - 1, widget.w, 1, 0, 35, 35, 45]

        case "hbox":
            if widget.bg != null:
                _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius, widget.bg, widget.border]
            for i in range of (len of widget.children):
                render of [widget.children[i], ax, ay]

        case "vbox":
            if widget.bg != null:
                _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius, widget.bg, widget.border]
            for i in range of (len of widget.children):
                render of [widget.children[i], ax, ay]

        case "toolbar":
            if widget.bg != null:
                gfx_rect of [ax, ay, widget.w, widget.h, widget.bg[0], widget.bg[1], widget.bg[2]]
            for i in range of (len of widget.children):
                render of [widget.children[i], ax, ay]

        case "statusbar":
            if widget.bg != null:
                gfx_rect of [ax, ay, widget.w, widget.h, widget.bg[0], widget.bg[1], widget.bg[2]]
            # Render sections left-to-right
            sx is ax
            total_flex is 0
            fixed_w is 0
            for i in range of (len of widget.sections):
                sec is widget.sections[i]
                sf is 0
                if sec.flex != null:
                    sf is sec.flex
                if sf > 0:
                    total_flex is total_flex + sf
                else:
                    fixed_w is fixed_w + sec.width
            flex_avail is widget.w - fixed_w
            for i in range of (len of widget.sections):
                sec is widget.sections[i]
                sf is 0
                if sec.flex != null:
                    sf is sec.flex
                if sf > 0 and total_flex > 0:
                    sw is floor of (sf / total_flex * flex_avail)
                else:
                    sw is sec.width
                # Separator between sections
                if i > 0:
                    gfx_line of [sx, ay + 4, sx, ay + widget.h - 4, _theme.panel_border[0], _theme.panel_border[1], _theme.panel_border[2]]
                _draw_text_clipped of [sx + 6, ay + 5, sw - 12, sec.text, _theme.text_dim, _theme.font_scale]
                sx is sx + sw

        case "scrollbar":
            c is _theme.slider_track
            gfx_rrect of [ax, ay, widget.w, widget.h, 3, c[0], c[1], c[2]]
            # Thumb
            ts is widget.thumb_size
            if ts < 0.05:
                ts is 0.05
            if ts > 1:
                ts is 1
            if widget.vertical == 1:
                thumb_h is floor of (ts * widget.h)
                if thumb_h < 16:
                    thumb_h is 16
                thumb_y is ay + floor of (widget.value * (widget.h - thumb_h))
                tc is _theme.slider_thumb
                if widget.hover == 1 or widget.dragging == 1:
                    tc is _theme.slider_fill
                gfx_rrect of [ax + 2, thumb_y, widget.w - 4, thumb_h, 3, tc[0], tc[1], tc[2]]
            else:
                thumb_w is floor of (ts * widget.w)
                if thumb_w < 16:
                    thumb_w is 16
                thumb_x is ax + floor of (widget.value * (widget.w - thumb_w))
                tc is _theme.slider_thumb
                if widget.hover == 1 or widget.dragging == 1:
                    tc is _theme.slider_fill
                gfx_rrect of [thumb_x, ay + 2, thumb_w, widget.h - 4, 3, tc[0], tc[1], tc[2]]

        case "table":
            # Background
            _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius_sm, _theme.panel_bg, _theme.panel_border]
            # Column headers
            hx is ax
            for ci in range of (len of widget.columns):
                col is widget.columns[ci]
                hbg is _theme.tab_bg
                if ci == widget.hover_col_header:
                    hbg is _theme.tab_hover
                gfx_rect of [hx, ay, col.width, widget.header_h, hbg[0], hbg[1], hbg[2]]
                _draw_text_clipped of [hx + 6, ay + 5, col.width - 12, col.name, _theme.tab_text_active, _theme.font_scale]
                # Sort indicator
                if ci == widget.sort_col:
                    if widget.sort_asc == 1:
                        gfx_text of [hx + col.width - 14, ay + 5, "^", _theme.accent[0], _theme.accent[1], _theme.accent[2], 1]
                    else:
                        gfx_text of [hx + col.width - 14, ay + 5, "v", _theme.accent[0], _theme.accent[1], _theme.accent[2], 1]
                # Column separator
                gfx_line of [hx + col.width - 1, ay, hx + col.width - 1, ay + widget.header_h, _theme.panel_border[0], _theme.panel_border[1], _theme.panel_border[2]]
                hx is hx + col.width
            # Header bottom border
            gfx_line of [ax, ay + widget.header_h, ax + widget.w, ay + widget.header_h, _theme.panel_border[0], _theme.panel_border[1], _theme.panel_border[2]]
            # Rows
            body_y is ay + widget.header_h
            body_h is widget.h - widget.header_h
            gfx_clip of [ax + 1, body_y, widget.w - 2, body_h]
            for ri in range of (len of widget.rows):
                ry is body_y - widget.scroll_y + ri * widget.row_h
                if ry + widget.row_h > body_y and ry < body_y + body_h:
                    if ri == widget.selected:
                        gfx_rrect of [ax + 1, ry, widget.w - 2, widget.row_h, 0, _theme.accent[0], _theme.accent[1], _theme.accent[2]]
                        row_tc is [255, 255, 255]
                    elif ri == widget.hover_row:
                        gfx_rrect of [ax + 1, ry, widget.w - 2, widget.row_h, 0, _theme.btn_hover[0], _theme.btn_hover[1], _theme.btn_hover[2]]
                        row_tc is _theme.text_color
                    else:
                        # Alternating row tint
                        if (ri / 2) != floor of (ri / 2):
                            gfx_rrect of [ax + 1, ry, widget.w - 2, widget.row_h, 0, _theme.dropdown_bg[0], _theme.dropdown_bg[1], _theme.dropdown_bg[2]]
                        row_tc is _theme.text_color
                    # Cell values
                    cx is ax
                    row is widget.rows[ri]
                    for ci in range of (len of widget.columns):
                        col is widget.columns[ci]
                        cell_text is ""
                        if ci < (len of row):
                            cell_text is f"{row[ci]}"
                        _draw_text_clipped of [cx + 6, ry + 4, col.width - 12, cell_text, row_tc, _theme.font_scale]
                        cx is cx + col.width
            gfx_clip of null
            # Scrollbar
            total_h is (len of widget.rows) * widget.row_h
            if total_h > body_h:
                sb_h is floor of (body_h * body_h / total_h)
                if sb_h < 16:
                    sb_h is 16
                sb_y is body_y + floor of (widget.scroll_y * (body_h - sb_h) / (total_h - body_h))
                gfx_rrect of [ax + widget.w - 6, sb_y, 4, sb_h, 2, 80, 80, 100]

        case "tree":
            # Background
            _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius_sm, _theme.panel_bg, _theme.panel_border]
            gfx_clip of [ax + 1, ay + 1, widget.w - 2, widget.h - 2]
            flat is []
            _flatten_tree of [widget.nodes, 0, flat]
            for fi in range of (len of flat):
                fe is flat[fi]
                iy is ay - widget.scroll_y + fi * widget.item_h
                if iy + widget.item_h > ay and iy < ay + widget.h:
                    indent is 16 * fe.depth + 8
                    # Selection highlight
                    if fe.node.id != null and fe.node.id == widget.selected_id:
                        gfx_rrect of [ax + 2, iy + 1, widget.w - 4, widget.item_h - 2, 2, _theme.accent[0], _theme.accent[1], _theme.accent[2]]
                        ntc is [255, 255, 255]
                    elif fi == widget.hover_index:
                        gfx_rrect of [ax + 2, iy + 1, widget.w - 4, widget.item_h - 2, 2, _theme.btn_hover[0], _theme.btn_hover[1], _theme.btn_hover[2]]
                        ntc is _theme.text_color
                    else:
                        ntc is _theme.text_color
                    # Expand arrow
                    if fe.has_children == 1:
                        if fe.expanded == 1:
                            gfx_text of [ax + indent - 12, iy + 4, "v", _theme.text_dim[0], _theme.text_dim[1], _theme.text_dim[2], _theme.font_scale]
                        else:
                            gfx_text of [ax + indent - 12, iy + 4, ">", _theme.text_dim[0], _theme.text_dim[1], _theme.text_dim[2], _theme.font_scale]
                    # Node text
                    _draw_text_clipped of [ax + indent, iy + 4, widget.w - indent - 8, fe.node.text, ntc, _theme.font_scale]
            gfx_clip of null
            # Scrollbar
            total_h is (len of flat) * widget.item_h
            if total_h > widget.h:
                sb_h is floor of (widget.h * widget.h / total_h)
                if sb_h < 16:
                    sb_h is 16
                sb_y is ay + floor of (widget.scroll_y * (widget.h - sb_h) / (total_h - widget.h))
                gfx_rrect of [ax + widget.w - 6, sb_y, 4, sb_h, 2, 80, 80, 100]

        case "combobox":
            if widget.hover == 1:
                cbg is _theme.dropdown_hover
            else:
                cbg is _theme.dropdown_bg
            if widget.open == 1:
                cb_border is _theme.accent
            else:
                cb_border is _theme.panel_border
            _draw_rbox of [ax, ay, widget.w, widget.h, _theme.radius_sm, cbg, cb_border]
            # Display filter text when open, otherwise selected item text
            if widget.open == 1:
                disp_text is widget.filter_text
            elif widget.selected >= 0 and widget.selected < (len of widget.items):
                disp_text is widget.items[widget.selected]
            else:
                disp_text is widget.filter_text
            _draw_text_clipped of [ax + 6, ay + 5, widget.w - 24, disp_text, _theme.text_color, _theme.font_scale]
            # Arrow
            arrow_x is ax + widget.w - 16
            arrow_y is ay + 8
            gfx_line of [arrow_x, arrow_y, arrow_x + 4, arrow_y + 6, _theme.dropdown_arrow[0], _theme.dropdown_arrow[1], _theme.dropdown_arrow[2]]
            gfx_line of [arrow_x + 8, arrow_y, arrow_x + 4, arrow_y + 6, _theme.dropdown_arrow[0], _theme.dropdown_arrow[1], _theme.dropdown_arrow[2]]
            # Cursor when open
            if widget.open == 1 and _cursor_blink < 35:
                cx_pos is ax + 6 + widget.cursor * _theme.char_w
                if cx_pos < ax + widget.w - 20:
                    gfx_line of [cx_pos, ay + 4, cx_pos, ay + widget.h - 4, _theme.accent[0], _theme.accent[1], _theme.accent[2]]
            # Dropdown when open
            if widget.open == 1:
                item_h is 24
                menu_h is (len of widget.filtered) * item_h
                if menu_h > 200:
                    menu_h is 200
                if menu_h > 0:
                    gfx_rrect of [ax, ay + widget.h + 2, widget.w, menu_h, _theme.radius_sm, _theme.menu_bg[0], _theme.menu_bg[1], _theme.menu_bg[2]]
                    for i in range of (len of widget.filtered):
                        iy is ay + widget.h + 2 + i * item_h
                        if iy < ay + widget.h + 2 + menu_h:
                            if i == widget.hover_index:
                                gfx_rrect of [ax + 2, iy, widget.w - 4, item_h, _theme.radius_sm, _theme.menu_hover[0], _theme.menu_hover[1], _theme.menu_hover[2]]
                            _draw_text_clipped of [ax + 8, iy + 5, widget.w - 16, widget.filtered[i], _theme.text_color, _theme.font_scale]

        case "color_picker":
            # SV square: 150x120 at top-left
            sq_w is 150
            sq_h is 120
            # Draw SV square as horizontal color strips
            for row in range of sq_h:
                v_val is 1.0 - row / sq_h
                for col_step in range of 15:
                    s_val is col_step / 15.0
                    c is _hsv_to_rgb of [widget.hue, s_val, v_val]
                    strip_x is ax + floor of (col_step * sq_w / 15)
                    strip_w is floor of (sq_w / 15)
                    gfx_rect of [strip_x, ay + row, strip_w, 1, c[0], c[1], c[2]]
            # SV crosshair
            cx_sv is ax + floor of (widget.sat * sq_w)
            cy_sv is ay + floor of ((1.0 - widget.val) * sq_h)
            gfx_line of [cx_sv - 4, cy_sv, cx_sv + 4, cy_sv, 255, 255, 255]
            gfx_line of [cx_sv, cy_sv - 4, cx_sv, cy_sv + 4, 255, 255, 255]
            # Hue bar: 20x120 to the right of SV square
            hue_x is ax + sq_w + 8
            hue_w is 20
            for row in range of sq_h:
                h_val is row * 360 / sq_h
                c is _hsv_to_rgb of [h_val, 1.0, 1.0]
                gfx_rect of [hue_x, ay + row, hue_w, 1, c[0], c[1], c[2]]
            # Hue marker
            hue_marker_y is ay + floor of (widget.hue * sq_h / 360)
            gfx_rect of [hue_x - 2, hue_marker_y - 1, hue_w + 4, 3, 255, 255, 255]
            # Color preview
            pc is widget.color
            gfx_rrect of [ax, ay + sq_h + 6, 40, 24, 4, pc[0], pc[1], pc[2]]
            # RGB text
            gfx_text of [ax + 48, ay + sq_h + 12, f"R:{pc[0]} G:{pc[1]} B:{pc[2]}", _theme.text_color[0], _theme.text_color[1], _theme.text_color[2], 1]

    # Disabled overlay for interactive widgets
    if widget.enabled != null and widget.enabled == 0:
        _draw_disabled_overlay of [ax, ay, widget.w, widget.h]

    # Focus ring for focused widget
    if _focused_widget != null and _focused_widget.id == widget.id:
        _draw_focus_ring of [ax, ay, widget.w, widget.h, _theme.radius_sm]

    return null

# Render tooltip overlay — called after main render
define _render_tooltip() as:
    if _tooltip_widget == null:
        return null
    if _tooltip_timer < 30:
        return null
    tw is (text_width of [_tooltip_widget.tooltip, 1]) + 8
    th is 18
    tx is _tooltip_x + 12
    ty is _tooltip_y - 20
    if ty < 0:
        ty is _tooltip_y + 20
    # Clamp to window bounds
    if tx + tw > _window_w:
        tx is _window_w - tw - 4
    if tx < 0:
        tx is 4
    if ty + th > _window_h:
        ty is _window_h - th - 4
    # Shadow
    tbg is _theme.tooltip_bg
    ttc is _theme.tooltip_text
    gfx_rrect of [tx + 1, ty + 1, tw, th, 3, 10, 10, 15, 150]
    # Background
    gfx_rrect of [tx, ty, tw, th, 3, tbg[0], tbg[1], tbg[2]]
    # Text
    gfx_text of [tx + 4, ty + 4, _tooltip_widget.tooltip, ttc[0], ttc[1], ttc[2], 1]

# ============================================================
# Hit testing
# ============================================================

define _hit_test(widget, ox, oy, mx, my) as:
    if widget.visible == 0:
        return null
    ax is ox + widget.x
    ay is oy + widget.y

    if widget.type == "panel" or widget.type == "hbox" or widget.type == "vbox" or widget.type == "toolbar":
        # Test children in reverse order (topmost first)
        i is (len of widget.children) - 1
        loop while i >= 0:
            hit is _hit_test of [widget.children[i], ax, ay, mx, my]
            if hit != null:
                return hit
            i is i - 1
        return null

    # Tabs — check active tab panel first, then tab bar
    if widget.type == "tabs":
        tab_h is 28
        if widget.active < (len of widget.tab_panels):
            tp is widget.tab_panels[widget.active]
            if tp != null:
                hit is _hit_test of [tp, ax, ay + tab_h, mx, my]
                if hit != null:
                    return hit
        # Tab bar hit — return the tabs widget itself
        if _point_in_rect of [mx, my, ax, ay, widget.w, 28]:
            return widget
        return null

    # Scroll panel — check scrollbar first, then children
    if widget.type == "scroll_panel":
        if _point_in_rect of [mx, my, ax, ay, widget.w, widget.h]:
            # Check if clicking on vertical scrollbar area (right 8px)
            if widget.content_h > widget.h and mx >= ax + widget.w - 8:
                return widget
            # Check children with scroll offset
            i is (len of widget.children) - 1
            loop while i >= 0:
                hit is _hit_test of [widget.children[i], ax - widget.scroll_x, ay - widget.scroll_y, mx, my]
                if hit != null:
                    return hit
                i is i - 1
            return widget
        return null

    # Splitter — check both panels then the bar
    if widget.type == "splitter":
        sp is floor of widget.split_pos
        bw is widget.bar_width
        # Check divider bar
        if _point_in_rect of [mx, my, ax + sp, ay, bw, widget.h]:
            return widget
        # Check panel A
        if widget.panel_a != null:
            hit is _hit_test of [widget.panel_a, ax, ay, mx, my]
            if hit != null:
                return hit
        # Check panel B
        if widget.panel_b != null:
            hit is _hit_test of [widget.panel_b, ax + sp + bw, ay, mx, my]
            if hit != null:
                return hit
        return null

    # Leaf widget — check bounds
    if widget.type == "button" or widget.type == "slider" or widget.type == "vslider" or widget.type == "toggle" or widget.type == "knob" or widget.type == "canvas" or widget.type == "checkbox" or widget.type == "text_input" or widget.type == "toggle_button" or widget.type == "spinbox" or widget.type == "radio_group" or widget.type == "meter" or widget.type == "grid" or widget.type == "editable_label" or widget.type == "item_list" or widget.type == "piano_kb" or widget.type == "waveform_view" or widget.type == "scrollbar" or widget.type == "table" or widget.type == "statusbar" or widget.type == "tree" or widget.type == "color_picker":
        if _point_in_rect of [mx, my, ax, ay, widget.w, widget.h]:
            return widget

    # Dropdown — include open menu area
    if widget.type == "dropdown":
        total_h is widget.h
        if widget.open == 1:
            total_h is widget.h + (len of widget.items) * 24 + 2
        if _point_in_rect of [mx, my, ax, ay, widget.w, total_h]:
            return widget

    # Combobox — include open dropdown area
    if widget.type == "combobox":
        total_h is widget.h
        if widget.open == 1:
            drop_h is (len of widget.filtered) * 24
            if drop_h > 200:
                drop_h is 200
            total_h is widget.h + drop_h + 2
        if _point_in_rect of [mx, my, ax, ay, widget.w, total_h]:
            return widget

    # Context menu
    if widget.type == "menu" and widget.visible == 1:
        menu_h is (len of widget.items) * 24
        if _point_in_rect of [mx, my, ax, ay, widget.w, menu_h]:
            return widget

    return null

# ============================================================
# Clear hover/pressed state
# ============================================================

define _clear_hover(widget) as:
    if _is_container of widget.type:
        for i in range of (len of widget.children):
            _clear_hover of widget.children[i]
    elif widget.type == "tabs":
        widget.hover_tab is -1
        for i in range of (len of widget.tab_panels):
            if widget.tab_panels[i] != null:
                _clear_hover of widget.tab_panels[i]
    elif widget.type == "splitter":
        widget.hover is 0
        if widget.panel_a != null:
            _clear_hover of widget.panel_a
        if widget.panel_b != null:
            _clear_hover of widget.panel_b
    elif widget.type == "dropdown":
        widget.hover is 0
        widget.hover_index is -1
    elif widget.type == "spinbox":
        widget.hover is 0
        widget.hover_btn is 0
    elif widget.type == "radio_group":
        widget.hover_index is -1
    elif widget.type == "table":
        widget.hover_row is -1
        widget.hover_col_header is -1
    elif widget.type == "tree":
        widget.hover_index is -1
    elif widget.type == "combobox":
        widget.hover is 0
        widget.hover_index is -1
    else:
        if (type of widget) == "dict":
            widget.hover is 0

# ============================================================
# Event dispatch
# ============================================================

define dispatch(root, ev) as:
    mx is 0
    my is 0
    if ev.type == "mousemove" or ev.type == "mousedown" or ev.type == "mouseup":
        mx is ev.x
        my is ev.y

    # Handle DnD in progress
    if ev.type == "mousemove" and _dnd_state.active == 1:
        _dnd_state.mx is mx
        _dnd_state.my is my
        # Compute reorder insertion index if dragging over source list
        if _dnd_state.source != null and _dnd_state.source.type == "item_list":
            src is _dnd_state.source
            abs_y is _find_abs_y of [root, src, 0, 0]
            if _point_in_rect of [mx, my, _find_abs_x of [root, src, 0, 0], abs_y, src.w, src.h]:
                src.reorder_insert is floor of ((my - abs_y + src.scroll_y) / src.item_h)
                if src.reorder_insert > (len of src.items):
                    src.reorder_insert is len of src.items
            else:
                src.reorder_insert is -1
        return null

    # Handle drag in progress (slider, vslider, or knob)
    if ev.type == "mousemove" and _drag_widget != null:
        if _drag_widget.type == "knob":
            _update_knob_drag of [_drag_widget, my]
        elif _drag_widget.type == "vslider":
            _update_vdrag of [_drag_widget, my]
        elif _drag_widget.type == "waveform_view":
            sample_pos is floor of (_drag_widget.offset + (mx - _drag_ox) * _drag_widget.zoom)
            _drag_widget.sel_end is sample_pos
        elif _drag_widget.type == "scrollbar":
            _update_scrollbar_drag of [_drag_widget, mx, my]
        elif _drag_widget.type == "splitter":
            new_pos is mx - _drag_ox
            if new_pos < 50:
                new_pos is 50
            if new_pos > _drag_widget.w - 50:
                new_pos is _drag_widget.w - 50
            _drag_widget.split_pos is new_pos
            if _drag_widget.on_resize != null:
                _drag_widget.on_resize of _drag_widget
        elif _drag_widget.type == "color_picker":
            abs_x is _find_abs_x of [root, _drag_widget, 0, 0]
            abs_y is _find_abs_y of [root, _drag_widget, 0, 0]
            if _drag_widget.drag_part == "sv":
                s_val is (mx - abs_x) / 150.0
                v_val is 1.0 - (my - abs_y) / 120.0
                if s_val < 0:
                    s_val is 0
                if s_val > 1:
                    s_val is 1
                if v_val < 0:
                    v_val is 0
                if v_val > 1:
                    v_val is 1
                _drag_widget.sat is s_val
                _drag_widget.val is v_val
            elif _drag_widget.drag_part == "hue":
                h_val is (my - abs_y) * 360 / 120.0
                if h_val < 0:
                    h_val is 0
                if h_val > 359:
                    h_val is 359
                _drag_widget.hue is h_val
            _drag_widget.color is _hsv_to_rgb of [_drag_widget.hue, _drag_widget.sat, _drag_widget.val]
            if _drag_widget.on_change != null:
                _drag_widget.on_change of _drag_widget
        else:
            _update_drag of [_drag_widget, mx]
        return null

    if ev.type == "mouseup" and _dnd_state.active == 1:
        # DnD drop
        hit is _hit_test of [root, 0, 0, mx, my]
        drop_data is {"source_widget": _dnd_state.source, "source_index": _dnd_state.source_index, "data": _dnd_state.data}
        # Self-drop reorder
        if hit != null and _dnd_state.source != null and hit.id == _dnd_state.source.id and hit.type == "item_list" and hit.on_reorder != null:
            insert_idx is hit.reorder_insert
            if insert_idx >= 0:
                hit.on_reorder of [hit, _dnd_state.source_index, insert_idx]
            hit.reorder_insert is -1
        elif hit != null and hit.on_drop != null:
            hit.on_drop of [hit, drop_data]
        # Clean up
        if _dnd_state.source != null and _dnd_state.source.type == "item_list":
            _dnd_state.source.reorder_insert is -1
        _dnd_state.active is 0
        _dnd_state.source is null
        _dnd_state.source_index is -1
        _dnd_state.data is null
        _dnd_state.text is ""
        return null

    if ev.type == "mouseup" and _drag_widget != null:
        _drag_widget.dragging is 0
        if _drag_widget.on_change != null:
            _drag_widget.on_change of _drag_widget
        _drag_widget is null
        return null

    # Mouse move — update hover + tooltip
    if ev.type == "mousemove":
        _clear_hover of root
        hit is _hit_test of [root, 0, 0, mx, my]
        if hit != null:
            hit.hover is 1
            # Tooltip tracking
            if hit.tooltip != null and (len of hit.tooltip) > 0:
                if _tooltip_widget == null or _tooltip_widget.id != hit.id:
                    _tooltip_widget is hit
                    _tooltip_timer is 0
                _tooltip_x is mx
                _tooltip_y is my
            else:
                _tooltip_widget is null
                _tooltip_timer is 0
            # Dropdown hover index
            if hit.type == "dropdown" and hit.open == 1:
                abs_y is _find_abs_y of [root, hit, 0, 0]
                rel_y is my - abs_y - hit.h
                if rel_y >= 0:
                    hit.hover_index is floor of (rel_y / 24)
                else:
                    hit.hover_index is -1
            # Tabs hover
            if hit.type == "tabs":
                abs_x is _find_abs_x of [root, hit, 0, 0]
                _update_tab_hover of [hit, mx - abs_x]
            # Menu hover index
            if hit.type == "menu":
                abs_y is _find_abs_y of [root, hit, 0, 0]
                hit.hover_index is floor of ((my - abs_y) / 24)
            # Spinbox button hover
            if hit.type == "spinbox":
                abs_x is _find_abs_x of [root, hit, 0, 0]
                rel_x is mx - abs_x
                if rel_x >= hit.w - 40 and rel_x < hit.w - 20:
                    hit.hover_btn is 1
                elif rel_x >= hit.w - 20:
                    hit.hover_btn is 2
                else:
                    hit.hover_btn is 0
            # Radio group hover
            if hit.type == "radio_group":
                abs_x is _find_abs_x of [root, hit, 0, 0]
                hit.hover_index is _radio_index_at of [hit, mx - abs_x]
            # Piano hover
            if hit.type == "piano_kb":
                abs_x is _find_abs_x of [root, hit, 0, 0]
                abs_y is _find_abs_y of [root, hit, 0, 0]
                hit.hover_note is _piano_note_at of [hit, mx - abs_x, my - abs_y]
            # Item list hover
            if hit.type == "item_list":
                abs_y is _find_abs_y of [root, hit, 0, 0]
                hit.hover_index is floor of ((my - abs_y + hit.scroll_y) / hit.item_h)
            # Grid hover
            if hit.type == "grid":
                abs_x is _find_abs_x of [root, hit, 0, 0]
                abs_y is _find_abs_y of [root, hit, 0, 0]
                hit.hover_col is floor of ((mx - abs_x) / hit.cell_w)
                hit.hover_row is floor of ((my - abs_y) / hit.cell_h)
            # Table hover
            if hit.type == "table":
                abs_x is _find_abs_x of [root, hit, 0, 0]
                abs_y is _find_abs_y of [root, hit, 0, 0]
                rel_y is my - abs_y
                if rel_y < hit.header_h:
                    # Column header hover
                    rx is 0
                    for ci in range of (len of hit.columns):
                        col is hit.columns[ci]
                        if (mx - abs_x) >= rx and (mx - abs_x) < rx + col.width:
                            hit.hover_col_header is ci
                        rx is rx + col.width
                else:
                    hit.hover_row is floor of ((rel_y - hit.header_h + hit.scroll_y) / hit.row_h)
            # Tree hover
            if hit.type == "tree":
                abs_y is _find_abs_y of [root, hit, 0, 0]
                hit.hover_index is floor of ((my - abs_y + hit.scroll_y) / hit.item_h)
            # Combobox hover index
            if hit.type == "combobox" and hit.open == 1:
                abs_y is _find_abs_y of [root, hit, 0, 0]
                rel_y is my - abs_y - hit.h - 2
                if rel_y >= 0:
                    hit.hover_index is floor of (rel_y / 24)
                else:
                    hit.hover_index is -1
        else:
            _tooltip_widget is null
            _tooltip_timer is 0
        return null

    # Mouse down — start interaction
    if ev.type == "mousedown":
        # Reset tooltip
        _tooltip_widget is null
        _tooltip_timer is 0
        # Close any open dropdowns first
        _close_dropdowns of root
        # Check modal stack first (they're modal)
        if (len of _modal_stack) > 0:
            top_modal is _modal_stack[(len of _modal_stack) - 1]
            _handle_dialog_click of [top_modal, mx, my]
            return null
        hit is _hit_test of [root, 0, 0, mx, my]
        if hit == null:
            _unfocus_all of root
            _focused_input is null
            _focused_widget is null
            _focus_index is -1
            return null
        # Universal disabled check
        if hit.enabled != null and hit.enabled == 0:
            return null
        # Right-click context menu
        btn is 1
        if ev.button != null:
            btn is ev.button
        if btn == 3:
            _close_menus of root
            if hit.context_menu != null:
                show_menu of [hit.context_menu, mx, my]
            elif hit.on_right_click != null:
                hit.on_right_click of [hit, mx, my]
            return null
        # Sync focus to clicked widget
        _sync_focus_to of hit
        # Double-click detection
        now is gfx_ticks of null
        if hit.id == _last_click_id and (now - _last_click_time) < 400:
            if hit.type == "editable_label":
                _start_editing of hit
            elif hit.on_dblclick != null:
                hit.on_dblclick of hit
            _last_click_id is ""
            _last_click_time is 0
            return null
        _last_click_id is hit.id
        _last_click_time is now
        if hit.type == "button" and hit.enabled == 1:
            hit.pressed is 1
        elif hit.type == "slider" and hit.enabled == 1:
            hit.dragging is 1
            _drag_widget is hit
            _drag_ox is _find_abs_x of [root, hit, 0, 0]
            _update_drag of [hit, mx]
        elif hit.type == "knob" and hit.enabled == 1:
            hit.dragging is 1
            hit.drag_start_y is my
            hit.drag_start_val is hit.value
            _drag_widget is hit
        elif hit.type == "toggle" and hit.enabled == 1:
            if hit.value == 1:
                hit.value is 0
            else:
                hit.value is 1
            if hit.on_change != null:
                hit.on_change of hit
        elif hit.type == "dropdown" and hit.enabled == 1:
            if hit.open == 1:
                # Click on open menu — select item
                if hit.hover_index >= 0 and hit.hover_index < (len of hit.items):
                    hit.selected is hit.hover_index
                    if hit.on_change != null:
                        hit.on_change of hit
                hit.open is 0
            else:
                hit.open is 1
        elif hit.type == "tabs":
            abs_x is _find_abs_x of [root, hit, 0, 0]
            idx is _tab_index_at of [hit, mx - abs_x]
            if idx >= 0:
                hit.active is idx
                if hit.on_tab != null:
                    hit.on_tab of hit
        elif hit.type == "vslider" and hit.enabled == 1:
            hit.dragging is 1
            _drag_widget is hit
            _drag_oy is _find_abs_y of [root, hit, 0, 0]
            _update_vdrag of [hit, my]
        elif hit.type == "checkbox" and hit.enabled == 1:
            if hit.value == 1:
                hit.value is 0
            else:
                hit.value is 1
            if hit.on_change != null:
                hit.on_change of hit
        elif hit.type == "toggle_button" and hit.enabled == 1:
            if hit.value == 1:
                hit.value is 0
            else:
                hit.value is 1
            if hit.on_click != null:
                hit.on_click of hit
        elif hit.type == "spinbox" and hit.enabled == 1:
            abs_x is _find_abs_x of [root, hit, 0, 0]
            rel_x is mx - abs_x
            if rel_x >= hit.w - 40 and rel_x < hit.w - 20:
                # Minus button
                hit.value is hit.value - hit.step
                if hit.value < hit.min_val:
                    hit.value is hit.min_val
                if hit.on_change != null:
                    hit.on_change of hit
            elif rel_x >= hit.w - 20:
                # Plus button
                hit.value is hit.value + hit.step
                if hit.value > hit.max_val:
                    hit.value is hit.max_val
                if hit.on_change != null:
                    hit.on_change of hit
        elif hit.type == "radio_group" and hit.enabled == 1:
            abs_x is _find_abs_x of [root, hit, 0, 0]
            idx is _radio_index_at of [hit, mx - abs_x]
            if idx >= 0 and idx != hit.selected:
                hit.selected is idx
                if hit.on_change != null:
                    hit.on_change of hit
        elif hit.type == "piano_kb":
            abs_x is _find_abs_x of [root, hit, 0, 0]
            abs_y is _find_abs_y of [root, hit, 0, 0]
            note is _piano_note_at of [hit, mx - abs_x, my - abs_y]
            if note >= 0:
                hit.pressed_note is note
                if hit.on_note != null:
                    hit.on_note of [hit, note, 1]
        elif hit.type == "waveform_view":
            abs_x is _find_abs_x of [root, hit, 0, 0]
            sample_pos is floor of (hit.offset + (mx - abs_x) * hit.zoom)
            hit.sel_start is sample_pos
            hit.sel_end is sample_pos
            _drag_widget is hit
            _drag_ox is abs_x
        elif hit.type == "item_list":
            abs_y is _find_abs_y of [root, hit, 0, 0]
            idx is floor of ((my - abs_y + hit.scroll_y) / hit.item_h)
            if idx >= 0 and idx < (len of hit.items):
                if hit.draggable == 1:
                    # Start DnD
                    _dnd_state.active is 1
                    _dnd_state.source is hit
                    _dnd_state.source_index is idx
                    _dnd_state.data is hit.items[idx]
                    _dnd_state.mx is mx
                    _dnd_state.my is my
                    _dnd_state.text is f"{hit.items[idx]}"
                    hit.selected is idx
                else:
                    hit.selected is idx
                    if hit.on_select != null:
                        hit.on_select of hit
        elif hit.type == "scroll_panel":
            # Scrollbar click — jump to position
            if hit.content_h > hit.h:
                abs_y is _find_abs_y of [root, hit, 0, 0]
                abs_x is _find_abs_x of [root, hit, 0, 0]
                if mx >= abs_x + hit.w - 8:
                    frac is (my - abs_y) / hit.h
                    hit.scroll_y is floor of (frac * (hit.content_h - hit.h))
                    if hit.scroll_y < 0:
                        hit.scroll_y is 0
                    max_sy is hit.content_h - hit.h
                    if hit.scroll_y > max_sy:
                        hit.scroll_y is max_sy
        elif hit.type == "grid":
            abs_x is _find_abs_x of [root, hit, 0, 0]
            abs_y is _find_abs_y of [root, hit, 0, 0]
            gc is floor of ((mx - abs_x) / hit.cell_w)
            gr is floor of ((my - abs_y) / hit.cell_h)
            if gc >= 0 and gc < hit.cols and gr >= 0 and gr < hit.rows:
                # Toggle cell
                if hit.cells[gr][gc] > 0:
                    hit.cells[gr][gc] is 0
                else:
                    hit.cells[gr][gc] is 1
                if hit.on_cell != null:
                    hit.on_cell of [hit, gr, gc]
        elif hit.type == "editable_label":
            # Single click does nothing (double-click starts editing)
            pass is 0
        elif hit.type == "splitter":
            hit.dragging is 1
            _drag_widget is hit
            _drag_ox is _find_abs_x of [root, hit, 0, 0]
        elif hit.type == "text_input" and hit.enabled == 1:
            _unfocus_all of root
            hit.focused is 1
            _focused_input is hit
        elif hit.type == "menu":
            if hit.hover_index >= 0 and hit.hover_index < (len of hit.items):
                item is hit.items[hit.hover_index]
                is_sep is 0
                if (type of item) == "str" and item == "-":
                    is_sep is 1
                if is_sep == 0:
                    if hit.on_select != null:
                        hit.on_select of [hit, hit.hover_index]
            hit.visible is 0
        elif hit.type == "canvas":
            if hit.on_mouse != null:
                hit.on_mouse of [hit, ev]
        elif hit.type == "scrollbar" and hit.enabled == 1:
            hit.dragging is 1
            _drag_widget is hit
            _drag_ox is _find_abs_x of [root, hit, 0, 0]
            _drag_oy is _find_abs_y of [root, hit, 0, 0]
            _update_scrollbar_drag of [hit, mx, my]
        elif hit.type == "table" and hit.enabled == 1:
            abs_x is _find_abs_x of [root, hit, 0, 0]
            abs_y is _find_abs_y of [root, hit, 0, 0]
            rel_y is my - abs_y
            if rel_y < hit.header_h:
                # Header click — sort
                rx is 0
                for ci in range of (len of hit.columns):
                    col is hit.columns[ci]
                    if (mx - abs_x) >= rx and (mx - abs_x) < rx + col.width:
                        if hit.sort_col == ci:
                            if hit.sort_asc == 1:
                                hit.sort_asc is 0
                            else:
                                hit.sort_asc is 1
                        else:
                            hit.sort_col is ci
                            hit.sort_asc is 1
                        if hit.on_sort != null:
                            hit.on_sort of hit
                    rx is rx + col.width
            else:
                # Row click — select
                ri is floor of ((rel_y - hit.header_h + hit.scroll_y) / hit.row_h)
                if ri >= 0 and ri < (len of hit.rows):
                    hit.selected is ri
                    if hit.on_select != null:
                        hit.on_select of hit
        elif hit.type == "tree":
            abs_y is _find_abs_y of [root, hit, 0, 0]
            flat is []
            _flatten_tree of [hit.nodes, 0, flat]
            fi is floor of ((my - abs_y + hit.scroll_y) / hit.item_h)
            if fi >= 0 and fi < (len of flat):
                fe is flat[fi]
                abs_x is _find_abs_x of [root, hit, 0, 0]
                indent is 16 * fe.depth + 8
                rel_x is mx - abs_x
                if fe.has_children == 1 and rel_x < indent:
                    # Toggle expand
                    if fe.expanded == 1:
                        fe.node.expanded is 0
                    else:
                        fe.node.expanded is 1
                else:
                    # Select node
                    hit.selected_id is fe.node.id
                    if hit.on_select != null:
                        hit.on_select of [hit, fe.node]
        elif hit.type == "combobox" and hit.enabled == 1:
            if hit.open == 1:
                if hit.hover_index >= 0 and hit.hover_index < (len of hit.filtered):
                    hit.filter_text is hit.filtered[hit.hover_index]
                    # Find original index
                    sel_text is hit.filtered[hit.hover_index]
                    for oi in range of (len of hit.items):
                        if hit.items[oi] == sel_text:
                            hit.selected is oi
                    hit.open is 0
                    if hit.on_change != null:
                        hit.on_change of hit
                else:
                    hit.open is 0
            else:
                hit.open is 1
                hit.filter_text is ""
                hit.filtered is hit.items
                hit.hover_index is 0
                hit.cursor is 0
        elif hit.type == "color_picker":
            abs_x is _find_abs_x of [root, hit, 0, 0]
            abs_y is _find_abs_y of [root, hit, 0, 0]
            rel_x is mx - abs_x
            rel_y is my - abs_y
            if rel_x < 150 and rel_y < 120:
                hit.drag_part is "sv"
                _drag_widget is hit
                hit.sat is rel_x / 150.0
                hit.val is 1.0 - rel_y / 120.0
            elif rel_x >= 158 and rel_x < 178 and rel_y < 120:
                hit.drag_part is "hue"
                _drag_widget is hit
                hit.hue is rel_y * 360 / 120.0
            hit.color is _hsv_to_rgb of [hit.hue, hit.sat, hit.val]
            if hit.on_change != null:
                hit.on_change of hit
        # Close menus on click elsewhere
        _close_menus of root
        return null

    # Mouse up — fire button click
    if ev.type == "mouseup":
        hit is _hit_test of [root, 0, 0, mx, my]
        if hit != null and hit.type == "button" and hit.pressed == 1:
            hit.pressed is 0
            if hit.on_click != null and hit.enabled == 1:
                hit.on_click of hit
            return null
        if hit != null and hit.type == "piano_kb":
            if hit.pressed_note >= 0:
                if hit.on_note != null:
                    hit.on_note of [hit, hit.pressed_note, 0]
                hit.pressed_note is -1
            return null
        if hit != null and hit.type == "canvas":
            if hit.on_mouse != null:
                hit.on_mouse of [hit, ev]
            return null
        _clear_pressed of root
        return null

    # Scroll wheel
    if ev.type == "wheel":
        _scroll_panels of [root, ev.x * -20, ev.y * -20]
        return null

    return null

define _clear_pressed(widget) as:
    if widget.type == "button":
        widget.pressed is 0
    elif _is_container of widget.type:
        for i in range of (len of widget.children):
            _clear_pressed of widget.children[i]
    elif widget.type == "tabs":
        for i in range of (len of widget.tab_panels):
            if widget.tab_panels[i] != null:
                _clear_pressed of widget.tab_panels[i]
    elif widget.type == "splitter":
        if widget.panel_a != null:
            _clear_pressed of widget.panel_a
        if widget.panel_b != null:
            _clear_pressed of widget.panel_b

# ============================================================
# Slider drag math
# ============================================================
# _drag_widget stores absolute x from the last hit_test walk.
# But we need the absolute x of the slider to compute the value.
# For simplicity, we walk up from root to find it. Instead,
# we store _drag_ox when drag starts.

_drag_ox is 0

define _find_abs_x(root, target, ox, oy) as:
    ax is ox + root.x
    ay is oy + root.y
    if root.id == target.id:
        return ax
    if _is_container of root.type:
        for i in range of (len of root.children):
            result is _find_abs_x of [root.children[i], target, ax, ay]
            if result != -1:
                return result
    if root.type == "tabs":
        for i in range of (len of root.tab_panels):
            if root.tab_panels[i] != null:
                result is _find_abs_x of [root.tab_panels[i], target, ax, ay + 28]
                if result != -1:
                    return result
    if root.type == "splitter":
        if root.panel_a != null:
            result is _find_abs_x of [root.panel_a, target, ax, ay]
            if result != -1:
                return result
        if root.panel_b != null:
            sp is floor of root.split_pos
            result is _find_abs_x of [root.panel_b, target, ax + sp + root.bar_width, ay]
            if result != -1:
                return result
    return -1

define _find_abs_y(root, target, ox, oy) as:
    ax is ox + root.x
    ay is oy + root.y
    if root.id == target.id:
        return ay
    if _is_container of root.type:
        for i in range of (len of root.children):
            result is _find_abs_y of [root.children[i], target, ax, ay]
            if result != -1:
                return result
    if root.type == "tabs":
        for i in range of (len of root.tab_panels):
            if root.tab_panels[i] != null:
                result is _find_abs_y of [root.tab_panels[i], target, ax, ay + 28]
                if result != -1:
                    return result
    if root.type == "splitter":
        if root.panel_a != null:
            result is _find_abs_y of [root.panel_a, target, ax, ay]
            if result != -1:
                return result
        if root.panel_b != null:
            sp is floor of root.split_pos
            result is _find_abs_y of [root.panel_b, target, ax + sp + root.bar_width, ay]
            if result != -1:
                return result
    return -1

define _update_knob_drag(widget, my) as:
    # Vertical drag: up = increase, down = decrease
    # 200px of drag covers the full range
    range_val is widget.max_val - widget.min_val
    if range_val <= 0:
        return null
    delta is (widget.drag_start_y - my) / 200.0
    new_val is widget.drag_start_val + delta * range_val
    if new_val < widget.min_val:
        new_val is widget.min_val
    if new_val > widget.max_val:
        new_val is widget.max_val
    widget.value is new_val
    if widget.on_change != null:
        widget.on_change of widget

define _update_tab_hover(widget, rel_x) as:
    tab_x is 0
    for i in range of (len of widget.tab_names):
        tw is (text_width of [widget.tab_names[i], _theme.font_scale]) + 24
        if rel_x >= tab_x and rel_x < tab_x + tw:
            widget.hover_tab is i
            return null
        tab_x is tab_x + tw
    widget.hover_tab is -1

define _tab_index_at(widget, rel_x) as:
    tab_x is 0
    for i in range of (len of widget.tab_names):
        tw is (text_width of [widget.tab_names[i], _theme.font_scale]) + 24
        if rel_x >= tab_x and rel_x < tab_x + tw:
            return i
        tab_x is tab_x + tw
    return -1

_drag_oy is 0
_focused_input is null

define _update_vdrag(widget, my) as:
    range_val is widget.max_val - widget.min_val
    if range_val <= 0:
        return null
    # Inverted: top = max, bottom = min
    frac is 1.0 - (my - _drag_oy) / widget.h
    if frac < 0:
        frac is 0
    if frac > 1:
        frac is 1
    widget.value is widget.min_val + frac * range_val
    if widget.on_change != null:
        widget.on_change of widget

define _unfocus_all(widget) as:
    if widget.type == "text_input":
        widget.focused is 0
    elif _is_container of widget.type:
        for i in range of (len of widget.children):
            _unfocus_all of widget.children[i]
    elif widget.type == "tabs":
        for i in range of (len of widget.tab_panels):
            if widget.tab_panels[i] != null:
                _unfocus_all of widget.tab_panels[i]
    elif widget.type == "splitter":
        if widget.panel_a != null:
            _unfocus_all of widget.panel_a
        if widget.panel_b != null:
            _unfocus_all of widget.panel_b

define _close_menus(widget) as:
    if widget.type == "menu":
        widget.visible is 0
    elif _is_container of widget.type:
        for i in range of (len of widget.children):
            _close_menus of widget.children[i]
    elif widget.type == "tabs":
        for i in range of (len of widget.tab_panels):
            if widget.tab_panels[i] != null:
                _close_menus of widget.tab_panels[i]
    elif widget.type == "splitter":
        if widget.panel_a != null:
            _close_menus of widget.panel_a
        if widget.panel_b != null:
            _close_menus of widget.panel_b

define _scroll_panels(widget, dx, dy) as:
    if widget.type == "item_list":
        widget.scroll_y is widget.scroll_y + dy
        if widget.scroll_y < 0:
            widget.scroll_y is 0
        max_sy is (len of widget.items) * widget.item_h - widget.h
        if max_sy < 0:
            max_sy is 0
        if widget.scroll_y > max_sy:
            widget.scroll_y is max_sy
    elif widget.type == "tree":
        widget.scroll_y is widget.scroll_y + dy
        if widget.scroll_y < 0:
            widget.scroll_y is 0
        # Flatten to count items
        flat is []
        _flatten_tree of [widget.nodes, 0, flat]
        max_sy is (len of flat) * widget.item_h - widget.h
        if max_sy < 0:
            max_sy is 0
        if widget.scroll_y > max_sy:
            widget.scroll_y is max_sy
    elif widget.type == "scroll_panel":
        # Vertical scroll
        widget.scroll_y is widget.scroll_y + dy
        if widget.scroll_y < 0:
            widget.scroll_y is 0
        max_sy is widget.content_h - widget.h
        if max_sy < 0:
            max_sy is 0
        if widget.scroll_y > max_sy:
            widget.scroll_y is max_sy
        # Horizontal scroll
        widget.scroll_x is widget.scroll_x + dx
        if widget.scroll_x < 0:
            widget.scroll_x is 0
        max_sx is widget.content_w - widget.w
        if max_sx < 0:
            max_sx is 0
        if widget.scroll_x > max_sx:
            widget.scroll_x is max_sx
    elif widget.type == "table":
        body_h is widget.h - widget.header_h
        total_h is (len of widget.rows) * widget.row_h
        widget.scroll_y is widget.scroll_y + dy
        if widget.scroll_y < 0:
            widget.scroll_y is 0
        max_sy is total_h - body_h
        if max_sy < 0:
            max_sy is 0
        if widget.scroll_y > max_sy:
            widget.scroll_y is max_sy
    elif _is_container of widget.type:
        for i in range of (len of widget.children):
            _scroll_panels of [widget.children[i], dx, dy]
    elif widget.type == "tabs":
        if widget.active < (len of widget.tab_panels):
            if widget.tab_panels[widget.active] != null:
                _scroll_panels of [widget.tab_panels[widget.active], dx, dy]
    elif widget.type == "splitter":
        if widget.panel_a != null:
            _scroll_panels of [widget.panel_a, dx, dy]
        if widget.panel_b != null:
            _scroll_panels of [widget.panel_b, dx, dy]

define _handle_text_key(widget, ev) as:
    k is ev.key
    shift is 0
    if ev.shift != null:
        shift is ev.shift
    ctrl is 0
    if ev.ctrl != null:
        ctrl is ev.ctrl
    # Ctrl+key shortcuts
    if ctrl == 1:
        if k == "a":
            widget.sel_start is 0
            widget.sel_end is len of widget.text
            widget.cursor is len of widget.text
            return null
        if k == "c":
            _clipboard is _get_selected_text of widget
            return null
        if k == "x":
            _clipboard is _get_selected_text of widget
            if (len of _clipboard) > 0:
                _delete_selection of widget
                if widget.on_change != null:
                    widget.on_change of widget
            return null
        if k == "v":
            if (len of _clipboard) > 0:
                if widget.sel_start != null and widget.sel_start >= 0 and widget.sel_end != null and widget.sel_end >= 0:
                    _delete_selection of widget
                before is substr of [widget.text, 0, widget.cursor]
                after is substr of [widget.text, widget.cursor, (len of widget.text) - widget.cursor]
                widget.text is before + _clipboard + after
                widget.cursor is widget.cursor + (len of _clipboard)
                if widget.on_change != null:
                    widget.on_change of widget
            return null
    # Shift+arrow extends selection
    if shift == 1 and (k == "left" or k == "right" or k == "home" or k == "end"):
        if widget.sel_start == null or widget.sel_start < 0:
            widget.sel_start is widget.cursor
            widget.sel_end is widget.cursor
        if k == "left" and widget.cursor > 0:
            widget.cursor is widget.cursor - 1
        elif k == "right" and widget.cursor < (len of widget.text):
            widget.cursor is widget.cursor + 1
        elif k == "home":
            widget.cursor is 0
        elif k == "end":
            widget.cursor is len of widget.text
        widget.sel_end is widget.cursor
        return null
    if k == "backspace":
        if widget.sel_start != null and widget.sel_start >= 0 and widget.sel_end != null and widget.sel_end >= 0:
            _delete_selection of widget
            if widget.on_change != null:
                widget.on_change of widget
        elif widget.cursor > 0:
            before is substr of [widget.text, 0, widget.cursor - 1]
            after is substr of [widget.text, widget.cursor, (len of widget.text) - widget.cursor]
            widget.text is before + after
            widget.cursor is widget.cursor - 1
            if widget.on_change != null:
                widget.on_change of widget
    elif k == "delete":
        if widget.sel_start != null and widget.sel_start >= 0 and widget.sel_end != null and widget.sel_end >= 0:
            _delete_selection of widget
            if widget.on_change != null:
                widget.on_change of widget
        elif widget.cursor < (len of widget.text):
            before is substr of [widget.text, 0, widget.cursor]
            after is substr of [widget.text, widget.cursor + 1, (len of widget.text) - widget.cursor - 1]
            widget.text is before + after
            if widget.on_change != null:
                widget.on_change of widget
    elif k == "left":
        _clear_selection of widget
        if widget.cursor > 0:
            widget.cursor is widget.cursor - 1
    elif k == "right":
        _clear_selection of widget
        if widget.cursor < (len of widget.text):
            widget.cursor is widget.cursor + 1
    elif k == "home":
        _clear_selection of widget
        widget.cursor is 0
    elif k == "end":
        _clear_selection of widget
        widget.cursor is len of widget.text
    elif k == "return":
        if widget.type == "editable_label":
            _commit_editing of widget
        else:
            _focused_input is null
            widget.focused is 0
    elif k == "escape":
        if widget.type == "editable_label":
            widget.editing is 0
            _focused_input is null
        else:
            _focused_input is null
            widget.focused is 0
    elif k == "space":
        _insert_char of [widget, " "]
    elif (len of k) == 1:
        ch is k
        if shift == 1:
            ch is str_upper of k
            # Shift+number -> symbol
            if k == "1":
                ch is "!"
            elif k == "2":
                ch is "@"
            elif k == "3":
                ch is "#"
            elif k == "4":
                ch is "$"
            elif k == "5":
                ch is "%"
            elif k == "6":
                ch is "^"
            elif k == "7":
                ch is "&"
            elif k == "8":
                ch is "*"
            elif k == "9":
                ch is "("
            elif k == "0":
                ch is ")"
            elif k == "-":
                ch is "_"
            elif k == "=":
                ch is "+"
            elif k == ";":
                ch is ":"
            elif k == "'":
                ch is "\""
            elif k == ",":
                ch is "<"
            elif k == ".":
                ch is ">"
            elif k == "/":
                ch is "?"
        _insert_char of [widget, ch]

define _insert_char(widget, ch) as:
    # Delete selection first if any
    if widget.sel_start != null and widget.sel_start >= 0 and widget.sel_end != null and widget.sel_end >= 0:
        _delete_selection of widget
    before is substr of [widget.text, 0, widget.cursor]
    after is substr of [widget.text, widget.cursor, (len of widget.text) - widget.cursor]
    widget.text is before + ch + after
    widget.cursor is widget.cursor + 1
    if widget.on_change != null:
        widget.on_change of widget

# ============================================================
# Clipboard + text selection helpers
# ============================================================

define _get_selected_text(widget) as:
    if widget.sel_start == null or widget.sel_end == null:
        return ""
    if widget.sel_start < 0 or widget.sel_end < 0:
        return ""
    s is widget.sel_start
    e is widget.sel_end
    if s > e:
        tmp is s
        s is e
        e is tmp
    return substr of [widget.text, s, e - s]

define _delete_selection(widget) as:
    if widget.sel_start == null or widget.sel_end == null:
        return null
    if widget.sel_start < 0 or widget.sel_end < 0:
        return null
    s is widget.sel_start
    e is widget.sel_end
    if s > e:
        tmp is s
        s is e
        e is tmp
    before is substr of [widget.text, 0, s]
    after is substr of [widget.text, e, (len of widget.text) - e]
    widget.text is before + after
    widget.cursor is s
    widget.sel_start is -1
    widget.sel_end is -1

define _clear_selection(widget) as:
    if widget.sel_start != null:
        widget.sel_start is -1
    if widget.sel_end != null:
        widget.sel_end is -1

# ============================================================
# Hotkey system
# ============================================================

define register_hotkey(combo, callback) as:
    append of [_hotkeys, {"combo": combo, "callback": callback}]

define unregister_hotkey(combo) as:
    new_list is []
    for i in range of (len of _hotkeys):
        if _hotkeys[i].combo != combo:
            append of [new_list, _hotkeys[i]]
    _hotkeys is new_list

define _combo_matches(combo, ctrl, shift, alt, key) as:
    # Parse combo string like "ctrl+s", "ctrl+shift+z", "alt+f"
    need_ctrl is 0
    need_shift is 0
    need_alt is 0
    target_key is combo
    if (contains of [combo, "ctrl+"]) == 1:
        need_ctrl is 1
        target_key is str_replace of [target_key, "ctrl+", ""]
    if (contains of [combo, "shift+"]) == 1:
        need_shift is 1
        target_key is str_replace of [target_key, "shift+", ""]
    if (contains of [combo, "alt+"]) == 1:
        need_alt is 1
        target_key is str_replace of [target_key, "alt+", ""]
    if ctrl != need_ctrl:
        return 0
    if shift != need_shift:
        return 0
    if alt != need_alt:
        return 0
    if key == target_key:
        return 1
    return 0

define _match_hotkey(ev) as:
    ctrl is 0
    shift is 0
    alt is 0
    if ev.ctrl != null:
        ctrl is ev.ctrl
    if ev.shift != null:
        shift is ev.shift
    if ev.alt != null:
        alt is ev.alt
    for i in range of (len of _hotkeys):
        hk is _hotkeys[i]
        if (_combo_matches of [hk.combo, ctrl, shift, alt, ev.key]) == 1:
            hk.callback of null
            return 1
    return 0

# ============================================================
# Modal stack
# ============================================================

define push_modal(dlg, parent_w, parent_h) as:
    dlg.x is floor of ((parent_w - dlg.w) / 2)
    dlg.y is floor of ((parent_h - dlg.h) / 2)
    dlg.visible is 1
    dlg.hover_btn is -1
    append of [_modal_stack, dlg]

define pop_modal() as:
    n is len of _modal_stack
    if n == 0:
        return null
    top is _modal_stack[n - 1]
    top.visible is 0
    new_stack is []
    for i in range of (n - 1):
        append of [new_stack, _modal_stack[i]]
    _modal_stack is new_stack
    return top

# ============================================================
# Tree view helpers
# ============================================================

define _flatten_tree(nodes, depth, out) as:
    for i in range of (len of nodes):
        nd is nodes[i]
        expanded is 0
        if nd.expanded != null:
            expanded is nd.expanded
        has_children is 0
        if nd.children != null and (len of nd.children) > 0:
            has_children is 1
        append of [out, {"node": nd, "depth": depth, "has_children": has_children, "expanded": expanded}]
        if expanded == 1 and has_children == 1:
            _flatten_tree of [nd.children, depth + 1, out]

# ============================================================
# HSV to RGB conversion
# ============================================================

define _hsv_to_rgb(h, s, v) as:
    c is v * s
    hp is h / 60
    x is c * (1 - abs of (hp - 2 * floor of (hp / 2) - 1))
    m is v - c
    if hp < 1:
        r is c
        g is x
        b is 0
    elif hp < 2:
        r is x
        g is c
        b is 0
    elif hp < 3:
        r is 0
        g is c
        b is x
    elif hp < 4:
        r is 0
        g is x
        b is c
    elif hp < 5:
        r is x
        g is 0
        b is c
    else:
        r is c
        g is 0
        b is x
    return [floor of ((r + m) * 255), floor of ((g + m) * 255), floor of ((b + m) * 255)]

# ============================================================
# DnD render overlay
# ============================================================

define _render_dnd() as:
    if _dnd_state.active == 0:
        return null
    tx is _dnd_state.mx + 10
    ty is _dnd_state.my - 10
    tw is (text_width of [_dnd_state.text, _theme.font_scale]) + 12
    gfx_rrect of [tx, ty, tw, 22, _theme.radius_sm, _theme.accent[0], _theme.accent[1], _theme.accent[2], 180]
    gfx_text of [tx + 6, ty + 4, _dnd_state.text, 255, 255, 255, _theme.font_scale]

# ============================================================
# Combobox key handler
# ============================================================

define _handle_combobox_key(widget, ev) as:
    k is ev.key
    if k == "escape":
        widget.open is 0
        return null
    if k == "return":
        if widget.hover_index >= 0 and widget.hover_index < (len of widget.filtered):
            widget.filter_text is widget.filtered[widget.hover_index]
            widget.selected is widget.hover_index
            widget.open is 0
            if widget.on_change != null:
                widget.on_change of widget
        return null
    if k == "up":
        widget.hover_index is widget.hover_index - 1
        if widget.hover_index < 0:
            widget.hover_index is 0
        return null
    if k == "down":
        widget.hover_index is widget.hover_index + 1
        if widget.hover_index >= (len of widget.filtered):
            widget.hover_index is (len of widget.filtered) - 1
        return null
    if k == "backspace":
        if (len of widget.filter_text) > 0:
            widget.filter_text is substr of [widget.filter_text, 0, (len of widget.filter_text) - 1]
            widget.cursor is len of widget.filter_text
    elif k == "space":
        widget.filter_text is widget.filter_text + " "
        widget.cursor is len of widget.filter_text
    elif (len of k) == 1:
        shift is 0
        if ev.shift != null:
            shift is ev.shift
        ch is k
        if shift == 1:
            ch is str_upper of k
        widget.filter_text is widget.filter_text + ch
        widget.cursor is len of widget.filter_text
    # Re-filter
    widget.filtered is []
    for i in range of (len of widget.items):
        if (len of widget.filter_text) == 0 or (contains of [str_lower of widget.items[i], str_lower of widget.filter_text]) == 1:
            append of [widget.filtered, widget.items[i]]
    widget.hover_index is 0

define show_menu(menu_widget, x, y) as:
    menu_widget.x is x
    menu_widget.y is y
    menu_widget.visible is 1
    menu_widget.hover_index is -1

define _find_visible_dialog(widget) as:
    if widget.type == "dialog" and widget.visible == 1:
        return widget
    if _is_container of widget.type:
        for i in range of (len of widget.children):
            found is _find_visible_dialog of widget.children[i]
            if found != null:
                return found
    if widget.type == "tabs":
        for i in range of (len of widget.tab_panels):
            if widget.tab_panels[i] != null:
                found is _find_visible_dialog of widget.tab_panels[i]
                if found != null:
                    return found
    if widget.type == "splitter":
        if widget.panel_a != null:
            found is _find_visible_dialog of widget.panel_a
            if found != null:
                return found
        if widget.panel_b != null:
            found is _find_visible_dialog of widget.panel_b
            if found != null:
                return found
    return null

define _handle_dialog_click(dlg, mx, my) as:
    btn_y is dlg.y + dlg.h - 40
    btn_x is dlg.x + dlg.w
    i is (len of dlg.buttons) - 1
    loop while i >= 0:
        btext is dlg.buttons[i]
        bw is (text_width of [btext, _theme.font_scale]) + 24
        btn_x is btn_x - bw - 8
        if _point_in_rect of [mx, my, btn_x, btn_y, bw, 28]:
            dlg.visible is 0
            if dlg.on_button != null:
                dlg.on_button of [dlg, i]
            return null
        i is i - 1

define show_dialog(dlg, parent_w, parent_h) as:
    push_modal of [dlg, parent_w, parent_h]

define _start_editing(widget) as:
    _unfocus_all_editable of _edit_root
    widget.editing is 1
    widget.cursor is len of widget.text
    _focused_input is widget

define _commit_editing(widget) as:
    widget.editing is 0
    widget.w is (text_width of [widget.text, widget.scale]) + 8
    _focused_input is null
    if widget.on_commit != null:
        widget.on_commit of widget

define _unfocus_all_editable(widget) as:
    if widget == null:
        return null
    if widget.type == "editable_label" and widget.editing == 1:
        _commit_editing of widget
    if _is_container of widget.type:
        for i in range of (len of widget.children):
            _unfocus_all_editable of widget.children[i]
    if widget.type == "tabs":
        for i in range of (len of widget.tab_panels):
            if widget.tab_panels[i] != null:
                _unfocus_all_editable of widget.tab_panels[i]
    if widget.type == "splitter":
        if widget.panel_a != null:
            _unfocus_all_editable of widget.panel_a
        if widget.panel_b != null:
            _unfocus_all_editable of widget.panel_b

define _piano_note_at(widget, rel_x, rel_y) as:
    kw is widget.key_w
    bh is widget.black_h
    # Check black keys first (they overlap white keys)
    if rel_y < bh:
        for o in range of widget.octaves:
            ox is o * 7 * kw
            # Black key positions relative to octave start
            # C#: after C, D#: after D, F#: after F, G#: after G, A#: after A
            blacks is [0, 1, 3, 4, 5]
            notes is [1, 3, 6, 8, 10]
            for bi in range of 5:
                bx is ox + blacks[bi] * kw + kw - 5
                if rel_x >= bx and rel_x < bx + 10:
                    return o * 12 + notes[bi]
    # White key
    white_idx is floor of (rel_x / kw)
    oct is floor of (white_idx / 7)
    key_in_oct is white_idx - oct * 7
    # White key -> semitone: 0,2,4,5,7,9,11
    white_to_semi is [0, 2, 4, 5, 7, 9, 11]
    if key_in_oct >= 0 and key_in_oct < 7:
        return oct * 12 + white_to_semi[key_in_oct]
    # Final C
    if oct == widget.octaves:
        return widget.octaves * 12
    return -1

define _radio_index_at(widget, rel_x) as:
    rx is 0
    for i in range of (len of widget.items):
        rw is (text_width of [widget.items[i], _theme.font_scale]) + 16
        if rel_x >= rx and rel_x < rx + rw:
            return i
        rx is rx + rw
    return -1

define _close_dropdowns(widget) as:
    if widget.type == "dropdown":
        widget.open is 0
    elif widget.type == "combobox":
        widget.open is 0
    elif _is_container of widget.type:
        for i in range of (len of widget.children):
            _close_dropdowns of widget.children[i]
    elif widget.type == "tabs":
        for i in range of (len of widget.tab_panels):
            if widget.tab_panels[i] != null:
                _close_dropdowns of widget.tab_panels[i]
    elif widget.type == "splitter":
        if widget.panel_a != null:
            _close_dropdowns of widget.panel_a
        if widget.panel_b != null:
            _close_dropdowns of widget.panel_b

define _update_drag(widget, mx) as:
    range_val is widget.max_val - widget.min_val
    if range_val <= 0:
        return null
    frac is (mx - _drag_ox) / widget.w
    if frac < 0:
        frac is 0
    if frac > 1:
        frac is 1
    widget.value is widget.min_val + frac * range_val
    if widget.on_change != null:
        widget.on_change of widget

define _update_scrollbar_drag(widget, mx, my) as:
    if widget.vertical == 1:
        ts is widget.thumb_size
        if ts < 0.05:
            ts is 0.05
        thumb_h is floor of (ts * widget.h)
        if thumb_h < 16:
            thumb_h is 16
        track is widget.h - thumb_h
        if track <= 0:
            return null
        frac is (my - _drag_oy - thumb_h / 2) / track
    else:
        ts is widget.thumb_size
        if ts < 0.05:
            ts is 0.05
        thumb_w is floor of (ts * widget.w)
        if thumb_w < 16:
            thumb_w is 16
        track is widget.w - thumb_w
        if track <= 0:
            return null
        frac is (mx - _drag_ox - thumb_w / 2) / track
    if frac < 0:
        frac is 0
    if frac > 1:
        frac is 1
    widget.value is frac
    if widget.on_change != null:
        widget.on_change of widget

# ============================================================
# Focus system
# ============================================================

_focusable_types is ["button", "slider", "vslider", "toggle", "knob", "checkbox", "text_input", "toggle_button", "spinbox", "radio_group", "dropdown", "item_list", "scrollbar", "table", "tree", "combobox"]

define _is_focusable(widget) as:
    for i in range of (len of _focusable_types):
        if widget.type == _focusable_types[i]:
            if widget.enabled != null and widget.enabled == 0:
                return 0
            if widget.visible == 0:
                return 0
            return 1
    return 0

define _build_focus_list(widget) as:
    if widget.visible == 0:
        return null
    if (_is_focusable of widget) == 1:
        append of [_focus_list, widget]
    if _is_container of widget.type:
        for i in range of (len of widget.children):
            _build_focus_list of widget.children[i]
    if widget.type == "tabs":
        if widget.active < (len of widget.tab_panels):
            if widget.tab_panels[widget.active] != null:
                _build_focus_list of widget.tab_panels[widget.active]
    if widget.type == "splitter":
        if widget.panel_a != null:
            _build_focus_list of widget.panel_a
        if widget.panel_b != null:
            _build_focus_list of widget.panel_b

define _sync_focus_to(widget) as:
    if (_is_focusable of widget) == 1:
        _focused_widget is widget
        # Try to find index in current focus list
        for i in range of (len of _focus_list):
            if _focus_list[i].id == widget.id:
                _focus_index is i
                return null
        _focus_index is -1

define _focus_next(root, reverse) as:
    _focus_list is []
    _build_focus_list of root
    n is len of _focus_list
    if n == 0:
        _focused_widget is null
        _focus_index is -1
        return null
    if reverse == 1:
        _focus_index is _focus_index - 1
        if _focus_index < 0:
            _focus_index is n - 1
    else:
        _focus_index is _focus_index + 1
        if _focus_index >= n:
            _focus_index is 0
    _focused_widget is _focus_list[_focus_index]
    # If it's a text input, focus it
    _unfocus_all of root
    _focused_input is null
    if _focused_widget.type == "text_input":
        _focused_widget.focused is 1
        _focused_input is _focused_widget

define _handle_focus_key(root, ev) as:
    if ev.key == "tab":
        if ev.shift == 1:
            _focus_next of [root, 1]
        else:
            _focus_next of [root, 0]
        return 1
    # Activation keys
    if _focused_widget == null:
        return 0
    w is _focused_widget
    if ev.key == "return" or ev.key == "space":
        if w.type == "button" and w.enabled == 1:
            if w.on_click != null:
                w.on_click of w
            return 1
        if w.type == "toggle" or w.type == "checkbox":
            if w.value == 1:
                w.value is 0
            else:
                w.value is 1
            if w.on_change != null:
                w.on_change of w
            return 1
        if w.type == "toggle_button":
            if w.value == 1:
                w.value is 0
            else:
                w.value is 1
            if w.on_click != null:
                w.on_click of w
            return 1
    # Arrow keys for sliders/knobs
    if ev.key == "left" or ev.key == "right" or ev.key == "up" or ev.key == "down":
        if w.type == "slider" or w.type == "vslider" or w.type == "knob":
            step is (w.max_val - w.min_val) / 50
            if ev.key == "right" or ev.key == "up":
                w.value is w.value + step
            else:
                w.value is w.value - step
            if w.value < w.min_val:
                w.value is w.min_val
            if w.value > w.max_val:
                w.value is w.max_val
            if w.on_change != null:
                w.on_change of w
            return 1
        if w.type == "radio_group":
            if ev.key == "left" or ev.key == "up":
                w.selected is w.selected - 1
                if w.selected < 0:
                    w.selected is (len of w.items) - 1
            else:
                w.selected is w.selected + 1
                if w.selected >= (len of w.items):
                    w.selected is 0
            if w.on_change != null:
                w.on_change of w
            return 1
        if w.type == "item_list":
            if ev.key == "up":
                w.selected is w.selected - 1
                if w.selected < 0:
                    w.selected is 0
            elif ev.key == "down":
                w.selected is w.selected + 1
                if w.selected >= (len of w.items):
                    w.selected is (len of w.items) - 1
            if w.on_select != null:
                w.on_select of w
            return 1
    # Tree navigation with arrow keys
    if ev.key == "up" or ev.key == "down" or ev.key == "left" or ev.key == "right":
        if w != null and w.type == "tree":
            flat is []
            _flatten_tree of [w.nodes, 0, flat]
            # Find currently selected flat index
            cur_fi is -1
            for fi in range of (len of flat):
                if flat[fi].node.id == w.selected_id:
                    cur_fi is fi
            if ev.key == "up" and cur_fi > 0:
                w.selected_id is flat[cur_fi - 1].node.id
                if w.on_select != null:
                    w.on_select of [w, flat[cur_fi - 1].node]
            elif ev.key == "down" and cur_fi < (len of flat) - 1:
                w.selected_id is flat[cur_fi + 1].node.id
                if w.on_select != null:
                    w.on_select of [w, flat[cur_fi + 1].node]
            elif ev.key == "left" and cur_fi >= 0:
                if flat[cur_fi].expanded == 1:
                    flat[cur_fi].node.expanded is 0
            elif ev.key == "right" and cur_fi >= 0:
                if flat[cur_fi].has_children == 1:
                    flat[cur_fi].node.expanded is 1
            return 1
    # Escape closes dropdowns/menus
    if ev.key == "escape":
        _close_dropdowns of root
        _close_menus of root
        if (len of _modal_stack) > 0:
            pop_modal of null
        return 1
    return 0

# ============================================================
# App loop
# ============================================================

define app_loop(root, on_key, on_tick) as:
    _edit_root is root
    _window_w is root.w
    _window_h is root.h
    _running is 1
    # Build initial focus list
    _focus_list is []
    _build_focus_list of root
    loop while _running == 1:
        ev is gfx_poll of null
        loop while ev != null:
            if ev.type == "quit":
                _running is 0
            elif ev.type == "resize":
                _window_w is ev.w
                _window_h is ev.h
                root.w is ev.w
                root.h is ev.h
            elif ev.type == "keydown":
                # Hotkeys get highest priority
                hotkey_handled is _match_hotkey of ev
                if hotkey_handled == 0:
                    # Escape pops modal stack
                    if ev.key == "escape" and (len of _modal_stack) > 0:
                        pop_modal of null
                    # Combobox key handling when open
                    elif _focused_widget != null and _focused_widget.type == "combobox" and _focused_widget.open == 1:
                        _handle_combobox_key of [_focused_widget, ev]
                    # Text input gets next crack at keys
                    elif _focused_input != null:
                        _handle_text_key of [_focused_input, ev]
                    # Focus navigation (Tab, Enter, Space, arrows, Escape)
                    elif ev.key == "tab" or ev.key == "escape":
                        _handle_focus_key of [root, ev]
                    elif (_focused_widget != null and _focused_input == null):
                        _handle_focus_key of [root, ev]
                if on_key != null:
                    result is on_key of ev
                    if result == 0:
                        _running is 0
            elif ev.type == "keyup":
                if on_key != null:
                    result is on_key of ev
                    if result == 0:
                        _running is 0
            else:
                dispatch of [root, ev]
            ev is gfx_poll of null
        # Update timers
        _frame_time is _frame_time + 1
        _cursor_blink is _cursor_blink + 1
        if _cursor_blink > 60:
            _cursor_blink is 0
        if _tooltip_widget != null:
            _tooltip_timer is _tooltip_timer + 1
        if on_tick != null:
            on_tick of root
        # Layout pass
        _layout of root
        # Animation pass
        _update_tweens of null
        # Render
        gfx_clear of [_theme.bg[0], _theme.bg[1], _theme.bg[2]]
        render of [root, 0, 0]
        # Render modal stack (dim overlay + dialog for each)
        for mi in range of (len of _modal_stack):
            mdlg is _modal_stack[mi]
            if mdlg.visible == 1:
                render of [mdlg, 0, 0]
        _render_tooltip of null
        _render_dnd of null
        gfx_present of null
        gfx_delay of 1
    return null
