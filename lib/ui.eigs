define vbox(id, x, y, w, h) as:
    return {
        "type": "vbox",
        "id": id,
        "x": x, "y": y, "w": w, "h": h,
        "bg": null,
        "border": null,
        "children": [],
        "gap": 0,
        "padding": 0,
