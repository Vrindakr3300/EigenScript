# ---- Standalone scrollbar ----

define scrollbar(id, x, y, length, vertical, on_change) as:
    if vertical == 1:
        sw is 12
        sh is length
    else:
        sw is length
        sh is 12
    return {
        "type": "scrollbar",
        "id": id,
        "x": x, "y": y, "w": sw, "h": sh,
        "vertical": vertical,
        "value": 0,
        "thumb_size": 0.2,
        "on_change": on_change,
        "dragging": 0,
        "hover": 0,
        "visible": 1,
        "enabled": 1
    }

