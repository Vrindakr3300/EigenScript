# ============================================================
# UI Toolkit — widget constructors, rendering, and event dispatch
# ============================================================
#
# Usage:
#   import ui
#
#   root is ui.panel of ["root", 0, 0, 800, 600]
#   ui.add_child of [root, ui.button of ["play", 8, 8, 60, 24, "Play", on_click]]
#   ui.app_loop of [root, on_key, null]
#
# Widget types: panel, button, label, slider, toggle, hbox, vbox,
#   toolbar, statusbar, scrollbar, table, and many more.
# All widgets are plain dicts with a "type" field.
# Panels have a "children" list and act as containers.
# Positions are relative to parent panel origin.

load_file of "lib/ui_theme.eigs"
load_file of "lib/ui_draw.eigs"
load_file of "lib/ui_layout.eigs"
load_file of "lib/ui_anim.eigs"

# ============================================================
# Module state — drag capture, focus, animation
# ============================================================

_drag_widget is null
_tooltip_widget is null
_tooltip_timer is 0
_tooltip_x is 0
_tooltip_y is 0
_last_click_time is 0
_last_click_id is ""
_cursor_blink is 0
_frame_time is 0
_edit_root is null
_focus_list is []
_focus_index is -1
_focused_widget is null
_window_w is 800
_window_h is 600
_hotkeys is []
_clipboard is ""
_modal_stack is []
_dnd_state is {"active": 0, "source": null, "source_index": -1, "data": null, "mx": 0, "my": 0, "text": ""}

# ============================================================
# Widget constructors
# ============================================================

define label(id, x, y, text) as:
    return {
        "type": "label",
        "id": id,
        "x": x, "y": y,
        "text": text,
        "color": _theme.text_color,
        "scale": _theme.font_scale,
        "visible": 1
    }

define panel(id, x, y, w, h) as:
    return {
        "type": "panel",
        "id": id,
        "x": x, "y": y, "w": w, "h": h,
        "bg": _theme.panel_bg,
        "border": _theme.panel_border,
        "children": [],
        "visible": 1
    }

define button(id, x, y, w, h, text, on_click) as:
    return {
        "type": "button",
        "id": id,
        "x": x, "y": y, "w": w, "h": h,
        "label": text,
        "on_click": on_click,
        "hover": 0,
        "pressed": 0,
        "visible": 1,
        "enabled": 1
    }

define slider(id, x, y, w, min_val, max_val, value, on_change) as:
    return {
        "type": "slider",
        "id": id,
        "x": x, "y": y, "w": w, "h": 16,
        "min_val": min_val, "max_val": max_val, "value": value,
        "on_change": on_change,
        "dragging": 0,
        "hover": 0,
        "visible": 1,
        "enabled": 1
    }

define toggle(id, x, y, value, on_change) as:
    return {
        "type": "toggle",
        "id": id,
        "x": x, "y": y, "w": 32, "h": 16,
        "value": value,
        "on_change": on_change,
        "hover": 0,
        "visible": 1,
        "enabled": 1
    }

define knob(id, x, y, size, min_val, max_val, value, on_change) as:
    return {
        "type": "knob",
        "id": id,
        "x": x, "y": y, "w": size, "h": size,
        "min_val": min_val, "max_val": max_val, "value": value,
        "on_change": on_change,
        "dragging": 0,
        "drag_start_y": 0,
        "drag_start_val": 0,
        "hover": 0,
        "visible": 1,
        "enabled": 1
    }

define dropdown(id, x, y, w, items, selected, on_change) as:
    return {
        "type": "dropdown",
        "id": id,
        "x": x, "y": y, "w": w, "h": 24,
        "items": items,
        "selected": selected,
        "on_change": on_change,
        "open": 0,
        "hover": 0,
        "hover_index": -1,
        "visible": 1,
        "enabled": 1
    }

define tabs(id, x, y, w, h, tab_names, on_tab) as:
    return {
        "type": "tabs",
        "id": id,
        "x": x, "y": y, "w": w, "h": h,
        "tab_names": tab_names,
        "active": 0,
        "on_tab": on_tab,
        "tab_panels": [],
        "hover_tab": -1,
        "visible": 1
    }

define canvas(id, x, y, w, h, on_paint, on_mouse) as:
    return {
        "type": "canvas",
        "id": id,
        "x": x, "y": y, "w": w, "h": h,
        "on_paint": on_paint,
        "on_mouse": on_mouse,
        "hover": 0,
        "visible": 1
    }

define scroll_panel(id, x, y, w, h) as:
    return {
        "type": "scroll_panel",
        "id": id,
        "x": x, "y": y, "w": w, "h": h,
        "bg": _theme.panel_bg,
        "border": _theme.panel_border,
        "children": [],
        "scroll_x": 0,
        "scroll_y": 0,
        "content_w": 0,
        "content_h": 0,
        "visible": 1
    }

define vslider(id, x, y, h, min_val, max_val, value, on_change) as:
    return {
        "type": "vslider",
        "id": id,
        "x": x, "y": y, "w": 16, "h": h,
        "min_val": min_val, "max_val": max_val, "value": value,
        "on_change": on_change,
        "dragging": 0,
        "hover": 0,
        "visible": 1,
        "enabled": 1
    }

define checkbox(id, x, y, text, value, on_change) as:
    tw is (text_width of [text, _theme.font_scale]) + 22
    return {
        "type": "checkbox",
        "id": id,
        "x": x, "y": y, "w": tw, "h": 16,
        "label": text,
        "value": value,
        "on_change": on_change,
        "hover": 0,
        "visible": 1,
        "enabled": 1
    }

define text_input(id, x, y, w, text, on_change) as:
    return {
        "type": "text_input",
        "id": id,
        "x": x, "y": y, "w": w, "h": 24,
        "text": text,
        "cursor": len of text,
        "sel_start": -1,
        "sel_end": -1,
        "on_change": on_change,
        "focused": 0,
        "hover": 0,
        "visible": 1,
        "enabled": 1
    }

define menu(id, items, on_select) as:
    return {
        "type": "menu",
        "id": id,
        "x": 0, "y": 0, "w": 140, "h": 0,
        "items": items,
        "on_select": on_select,
        "hover_index": -1,
        "visible": 0
    }

define meter(id, x, y, w, h) as:
    return {
        "type": "meter",
        "id": id,
        "x": x, "y": y, "w": w, "h": h,
        "value": 0,
        "peak": 0,
        "peak_hold": 0,
        "visible": 1
    }

define toggle_button(id, x, y, w, h, text, on_click) as:
    return {
        "type": "toggle_button",
        "id": id,
        "x": x, "y": y, "w": w, "h": h,
        "label": text,
        "value": 0,
        "on_click": on_click,
        "hover": 0,
        "visible": 1,
        "enabled": 1,
        "color_on": _theme.accent,
        "color_off": _theme.btn_bg
    }

define separator(id, x, y, length, vertical) as:
    if vertical == 1:
        sw is 1
        sh is length
    else:
        sw is length
        sh is 1
    return {
        "type": "separator",
        "id": id,
        "x": x, "y": y, "w": sw, "h": sh,
        "color": _theme.panel_border,
        "visible": 1
    }

define spinbox(id, x, y, w, min_val, max_val, value, step, on_change) as:
    return {
        "type": "spinbox",
        "id": id,
        "x": x, "y": y, "w": w, "h": 24,
        "min_val": min_val, "max_val": max_val,
        "value": value, "step": step,
        "on_change": on_change,
        "hover": 0,
        "hover_btn": 0,
        "visible": 1,
        "enabled": 1
    }

define radio_group(id, x, y, items, selected, on_change) as:
    return {
        "type": "radio_group",
        "id": id,
        "x": x, "y": y, "w": 0, "h": 24,
        "items": items,
        "selected": selected,
        "on_change": on_change,
        "hover_index": -1,
        "visible": 1,
        "enabled": 1
    }

define progress_bar(id, x, y, w, value) as:
    return {
        "type": "progress_bar",
        "id": id,
        "x": x, "y": y, "w": w, "h": 12,
        "value": value,
        "visible": 1
    }

define splitter(id, x, y, w, h, split_pos, on_resize) as:
    return {
        "type": "splitter",
        "id": id,
        "x": x, "y": y, "w": w, "h": h,
        "split_pos": split_pos,
        "on_resize": on_resize,
        "panel_a": null,
        "panel_b": null,
        "dragging": 0,
        "hover": 0,
        "visible": 1,
        "bar_width": 4
    }

define dialog(id, w, h, title, message, buttons, on_button) as:
    return {
        "type": "dialog",
        "id": id,
        "x": 0, "y": 0, "w": w, "h": h,
        "title": title,
        "message": message,
        "buttons": buttons,
        "on_button": on_button,
        "hover_btn": -1,
        "visible": 0
    }

define editable_label(id, x, y, text, on_commit) as:
    return {
        "type": "editable_label",
        "id": id,
        "x": x, "y": y,
        "w": (text_width of [text, _theme.font_scale]) + 8,
        "h": _theme.char_h + 4,
        "text": text,
        "editing": 0,
        "cursor": 0,
        "sel_start": -1,
        "sel_end": -1,
        "on_commit": on_commit,
        "on_dblclick": null,
        "color": _theme.text_color,
        "scale": _theme.font_scale,
        "visible": 1
    }

define grid(id, x, y, cols, rows, cell_w, cell_h, on_cell) as:
    # Initialize cells to all zeros
    cells is []
    for r in range of rows:
        row is []
        for c in range of cols:
            append of [row, 0]
        append of [cells, row]
    return {
        "type": "grid",
        "id": id,
        "x": x, "y": y,
        "w": cols * cell_w, "h": rows * cell_h,
        "cols": cols, "rows": rows,
        "cell_w": cell_w, "cell_h": cell_h,
        "cells": cells,
        "on_cell": on_cell,
        "row_labels": null,
        "col_highlight": -1,
        "hover_col": -1, "hover_row": -1,
        "color_on": _theme.accent,
        "color_off": [40, 40, 55],
        "color_beat": [45, 45, 60],
        "color_hover": [55, 55, 75],
        "visible": 1
    }

define item_list(id, x, y, w, h, items, on_select) as:
    return {
        "type": "item_list",
        "id": id,
        "x": x, "y": y, "w": w, "h": h,
        "items": items,
        "selected": -1,
        "scroll_y": 0,
        "on_select": on_select,
        "on_drop": null,
        "on_reorder": null,
        "reorder_insert": -1,
        "draggable": 0,
        "hover_index": -1,
        "item_h": 22,
        "visible": 1
    }

define section(id, x, y, w, text) as:
    return {
        "type": "section",
        "id": id,
        "x": x, "y": y, "w": w, "h": 20,
        "text": text,
        "visible": 1
    }

define color_dot(id, x, y, size, color) as:
    return {
        "type": "color_dot",
        "id": id,
        "x": x, "y": y, "w": size, "h": size,
        "color": color,
        "visible": 1
    }

define piano_keyboard(id, x, y, octaves, on_note) as:
    # 2 octaves = 24 semitones, white keys are wider
    whites_per_oct is 7
    key_w is 18
    key_h is 80
    black_h is 50
    total_w is octaves * whites_per_oct * key_w + key_w
    return {
        "type": "piano_kb",
        "id": id,
        "x": x, "y": y,
        "w": total_w, "h": key_h,
        "octaves": octaves,
        "on_note": on_note,
        "key_w": key_w,
        "key_h": key_h,
        "black_h": black_h,
        "pressed_note": -1,
        "hover_note": -1,
        "base_octave": 4,
        "visible": 1
    }

define waveform_view(id, x, y, w, h) as:
    return {
        "type": "waveform_view",
        "id": id,
        "x": x, "y": y, "w": w, "h": h,
        "samples": [],
        "zoom": 1.0,
        "offset": 0,
        "sel_start": -1,
        "sel_end": -1,
        "playhead": -1,
        "color": [80, 160, 220],
        "visible": 1
    }

