    "text_dim": [180, 180, 180],
    "accent": [255, 255, 0],
    "focus_ring": [255, 255, 0],
    "slider_track": [40, 40, 40],
    "slider_fill": [255, 255, 0],
    "slider_thumb": [255, 255, 255],
    "toggle_off": [40, 40, 40],
    "toggle_on": [255, 255, 0],
    "knob_bg": [30, 30, 30],
    "knob_fg": [255, 255, 0],
    "knob_pointer": [255, 255, 255],
    "dropdown_bg": [20, 20, 20],
    "dropdown_hover": [50, 50, 50],
    "dropdown_item_hover": [60, 60, 60],
    "dropdown_arrow": [255, 255, 255],
    "tab_bg": [10, 10, 10],
    "tab_active": [40, 40, 40],
    "tab_hover": [25, 25, 25],
    "tab_text": [200, 200, 200],
    "tab_text_active": [255, 255, 255],
    "menu_bg": [20, 20, 20],
    "menu_hover": [60, 60, 60],
    "menu_border": [255, 255, 255],
    "tooltip_bg": [40, 40, 0],
    "tooltip_text": [255, 255, 255],
    "disabled_overlay": [0, 0, 0],
    "selection_bg": [255, 255, 0],
    "font_scale": 2,
    "char_w": 12,
    "char_h": 14,
    "padding": 6,
    "border_width": 1,
    "radius": 4,
    "radius_sm": 3,
    "radius_lg": 6
}

# ---- Active theme ----

_theme is _theme_dark

define theme() as:
    return _theme

define set_theme(t) as:
    _theme is t

define theme_dark() as:
    return _theme_dark

define theme_light() as:
    return _theme_light

define theme_high_contrast() as:
    return _theme_high_contrast
