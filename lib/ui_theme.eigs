# ---- High-contrast theme ----

_theme_high_contrast is {
    "bg": [0, 0, 0],
    "panel_bg": [10, 10, 10],
    "panel_border": [255, 255, 255],
    "btn_bg": [30, 30, 30],
    "btn_hover": [50, 50, 50],
    "btn_pressed": [20, 20, 20],
    "btn_disabled": [15, 15, 15],
    "btn_text": [255, 255, 255],
    "btn_text_disabled": [80, 80, 80],
