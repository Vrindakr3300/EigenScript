{
    "name": "EigenScript",
    "scopeName": "source.eigenscript",
    "fileTypes": ["eigs"],
    "patterns": [
        { "include": "#comment" },
        { "include": "#fstring" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#function-definition" },
        { "include": "#keyword-control" },
        { "include": "#keyword-operator" },
        { "include": "#interrogative" },
        { "include": "#predicate" },
        { "include": "#builtin-function" },
        { "include": "#constant" },
        { "include": "#operator" },
        { "include": "#identifier" }
    ],
    "repository": {
        "comment": {
            "match": "#.*$",
            "name": "comment.line.number-sign.eigenscript"
        },
        "fstring": {
            "begin": "f\"",
            "end": "\"",
            "name": "string.quoted.double.interpolated.eigenscript",
            "patterns": [
                {
                    "begin": "\\{",
                    "end": "\\}",
                    "name": "meta.interpolation.eigenscript",
                    "patterns": [
                        { "include": "source.eigenscript" }
                    ],
                    "beginCaptures": {
                        "0": { "name": "punctuation.section.interpolation.begin.eigenscript" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.section.interpolation.end.eigenscript" }
                    }
                },
                {
                    "match": "\\\\[ntr\\\\\"{}]",
                    "name": "constant.character.escape.eigenscript"
                }
            ]
        },
        "string": {
            "begin": "\"",
            "end": "\"",
            "name": "string.quoted.double.eigenscript",
            "patterns": [
                {
                    "match": "\\\\[ntr\\\\\"{}]",
                    "name": "constant.character.escape.eigenscript"
                }
            ]
        },
        "number": {
            "match": "\\b\\d+(\\.\\d+)?\\b",
            "name": "constant.numeric.eigenscript"
        },
        "function-definition": {
            "match": "\\b(define)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.other.definition.eigenscript" },
                "2": { "name": "entity.name.function.eigenscript" }
            }
        },
        "keyword-control": {
            "match": "\\b(is|of|define|as|if|else|elif|loop|while|for|in|return|try|catch|break|continue|import|match|case|unobserved|local)\\b",
            "name": "keyword.control.eigenscript"
        },
        "keyword-operator": {
            "match": "\\b(and|or|not)\\b",
            "name": "keyword.operator.logical.eigenscript"
        },
        "interrogative": {
            "match": "\\b(what|who|when|where|why|how)\\b",
            "name": "keyword.other.interrogative.eigenscript"
        },
        "predicate": {
            "match": "\\b(converged|stable|improving|oscillating|diverging|equilibrium)\\b",
            "name": "keyword.other.predicate.eigenscript"
        },
        "builtin-function": {
            "match": "\\b(print|len|append|type|range|str|num|keys|values|has_key|dict_set|floor|ceil|round|abs|min|max|sqrt|sin|cos|split|scan_ints|join|trim|contains|substr|index_of|str_replace|read_text|write_text|file_exists|json_encode|json_decode|spawn|thread_join|channel|send|recv|store_open|store_put|store_get|store_query|store_close|assert|observe|report|sort|reverse|map|filter|reduce|exec|exit|time|sleep|random|input|eval)\\b",
            "name": "support.function.builtin.eigenscript"
        },
        "constant": {
            "match": "\\b(true|false|null)\\b",
            "name": "constant.language.eigenscript"
        },
        "operator": {
            "match": "(\\|>|=>|==|!=|<=|>=|[+\\-*/%<>=])",
            "name": "keyword.operator.eigenscript"
        },
        "identifier": {
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
            "name": "variable.other.eigenscript"
        }
    }
}
