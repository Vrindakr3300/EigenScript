{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": ":\\s*(#.*)?$",
    "decreaseIndentPattern": "^\\s*(return|break|continue)\\b.*$"
  },
  "onEnterRules": [
    {
      "beforeText": ":\\s*(#.*)?$",
      "action": { "indent": "indent" }
    }
  ]
}
