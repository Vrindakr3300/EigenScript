{
  "name": "eigenscript",
  "displayName": "EigenScript",
  "description": "Syntax highlighting and editor support for the EigenScript language (.eigs)",
  "version": "0.13.0",
  "publisher": "inauguralsystems",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/InauguralSystems/EigenScript",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "eigenscript",
        "aliases": ["EigenScript", "eigenscript"],
        "extensions": [".eigs"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "eigenscript",
        "scopeName": "source.eigenscript",
        "path": "./syntaxes/eigenscript.tmLanguage.json"
      }
    ]
  }
}
